# Caddy reverse proxy with automatic HTTPS for an R2 wayfinder.
# Replace wayfinder.example.com with your domain. Caddy obtains and
# renews a Let's Encrypt certificate automatically and upgrades the
# /r2 and /r2/mgmt WebSockets.
#
# Usage:
#   caddy run --config Caddyfile

wayfinder.example.com {
    reverse_proxy localhost:21042
}
