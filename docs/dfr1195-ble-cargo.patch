diff --git a/platforms/dfr1195/Cargo.toml b/platforms/dfr1195/Cargo.toml
index 5a3c89f..bbc5f37 100644
--- a/platforms/dfr1195/Cargo.toml
+++ b/platforms/dfr1195/Cargo.toml
@@ -14,6 +14,10 @@ path = "src/main.rs"
 r2-wire = { path = "../../crates/r2-wire", default-features = false }
 r2-transport = { path = "../../crates/r2-transport", default-features = false }
 r2-route = { path = "../../crates/r2-route", default-features = false }
+r2-cbor = { path = "../../crates/r2-cbor", default-features = false }
+# Intra-TG trust: GroupHmac deliver-gate (HMAC-SHA256). r2-fnv for the TG-hash.
+r2-trust = { path = "../../crates/r2-trust", default-features = false }
+r2-fnv = { path = "../../crates/r2-fnv" }
 # r2-discovery non-alloc core types (HiveId/TransportId) — no async API at this tier.
 r2-discovery = { path = "../../crates/r2-discovery", default-features = false }
 
@@ -21,18 +25,29 @@ r2-discovery = { path = "../../crates/r2-discovery", default-features = false }
 # VERSION PINS — hive: confirm against the installed toolchain before flashing.
 # esp-hal/esp-wifi APIs churn between minor versions; these are the shapes the
 # skeleton is written against.
-esp-hal = { version = "0.23", features = ["esp32s3"] }
-esp-hal-embassy = { version = "0.6", features = ["esp32s3"] }
-esp-wifi = { version = "0.12", features = ["esp32s3", "wifi", "ble", "utils"] }
-esp-alloc = "0.6"
-esp-backtrace = { version = "0.15", features = ["esp32s3", "panic-handler", "println"] }
-esp-println = { version = "0.13", features = ["esp32s3"] }
-
-embassy-executor = { version = "0.7", features = ["task-arena-size-32768"] }
-embassy-time = "0.4"
-embassy-net = { version = "0.6", features = ["udp", "proto-ipv4", "medium-ethernet", "dhcpv4"] }
-embassy-sync = "0.6"
+esp-hal = { version = "1.1.1", features = ["esp32s3", "unstable"] }
+esp-alloc = "0.10.0"
+esp-backtrace = { version = "0.17.0", features = ["esp32s3", "panic-handler", "println"] }
+esp-println = { version = "0.15.0", features = ["esp32s3"] }
+# App descriptor required by espflash 4.4.0 (esp-hal 1.x flow) — emits esp_app_desc_t.
+# Must match espflash 4.4.0's expected descriptor format (0.5.x line, not 0.2.x).
+esp-bootloader-esp-idf = { version = "0.5.0", features = ["esp32s3"] }
+
+# ── Async/WiFi tier (the WiFi-UDP milestone) — VERIFIED RESOLVING MATRIX ──────
+# CRITICAL: on the esp-hal 1.1.x line the WiFi crate is esp-RADIO (NOT esp-wifi:
+# esp-wifi 0.15.x links-collides on xtensa-lx-rt ^0.20 vs esp-hal's ^0.22), and the
+# scheduler is esp-RTOS (NOT esp-hal-embassy, which wants a private esp-hal feature
+# no 1.x exposes). esp-radio needs default-features=false (its default builtin-
+# scheduler also wants a private feature). Embassy jumps to net 0.9/sync 0.7/exec
+# 0.10/time 0.5. See memory: esp32-wifi-embassy-matrix.
+esp-rtos = { version = "0.3.0", features = ["esp32s3", "embassy", "esp-radio", "esp-alloc"] }
+esp-radio = { version = "0.18", default-features = false, features = ["esp32s3", "wifi", "unstable"] }
+embassy-executor = { version = "0.10", default-features = false }
+embassy-time = "0.5"
+embassy-sync = "0.7"
+embassy-net = { version = "0.9", features = ["udp", "proto-ipv4", "medium-ethernet", "dhcpv4"] }
 embassy-futures = "0.1"
+static_cell = "2"
 
 # SX1262 LoRa: driven via embedded-hal SPI. The binding is GENERIC over
 # composer's chip-agnostic radio trait (SX1262 + LR2021) — see src/lora.rs.
@@ -40,6 +55,30 @@ embassy-futures = "0.1"
 # here to avoid pinning an SX1262-specific surface prematurely.
 embedded-hal = "1.0"
 heapless = "0.8"
+# Network-OTA (#17): flash backend (esp-hal 1.1 has no flash module) + the storage trait.
+esp-storage = { version = "0.6", features = ["esp32s3"] }
+embedded-storage = "0.3.1"
+# OTA receiver (#17): streamed-image integrity (SHA-256 over the unpadded image).
+sha2 = { version = "0.10", default-features = false }
+# Real-TG persona (#20): hive_id derived via the CANONICAL r2_trust::derive_hive_id.
+
+# On-device proof-surface LCD (ST7735S 160x80) — first-light liveness screen:
+# status line on top + events scrolling up. Stepping stone to the general display
+# plugin (composer's CMD_RENDER contract) once the plugin runtime lands.
+mipidsi = "0.9.0"
+embedded-graphics = "0.8.1"
+embedded-hal-bus = "0.3.0"
+
+# #24 BLE control plane — feature-gated, OFF by default so the live firmware builds unchanged.
+# esp-radio BLE controller (BleConnector impls bt-hci Transport) -> trouble-host (advertise/scan/
+# L2CAP CoC). WiFi+BLE coex via esp-radio/coex. trouble MUST use the same bt-hci major as esp-radio
+# (0.8) — trouble 0.2 used bt-hci 0.3 (mismatch); let cargo pick the bt-hci-0.8-compatible trouble.
+# trouble 0.6 = the version pinned to bt-hci 0.8 (matches esp-radio 0.18's bt-hci). 0.2=bt-hci0.3, 0.7=bt-hci0.9 (both mismatch).
+trouble-host = { version = "0.6", optional = true, default-features = false, features = ["central", "peripheral", "default-packet-pool", "default-packet-pool-mtu-251"] }
+
+[features]
+default = []
+ble = ["esp-radio/ble", "esp-radio/coex", "dep:trouble-host"]
 
 [profile.release]
 opt-level = "s"
