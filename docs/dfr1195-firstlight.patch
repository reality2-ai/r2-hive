+}
+
+/// Push an event line, evicting the oldest when the log is full (scroll up).
+fn push_event(events: &mut EventLog, s: &str) {
+    if events.is_full() {
+        let _ = events.pop_front();
+    }
+    let mut line: heapless::String<26> = heapless::String::new();
+    let _ = line.push_str(s);
+    let _ = events.push_back(line);
+}
+
+/// Render: cyan status line on top, white event lines below (oldest→newest, so new
+/// events appear at the bottom and everything scrolls up as the log fills).
+fn render<D>(display: &mut D, status: &str, events: &EventLog)
+where
+    D: DrawTarget<Color = Rgb565>,
+{
+    let _ = display.clear(Rgb565::BLACK);
+    let status_style = MonoTextStyle::new(&FONT_6X10, Rgb565::CYAN);
+    let event_style = MonoTextStyle::new(&FONT_6X10, Rgb565::WHITE);
+    let _ = Text::new(status, Point::new(2, 8), status_style).draw(display);
+    let mut y = 22;
+    for e in events.iter() {
+        let _ = Text::new(e.as_str(), Point::new(2, y), event_style).draw(display);
+        y += 10;
     }
 }
