+/// Log an aggregated/received health CBOR as a hex line for composer's serial-reader.
+fn log_health(cbor: &[u8]) {
+    let mut hx: heapless::String<320> = heapless::String::new();
+    for b in cbor {
+        let _ = write!(hx, "{b:02x}");
+    }
+    println!("r2-dfr1195: HEALTH {hx}");
+}
