+// ── M8: NegotiationRadio sync↔async bridge ─────────────────────────────────────
+// The trait is SYNC (engine.poll); BLE is async. Bridge via static queues: the async BLE tasks
+// (scan handler / conn-manager) fill+drain them; the sync EspNegRadio façade push/pops for the engine.
+#[cfg(feature = "ble")]
+type CtrlItem = (u32, [u8; 103], usize); // (peer_hive, encoded ControlMsg, len)
+#[cfg(feature = "ble")]
+static SCAN_OBS: embassy_sync::blocking_mutex::Mutex<CriticalSectionRawMutex, core::cell::RefCell<heapless::Deque<(u32, bool, u8), 16>>> =
+    embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(heapless::Deque::new()));
+#[cfg(feature = "ble")]
+static CTRL_OUT: embassy_sync::blocking_mutex::Mutex<CriticalSectionRawMutex, core::cell::RefCell<heapless::Deque<CtrlItem, 8>>> =
+    embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(heapless::Deque::new()));
+#[cfg(feature = "ble")]
+static CTRL_IN: embassy_sync::blocking_mutex::Mutex<CriticalSectionRawMutex, core::cell::RefCell<heapless::Deque<CtrlItem, 8>>> =
+    embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(heapless::Deque::new()));
+#[cfg(feature = "ble")]
+static DATA_PLANE_AVAIL: AtomicBool = AtomicBool::new(false);
+/// Signalled by join_provider → the wifi task connects the joiner to the provider's SoftAP (M8c).
+#[cfg(feature = "ble")]
+static DATA_PLANE_JOIN: Signal<CriticalSectionRawMutex, ()> = Signal::new();
