+// ── M8: NegotiationRadio sync↔async bridge ─────────────────────────────────────
+// The trait is SYNC (engine.poll); BLE is async. Bridge via static queues: the async BLE tasks
+// (scan handler / conn-manager) fill+drain them; the sync EspNegRadio façade push/pops for the engine.
+#[cfg(feature = "ble")]
+type CtrlItem = (u32, [u8; 103], usize); // (peer_hive, encoded ControlMsg, len)
+#[cfg(feature = "ble")]
+static SCAN_OBS: embassy_sync::blocking_mutex::Mutex<CriticalSectionRawMutex, core::cell::RefCell<heapless::Deque<(u32, bool, u8), 16>>> =
+    embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(heapless::Deque::new()));
+#[cfg(feature = "ble")]
+static CTRL_OUT: embassy_sync::blocking_mutex::Mutex<CriticalSectionRawMutex, core::cell::RefCell<heapless::Deque<CtrlItem, 8>>> =
+    embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(heapless::Deque::new()));
+#[cfg(feature = "ble")]
+static CTRL_IN: embassy_sync::blocking_mutex::Mutex<CriticalSectionRawMutex, core::cell::RefCell<heapless::Deque<CtrlItem, 8>>> =
+    embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(heapless::Deque::new()));
+#[cfg(feature = "ble")]
+static DATA_PLANE_AVAIL: AtomicBool = AtomicBool::new(false);
+/// Signalled by join_provider → the wifi task connects the joiner to the provider's SoftAP (M8c).
+#[cfg(feature = "ble")]
+static DATA_PLANE_JOIN: Signal<CriticalSectionRawMutex, ()> = Signal::new();
+
+/// Heartbeat-over-ESP-NOW BRIDGE (mesh): io_task's PROVEN conductor-PLL drives these channels instead of
+/// the UDP socket (cfg-gated). DATA_TX = beats io_task wants broadcast → espnow_task ESP-NOW-broadcasts.
+/// DATA_RX = frames espnow_task received → io_task's recv-select reads them. Reuses the exact PLL, no AP.
+#[cfg(feature = "ble")]
+type MeshFrame = ([u8; 256], usize);
+// DATA_RX carries the immediate-sender hive (resolved from the L2 src MAC in espnow_task) so the
+// §4.3.4 TrailReinforcer (routetest) can weak/strong-reinforce toward it. 0 = unknown sender.
+#[cfg(feature = "ble")]
+// (frame, len, immediate-sender hive, RX transport ordinal). The 4th field is the r2_route::Transport
+// ordinal of the carrier the frame was RECEIVED on (Ble0/Wifi1/Lora2/Internet3/Usb4/EspNow5/Udp6) — set
+// by each feeder (espnow/lora/blemesh). This is the per-hop link-usage tap: every received frame counts
+// one real traversal of the (sender, transport) link. Telemetry only — it never re-enters the wire.
+type MeshRxFrame = ([u8; 256], usize, u32, u8);
+// Transport label for accurate serial evidence (Roy's eyes = ground truth — never log "esp-now" over BLE).
+#[cfg(all(feature = "ble", not(feature = "blemesh")))]
+const MESH_LABEL: &str = "esp-now";
+#[cfg(feature = "blemesh")]
+const MESH_LABEL: &str = "ble";
+#[cfg(all(feature = "ble", not(feature = "blemesh")))]
+const COC_PLANE: &str = "control plane";
+#[cfg(feature = "blemesh")]
+const COC_PLANE: &str = "BLE data-mesh (R2 frames: heartbeat + GroupHmac delivery)";
+#[cfg(feature = "ble")]
+static DATA_TX: embassy_sync::channel::Channel<CriticalSectionRawMutex, MeshFrame, 4> =
+    embassy_sync::channel::Channel::new();
+#[cfg(feature = "ble")]
+static DATA_RX: embassy_sync::channel::Channel<CriticalSectionRawMutex, MeshRxFrame, 4> =
+    embassy_sync::channel::Channel::new();
+// TN-FR-2: the LoRa egress queue (separate from DATA_TX = the ESP-NOW egress). A consuming channel routes a
+// frame to ONE drainer, so the bridge needs per-transport TX channels: lora_route_task drains DATA_TX_LORA,
+// espnow_task drains DATA_TX. io_task's mesh_broadcast pushes to the carrier(s) this node runs.
+#[cfg(feature = "loraroute")]
+static DATA_TX_LORA: embassy_sync::channel::Channel<CriticalSectionRawMutex, MeshFrame, 4> =
+    embassy_sync::channel::Channel::new();
+
+/// Broadcast an io_task frame onto THIS node's carrier(s). loraroute -> the LoRa carrier (DATA_TX_LORA);
+/// ESP-NOW (incl. the bridge) -> DATA_TX. A BRIDGE (loraroute+bridge) pushes to BOTH = the cross-transport
+/// relay: the engine/dedup make it dedup-ONCE-across-transports (DG-2), and the flood reaches the other
+/// island. A LoRa leaf pushes only LoRa; the ESP-NOW receiver pushes only ESP-NOW.
+#[cfg(feature = "ble")]
+fn mesh_broadcast(f: [u8; 256], n: usize) {
+    #[cfg(feature = "loraroute")]
+    let _ = DATA_TX_LORA.try_send((f, n));
+    #[cfg(any(not(feature = "loraroute"), feature = "bridge"))]
+    let _ = DATA_TX.try_send((f, n));
+}
+
+/// M-ESPNOW-2: hive_id↔WiFi-MAC map, LEARNED from the ESP-NOW recv src (core's design — no MAC in the
+/// beacon). Populated from each received frame's originator hive + its L2 src MAC. r2-route unicast
+/// (M-ESPNOW-3) looks up map[hive_id] → ESP-NOW send_to(mac). Broadcast (heartbeat) needs no map.
+#[cfg(feature = "ble")]
+static HIVE_MAC: embassy_sync::blocking_mutex::Mutex<
+    CriticalSectionRawMutex,
+    core::cell::RefCell<heapless::Vec<(u32, [u8; 6]), 16>>,
+> = embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(heapless::Vec::new()));
+
+/// M-ESPNOW-3b BENCH multi-hop allow-list (core's technique): a per-board can-hear MAC set, applied at
+/// the ESP-NOW recv BEFORE r2-route, so A→B→C relay is exercised on a bench (all 1-hop in-range) without
+/// physical separation. Topology: A(0dcadbf8)={B}, B(2cab5f69)={A,C}, C(f91c8911)={B} → A↔C NOT direct →
+/// A→C only via B's relay. Other boards: no mask (true). Invisible to r2-route (just shapes its neighbours).
+#[cfg(feature = "ble")]
+// routetest: runtime topology mask = this board's allowed-neighbour MAC allow-list (empty = hear all).
+// BL-103: ROUTE-engine clock accelerator. Scales the time fed to decay_neighbours/decay_paths/ingest so
+// the §2.5 eviction horizon (1800s hard timeout / conf<0.01) is crossed in seconds. Dashboard liveness
+// (seen/MESH_PEER_TTL_S) uses REAL time — only the engine-facing clock scales here. FACTOR 120: a 30s
+// blackout silence = 3600 route-s (2x the hard timeout) -> the silent board evicts mid-blackout.
+// x40: silent board evicts ~42s into the blackout (conf<0.01 at 1680/40s), while an ACTIVE neighbour
+// (refreshed every ~2s -> mild 0.83 conf-decay/beat) stays well above threshold. x120 was too steep
+// (0.57/beat) -> it evicted active neighbours too, losing the silent-vs-active contrast.
+#[cfg(feature = "fastevict")]
+const ROUTE_TIME_FACTOR: u32 = 20;
+fn route_now_s() -> u32 {
+    let r = embassy_time::Instant::now().as_secs() as u32;
+    #[cfg(feature = "fastevict")]
+    {
+        r.wrapping_mul(ROUTE_TIME_FACTOR)
+    }
+    #[cfg(not(feature = "fastevict"))]
+    {
+        r
+    }
+}
+
+// The runner pushes 'MASK <mac>...' to each board's own tty to shape an arbitrary topology (chain,
+// diamond, …) on the full-mesh RF. Mirrors the hardcoded meshmask but configurable per scenario.
+#[cfg(feature = "routetest")]
+static MASK_LIST: embassy_sync::blocking_mutex::Mutex<
+    CriticalSectionRawMutex,
+    core::cell::RefCell<heapless::Vec<[u8; 6], 8>>,
+> = embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(heapless::Vec::new()));
+
+/// Set this board's allowed-neighbour MAC list (from a 'MASK' serial command). Empty = hear all.
+#[cfg(feature = "routetest")]
+fn set_mask(macs: &[[u8; 6]]) {
+    MASK_LIST.lock(|c| {
+        let mut v = c.borrow_mut();
+        v.clear();
+        for m in macs.iter().take(8) {
+            let _ = v.push(*m);
+        }
+    });
+    write_mask_nvs(macs); // persist so it survives the capture's serial-open DTR-reset (NVS @0x15000)
+}
+
+// MASK persisted to NVS @0x15000 (own 4KB sector, after provision@0x14000, below ota_0@0x20000) so the
+// topology survives a board reset (the capture's serial-open toggles DTR -> reset -> RAM MASK would clear).
+// Layout: [magic u32 BE]["R2MK"][count u8][count×6 MAC bytes].
+#[cfg(feature = "routetest")]
+const MASK_NVS_OFFSET: u32 = 0x15000;
+#[cfg(feature = "routetest")]
+const MASK_NVS_MAGIC: u32 = 0x5232_4d4b; // "R2MK"
+
+#[cfg(feature = "routetest")]
+fn write_mask_nvs(macs: &[[u8; 6]]) {
+    use embedded_storage::Storage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 64];
+    b[0..4].copy_from_slice(&MASK_NVS_MAGIC.to_be_bytes());
+    let n = macs.len().min(8);
+    b[4] = n as u8;
+    for (i, m) in macs.iter().take(8).enumerate() {
+        b[5 + i * 6..5 + i * 6 + 6].copy_from_slice(m);
+    }
+    let _ = flash.write(MASK_NVS_OFFSET, &b);
+}
+
+// SENDTO (BL-200 origin dest) persisted to NVS @0x16000 — survives the capture DTR-reset like the MASK.
+#[cfg(feature = "routetest")]
+const DEST_NVS_OFFSET: u32 = 0x16000;
+#[cfg(feature = "routetest")]
+const DEST_NVS_MAGIC: u32 = 0x5232_4453; // "R2DS"
+
+#[cfg(feature = "routetest")]
+fn write_dest_nvs(dest: u32) {
+    use embedded_storage::Storage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 8];
+    b[0..4].copy_from_slice(&DEST_NVS_MAGIC.to_be_bytes());
+    b[4..8].copy_from_slice(&dest.to_be_bytes());
+    let _ = flash.write(DEST_NVS_OFFSET, &b);
+}
+
+#[cfg(feature = "routetest")]
+fn read_dest_nvs() -> Option<u32> {
+    use embedded_storage::ReadStorage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 8];
+    flash.read(DEST_NVS_OFFSET, &mut b).ok()?;
+    if u32::from_be_bytes([b[0], b[1], b[2], b[3]]) != DEST_NVS_MAGIC {
+        return None;
+    }
+    Some(u32::from_be_bytes([b[4], b[5], b[6], b[7]]))
+}
+
+/// Restore the persisted MASK at boot (None if unset/erased). Re-arms can_hear before the radio starts.
+#[cfg(feature = "routetest")]
+fn read_mask_nvs() -> Option<heapless::Vec<[u8; 6], 8>> {
+    use embedded_storage::ReadStorage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 64];
+    flash.read(MASK_NVS_OFFSET, &mut b).ok()?;
+    if u32::from_be_bytes([b[0], b[1], b[2], b[3]]) != MASK_NVS_MAGIC {
+        return None;
+    }
+    let n = (b[4] as usize).min(8);
+    let mut v: heapless::Vec<[u8; 6], 8> = heapless::Vec::new();
+    for i in 0..n {
+        let mut m = [0u8; 6];
+        m.copy_from_slice(&b[5 + i * 6..5 + i * 6 + 6]);
+        let _ = v.push(m);
+    }
+    Some(v)
+}
+
+/// True if `src` is in the allow-list (or the list is empty = hear all). The topology gate.
+#[cfg(feature = "routetest")]
+fn mask_allows(src: &[u8; 6]) -> bool {
+    MASK_LIST.lock(|c| {
+        let v = c.borrow();
+        v.is_empty() || v.iter().any(|m| m == src)
+    })
+}
+
+fn can_hear(_my_hive: u32, _src: &[u8; 6]) -> bool {
+    // routetest: the runtime allow-list shapes the topology (set per-scenario via the MASK cmd).
+    #[cfg(feature = "routetest")]
+    {
+        return mask_allows(_src);
+    }
+    // GENERAL no-AP mesh (default): every node hears every in-range peer → self-growing (N-join) +
+    // self-healing (reform). This is the real-world TN case for mobile wearables.
+    #[cfg(all(not(feature = "meshmask"), not(feature = "routetest")))]
+    {
+        true
+    }
+    // BENCH multi-hop mask (meshmask): hide A↔C so A→B→C relay is forced on a bench (no physical range).
+    #[cfg(all(feature = "meshmask", not(feature = "routetest")))]
+    {
+        const A: [u8; 6] = [0xf4, 0x12, 0xfa, 0x50, 0x23, 0xe4]; // 0dcadbf8
+        const B: [u8; 6] = [0xf4, 0x12, 0xfa, 0xb7, 0x90, 0x10]; // 2cab5f69
+        const C: [u8; 6] = [0xf4, 0x12, 0xfa, 0xb6, 0x0a, 0xa0]; // f91c8911
+        match _my_hive {
+            0x0dca_dbf8 => *_src == B,
+            0x2cab_5f69 => *_src == A || *_src == C,
+            0xf91c_8911 => *_src == B,
+            _ => true,
+        }
+    }
+}
+
+/// Upsert a learned hive_id↔MAC pair (M-ESPNOW-2). Returns true if newly mapped (for logging).
+#[cfg(feature = "ble")]
+fn map_peer(hive: u32, mac: [u8; 6]) -> bool {
+    HIVE_MAC.lock(|c| {
+        let mut v = c.borrow_mut();
+        if let Some(e) = v.iter_mut().find(|(h, _)| *h == hive) {
+            e.1 = mac;
+            false
+        } else {
+            let _ = v.push((hive, mac));
+            true
+        }
+    })
+}
+
+/// Reverse lookup: the immediate-sender hive for an L2 src MAC (learned from heartbeats). 0 = unknown
+/// (peer not heartbeated yet). Used to thread src_hive into DATA_RX for the §4.3.4 TrailReinforcer.
+#[cfg(feature = "ble")]
+fn hive_for_mac(mac: &[u8; 6]) -> u32 {
+    HIVE_MAC.lock(|c| {
+        c.borrow()
+            .iter()
+            .find(|(_, m)| m == mac)
+            .map(|(h, _)| *h)
+            .unwrap_or(0)
+    })
+}
