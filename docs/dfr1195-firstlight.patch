+/// Heartbeat-over-ESP-NOW BRIDGE (mesh): io_task's PROVEN conductor-PLL drives these channels instead of
+/// the UDP socket (cfg-gated). DATA_TX = beats io_task wants broadcast → espnow_task ESP-NOW-broadcasts.
+/// DATA_RX = frames espnow_task received → io_task's recv-select reads them. Reuses the exact PLL, no AP.
+#[cfg(feature = "ble")]
+type MeshFrame = ([u8; 256], usize);
+// DATA_RX carries the immediate-sender hive (resolved from the L2 src MAC in espnow_task) so the
+// §4.3.4 TrailReinforcer (routetest) can weak/strong-reinforce toward it. 0 = unknown sender.
+#[cfg(feature = "ble")]
+type MeshRxFrame = ([u8; 256], usize, u32);
+// Transport label for accurate serial evidence (Roy's eyes = ground truth — never log "esp-now" over BLE).
+#[cfg(all(feature = "ble", not(feature = "blemesh")))]
+const MESH_LABEL: &str = "esp-now";
+#[cfg(feature = "blemesh")]
+const MESH_LABEL: &str = "ble";
+#[cfg(all(feature = "ble", not(feature = "blemesh")))]
+const COC_PLANE: &str = "control plane";
+#[cfg(feature = "blemesh")]
+const COC_PLANE: &str = "BLE data-mesh (R2 frames: heartbeat + GroupHmac delivery)";
+#[cfg(feature = "ble")]
+static DATA_TX: embassy_sync::channel::Channel<CriticalSectionRawMutex, MeshFrame, 4> =
+    embassy_sync::channel::Channel::new();
+#[cfg(feature = "ble")]
+static DATA_RX: embassy_sync::channel::Channel<CriticalSectionRawMutex, MeshRxFrame, 4> =
+    embassy_sync::channel::Channel::new();
+
+/// M-ESPNOW-2: hive_id↔WiFi-MAC map, LEARNED from the ESP-NOW recv src (core's design — no MAC in the
+/// beacon). Populated from each received frame's originator hive + its L2 src MAC. r2-route unicast
+/// (M-ESPNOW-3) looks up map[hive_id] → ESP-NOW send_to(mac). Broadcast (heartbeat) needs no map.
+#[cfg(feature = "ble")]
+static HIVE_MAC: embassy_sync::blocking_mutex::Mutex<
+    CriticalSectionRawMutex,
+    core::cell::RefCell<heapless::Vec<(u32, [u8; 6]), 16>>,
+> = embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(heapless::Vec::new()));
+
+/// M-ESPNOW-3b BENCH multi-hop allow-list (core's technique): a per-board can-hear MAC set, applied at
+/// the ESP-NOW recv BEFORE r2-route, so A→B→C relay is exercised on a bench (all 1-hop in-range) without
+/// physical separation. Topology: A(0dcadbf8)={B}, B(2cab5f69)={A,C}, C(f91c8911)={B} → A↔C NOT direct →
+/// A→C only via B's relay. Other boards: no mask (true). Invisible to r2-route (just shapes its neighbours).
+#[cfg(feature = "ble")]
+// routetest: runtime topology mask = this board's allowed-neighbour MAC allow-list (empty = hear all).
+// BL-103: ROUTE-engine clock accelerator. Scales the time fed to decay_neighbours/decay_paths/ingest so
+// the §2.5 eviction horizon (1800s hard timeout / conf<0.01) is crossed in seconds. Dashboard liveness
+// (seen/MESH_PEER_TTL_S) uses REAL time — only the engine-facing clock scales here. FACTOR 120: a 30s
+// blackout silence = 3600 route-s (2x the hard timeout) -> the silent board evicts mid-blackout.
+// x40: silent board evicts ~42s into the blackout (conf<0.01 at 1680/40s), while an ACTIVE neighbour
+// (refreshed every ~2s -> mild 0.83 conf-decay/beat) stays well above threshold. x120 was too steep
+// (0.57/beat) -> it evicted active neighbours too, losing the silent-vs-active contrast.
+#[cfg(feature = "fastevict")]
+const ROUTE_TIME_FACTOR: u32 = 20;
+fn route_now_s() -> u32 {
+    let r = embassy_time::Instant::now().as_secs() as u32;
+    #[cfg(feature = "fastevict")]
+    {
+        r.wrapping_mul(ROUTE_TIME_FACTOR)
+    }
+    #[cfg(not(feature = "fastevict"))]
+    {
+        r
+    }
+}
