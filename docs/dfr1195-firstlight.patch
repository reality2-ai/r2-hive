+                            msg_type: h.msg_type,
+                            payload_len: m.payload.len(),
+                            relay_enabled: true,
+                            congested: false,
+                            dice_roll: 0.0,
+                        };
+                        let advice = engine.plan_forward(req);
+                        let for_me = h.target_hive == my_hive || h.target_hive == 0;
+                        if matches!(advice.action, ForwardAction::Drop(DropReason::Duplicate)) {
+                            println!("r2-dfr1195: DEDUP msg_id={} dropped", h.msg_id);
+                        } else if for_me {
+                            DELIVERED.fetch_add(1, Ordering::Relaxed);
+                            let body = core::str::from_utf8(m.payload).unwrap_or("?");
+                            println!("r2-dfr1195: DELIVERED msg_id={} '{}'", h.msg_id, body);
+                        }
+                    }
+                },
+                Err(e) => println!("r2-dfr1195: decode err {e:?}"),
+            },
+            Either::Second(Err(e)) => println!("r2-dfr1195: RX err {e:?}"),
+        }
+    }
+}
+
+/// R2 mesh UDP port (R2-WIFI §4).
+const R2_UDP_PORT: u16 = 21042;
+
+/// embassy-net background runner — required for the stack to make progress.
+#[embassy_executor::task]
+async fn net_task(mut runner: Runner<'static, wifi::Interface<'static>>) -> ! {
+    runner.run().await
+}
+
+/// WiFi event loop. STA: connect + reconnect on drop. AP: already up; observe joins.
+#[embassy_executor::task]
+async fn wifi_task(mut controller: WifiController<'static>, is_ap: bool) {
+    if is_ap {
+        loop {
+            match controller.wait_for_access_point_connected_event_async().await {
+                Ok(_) => println!("r2-dfr1195: [ap] station joined"),
+                Err(e) => println!("r2-dfr1195: [ap] event err {e:?}"),
+            }
+        }
+    } else {
+        loop {
+            match controller.connect_async().await {
+                Ok(_) => {
+                    println!("r2-dfr1195: [sta] connected to {FIELDLAB_SSID}");
+                    let _ = controller.wait_for_disconnect_async().await;
+                    println!("r2-dfr1195: [sta] disconnected, retrying");
+                }
+                Err(e) => {
+                    println!("r2-dfr1195: [sta] connect failed {e:?}, retry 2s");
+                    Timer::after(Duration::from_secs(2)).await;
+                }
+            }
+        }
     }
 }
