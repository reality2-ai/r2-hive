+// ═══════════════════════════════════════════════════════════════════════════════════════════════
+//  RADAR Modbus-RTU PROBE (feature `radarprobe`) — standalone RS-485 sweep, no radio stack.
+//  esp-hal 1.1.1 API source-verified (Config builders with_baudrate/with_data_bits/with_parity/
+//  with_stop_bits; DataBits::_8/Parity::None/StopBits::_1; new/with_tx/with_rx; apply_config for the
+//  LIVE baud sweep; write()=short-write→loop; flush()=true tx-idle (mod.rs:850/906) = the only safe
+//  DE/RE de-assert point; read_ready()+read_buffered() + a software deadline since read() never times
+//  out). Modbus CRC + framing independently re-derived (poly 0xA001/init 0xFFFF; {01 04 00 00 00 01}
+//  -> wire 31 CA). Output: USB-Serial-JTAG println! (the UART1 line IS the RS-485 bus — never log there).
+// ═══════════════════════════════════════════════════════════════════════════════════════════════
+#[cfg(feature = "radarprobe")]
+mod radarprobe {
+    use super::*;
+    use core::fmt::Write as _;
+    use embassy_time::Instant;
+    use esp_hal::gpio::Output;
+    use esp_hal::uart::{Config as UartConfig, DataBits, Parity, RxError, StopBits, Uart};
+    use esp_hal::Blocking;
+
+    // ─── PIN MAP (from Roy 2026-06-27): XIAO ESP32-S3 + MAX485. D-header→GPIO: D5=6 D6=43 D7=44 ───
+    pub const RADAR_UART_TX: u8 = 43; // XIAO D6 / GPIO43 → MAX485 DI  (UART1 TX)
+    pub const RADAR_UART_RX: u8 = 44; // XIAO D7 / GPIO44 ← MAX485 RO  (UART1 RX)
+    pub const RADAR_DE_RE: u8 = 6; //   XIAO D5 / GPIO6  → MAX485 DE+!RE tied (HIGH=TX, LOW=RX)
+    // Frame format. 8 data bits, 1 stop. PARITY is now SWEPT (radar may be 8N1/8E1/8O1 — Modbus's spec
+    // default is actually 8E1) so we don't have to guess. Stop bits fixed _1 (8N2 covered by the gap math).
+    const RADAR_DATA_BITS: DataBits = DataBits::_8;
+    const RADAR_STOP_BITS: StopBits = StopBits::_1;
+    // Parity sweep (outer loop) — None first (most common cheap sensors), then Even (Modbus default), Odd.
+    pub const RADAR_PARITIES: &[Parity] = &[Parity::None, Parity::Even, Parity::Odd];
+    // Baud sweep — the full common Modbus set (2400..115200), most likely first.
+    pub const RADAR_BAUDS: &[u32] = &[9600, 115200, 19200, 38400, 57600, 4800, 2400];
+    // Address scan: 1 first, then dense 1..=20, then sparse to 247. (addr 0 = broadcast, never probed.)
+    const RADAR_ADDR_DENSE_HI: u8 = 20;
+    const RADAR_ADDR_SPARSE: &[u8] = &[30, 40, 50, 60, 80, 100, 120, 160, 200, 240, 247];
+    // Timeouts. T3.5 inter-frame: char-time ≤19200, fixed ~1.75ms >19200 (Modbus serial spec) — use a 3ms
+    // floor that satisfies both. Per-(baud,addr) response wall-clock deadline kept generous for slow slaves.
+    const RADAR_RESP_TIMEOUT_MS: u64 = 120;
+    const RADAR_INTERCHAR_GAP_MS: u64 = 3;
+    const RADAR_PRE_RECONFIG_IDLE_MS: u64 = 20;
+
+    /// CRC-16/MODBUS: poly 0xA001 (reflected), init 0xFFFF, no final XOR. Append crc_lo THEN crc_hi.
+    /// Verified: crc16(&[01,04,00,00,00,01])==0xCA31 (wire 31 CA); crc16(&[01,03,00,00,00,0A])==0xCDC5.
+    pub fn crc16_modbus(data: &[u8]) -> u16 {
+        let mut crc: u16 = 0xFFFF;
+        for &b in data {
+            crc ^= b as u16;
+            for _ in 0..8 {
+                if crc & 1 != 0 {
+                    crc = (crc >> 1) ^ 0xA001;
+                } else {
+                    crc >>= 1;
+                }
+            }
+        }
+        crc
+    }
+
+    fn append_crc(buf: &mut heapless::Vec<u8, 8>) {
+        let c = crc16_modbus(buf);
+        let _ = buf.push((c & 0xFF) as u8); // lo first
+        let _ = buf.push((c >> 8) as u8); // hi second
+    }
+
+    /// fn 0x03 (Read Holding) / 0x04 (Read Input): 8 bytes, addr/start/qty big-endian.
+    fn build_read_request(addr: u8, func: u8, start: u16, qty: u16) -> heapless::Vec<u8, 8> {
+        let mut f: heapless::Vec<u8, 8> = heapless::Vec::new();
+        let _ = f.push(addr);
+        let _ = f.push(func);
+        let _ = f.push((start >> 8) as u8);
+        let _ = f.push((start & 0xFF) as u8);
+        let _ = f.push((qty >> 8) as u8);
+        let _ = f.push((qty & 0xFF) as u8);
+        append_crc(&mut f);
+        f
+    }
+
+    /// fn 0x2B / MEI 0x0E Read Device Identification (basic, start at VendorName). 7 bytes.
+    fn build_mei_request(addr: u8) -> heapless::Vec<u8, 8> {
+        let mut f: heapless::Vec<u8, 8> = heapless::Vec::new();
+        let _ = f.push(addr);
+        let _ = f.push(0x2B);
+        let _ = f.push(0x0E);
+        let _ = f.push(0x01); // basic device id
+        let _ = f.push(0x00); // start object = VendorName
+        append_crc(&mut f);
+        f
+    }
+
+    enum Probe<'a> {
+        Silence,                                // 0 bytes — no device at this (baud,addr)
+        Garbage,                                // bytes but CRC/addr/len bad — wrong baud or noise
+        Exception { code: u8 },                 // CRC-valid fn|0x80 — DEVICE PRESENT
+        Ok { data: &'a [u8] },                  // CRC-valid normal read — DEVICE PRESENT
+    }
+
+    /// Presence = ANY CRC-valid reply with matching addr (normal OR exception). CRC is the gate.
+    fn parse_response<'a>(req_addr: u8, req_func: u8, rx: &'a [u8]) -> Probe<'a> {
+        if rx.is_empty() {
+            return Probe::Silence;
+        }
+        if rx.len() < 5 {
+            return Probe::Garbage; // shortest valid (exception) = 5
+        }
+        let n = rx.len();
+        let got = ((rx[n - 1] as u16) << 8) | (rx[n - 2] as u16); // hi<<8 | lo
+        if got != crc16_modbus(&rx[..n - 2]) {
+            return Probe::Garbage; // wrong baud / line noise
+        }
+        if rx[0] != req_addr {
+            return Probe::Garbage; // someone else / our own echo
+        }
+        let fnb = rx[1];
+        if fnb == (req_func | 0x80) {
+            return if n == 5 { Probe::Exception { code: rx[2] } } else { Probe::Garbage };
+        }
+        if fnb == req_func {
+            let bc = rx[2] as usize;
+            if n == 3 + bc + 2 {
+                return Probe::Ok { data: &rx[3..3 + bc] };
+            }
+        }
+        Probe::Garbage
+    }
+
+    /// The radar UART Config at a given baud (8N1 default). Pin-free — main() constructs the Uart with
+    /// the concrete pins (`Uart::new(p.UART1, radar_cfg(b)).with_tx(p.GPIO43).with_rx(p.GPIO44)`), which
+    /// avoids naming the (interconnect-private) PeripheralOutput/Input traits in a signature.
+    pub fn radar_cfg(baud: u32, parity: Parity) -> UartConfig {
+        UartConfig::default()
+            .with_baudrate(baud)
+            .with_data_bits(RADAR_DATA_BITS)
+            .with_parity(parity)
+            .with_stop_bits(RADAR_STOP_BITS)
+    }
+
+    /// Per-(baud,parity) reconfig on the LIVE peripheral (apply_config, mod.rs:1977 — no drop/rebuild).
+    /// Drain stale RX + idle the bus first so a half-received frame at the old setting isn't misparsed.
+    async fn radar_set_line(uart: &mut Uart<'_, Blocking>, baud: u32, parity: Parity) {
+        let mut scratch = [0u8; 64];
+        while uart.read_ready() {
+            let _ = uart.read_buffered(&mut scratch);
+        }
+        Timer::after(Duration::from_millis(RADAR_PRE_RECONFIG_IDLE_MS)).await;
+        let _ = uart.apply_config(&radar_cfg(baud, parity));
+    }
+
+    fn parity_str(p: Parity) -> &'static str {
+        match p {
+            Parity::None => "N",
+            Parity::Even => "E",
+            Parity::Odd => "O",
+        }
+    }
+
+    /// One Modbus transaction: DE/RE HIGH → write whole frame → flush to TRUE tx-idle → DE/RE LOW →
+    /// receive until a 3.5-char silent gap OR the wall-clock deadline. Returns response bytes captured.
+    async fn modbus_txn(
+        uart: &mut Uart<'_, Blocking>,
+        de_re: &mut Output<'_>,
+        req: &[u8],
+        resp: &mut [u8],
+        timeout: Duration,
+        interchar_gap: Duration,
+    ) -> usize {
+        // echo guard: drain RX before transmitting (our own bytes mustn't be parsed as the reply)
+        let mut junk = [0u8; 64];
+        while uart.read_ready() {
+            let _ = uart.read_buffered(&mut junk);
+        }
+        // ── TRANSMIT ──
+        de_re.set_high(); // enable driver
+        let mut sent = 0;
+        while sent < req.len() {
+            sent += uart.write(&req[sent..]).expect("TxError uninhabited"); // short-write loop
+        }
+        let _ = uart.flush(); // VERIFIED: returns only after the last bit is shifted out
+        de_re.set_low(); // ← de-assert DE/RE HERE (frame fully on the wire), switch to RX
+                         // ── LISTEN (manual deadline; read() has no timeout) ──
+        let hard_deadline = Instant::now() + timeout;
+        let mut n = 0usize;
+        let mut last_rx: Option<Instant> = None;
+        loop {
+            if uart.read_ready() && n < resp.len() {
+                if let Ok(got) = uart.read_buffered(&mut resp[n..]) {
+                    if got > 0 {
+                        n += got;
+                        last_rx = Some(Instant::now());
+                    }
+                }
+            } else {
+                let now = Instant::now();
+                if let Some(t) = last_rx {
+                    if now.duration_since(t) >= interchar_gap {
+                        break; // end-of-frame (3.5-char silence after data)
+                    }
+                }
+                if now >= hard_deadline {
+                    break; // response timeout / silence
+                }
+                Timer::after(Duration::from_micros(200)).await; // yield
+            }
+            if n == resp.len() {
+                break; // buffer full
+            }
+        }
+        n
+    }
+
+    fn print_reg_chunk(baud: u32, addr: u8, func: u8, start: u16, data: &[u8]) {
+        let mut words: heapless::String<200> = heapless::String::new();
+        for i in 0..(data.len() / 2) {
+            let w = ((data[2 * i] as u16) << 8) | (data[2 * i + 1] as u16);
+            if i > 0 {
+                let _ = words.push(',');
+            }
+            let _ = write!(words, "{:04X}", w);
+        }
+        println!(
+            "RADAR reg baud={} addr={} fn={:02X} start={} qty={} words={}",
+            baud, addr, func, start, data.len() / 2, words
+        );
+    }
+
+    /// Parse + print the MEI (fn 0x2B/0x0E) device-id objects (0=vendor 1=product 2=rev), CRC-gated.
+    fn print_mei(baud: u32, addr: u8, rx: &[u8]) {
+        let none = || println!("RADAR devid baud={} addr={} NONE", baud, addr);
+        if rx.len() < 10 {
+            return none();
+        }
+        let n = rx.len();
+        let got = ((rx[n - 1] as u16) << 8) | (rx[n - 2] as u16);
+        if got != crc16_modbus(&rx[..n - 2]) || rx[0] != addr || rx[1] != 0x2B || rx[2] != 0x0E {
+            return none();
+        }
+        // header: [0]addr [1]2B [2]0E [3]readcode [4]conformity [5]more [6]next_obj [7]num_objs, then TLVs
+        let num = rx[7] as usize;
+        let mut p = 8usize;
+        let body = &rx[..n - 2]; // exclude CRC
+        let mut vendor: &str = "";
+        let mut product: &str = "";
+        let mut rev: &str = "";
+        for _ in 0..num {
+            if p + 2 > body.len() {
+                break;
+            }
+            let oid = body[p];
+            let olen = body[p + 1] as usize;
+            let vstart = p + 2;
+            if vstart + olen > body.len() {
+                break;
+            }
+            let val = core::str::from_utf8(&body[vstart..vstart + olen]).unwrap_or("?");
+            match oid {
+                0x00 => vendor = val,
+                0x01 => product = val,
+                0x02 => rev = val,
+                _ => {}
+            }
+            p = vstart + olen;
+        }
+        println!(
+            "RADAR devid baud={} addr={} vendor=\"{}\" product=\"{}\" rev=\"{}\"",
+            baud, addr, vendor, product, rev
+        );
+    }
+
+    /// Read regs 0..=63 of `func` (0x03/0x04) in qty<=8 chunks; print each chunk (or EXC/TIMEOUT/GARBAGE).
+    async fn dump_regs(
+        uart: &mut Uart<'_, Blocking>,
+        de_re: &mut Output<'_>,
+        rx: &mut [u8],
+        baud: u32,
+        addr: u8,
+        func: u8,
+        timeout: Duration,
+        gap: Duration,
+    ) {
+        let mut start: u16 = 0;
+        while start < 64 {
+            let qty = core::cmp::min(8, 64 - start);
+            let req = build_read_request(addr, func, start, qty);
+            let n = modbus_txn(uart, de_re, &req, rx, timeout, gap).await;
+            match parse_response(addr, func, &rx[..n]) {
+                Probe::Ok { data } => print_reg_chunk(baud, addr, func, start, data),
+                Probe::Exception { code } => println!(
+                    "RADAR reg baud={} addr={} fn={:02X} start={} EXC={:02X}",
+                    baud, addr, func, start, code
+                ),
+                Probe::Silence => println!(
+                    "RADAR reg baud={} addr={} fn={:02X} start={} TIMEOUT",
+                    baud, addr, func, start
+                ),
+                Probe::Garbage => println!(
+                    "RADAR reg baud={} addr={} fn={:02X} start={} GARBAGE",
+                    baud, addr, func, start
+                ),
+            }
+            start += qty;
+        }
+    }
+
+    /// PASSIVE LISTEN-ONLY sweep — DE/RE held LOW (RX only, NEVER drives the bus, zero contention risk).
+    /// Catches a STREAMING radar (emits data unsolicited, not Modbus poll-response) AND proves whether the
+    /// RX path delivers ANY bytes. Per baud, listen ~1.5s and hex-dump whatever arrives (or NONE).
+    async fn listen_only_sweep(uart: &mut Uart<'_, Blocking>, de_re: &mut Output<'_>) {
+        de_re.set_low(); // RX mode — do not transmit
+        println!("RADAR LISTEN-ONLY phase (passive, DE/RE low; catches a streaming/non-Modbus radar)");
+        for &baud in RADAR_BAUDS {
+            radar_set_line(uart, baud, Parity::None).await; // 8N1 listen
+            let mut buf = [0u8; 128];
+            let mut n = 0usize;
+            let deadline = Instant::now() + Duration::from_millis(1500);
+            while Instant::now() < deadline && n < buf.len() {
+                if uart.read_ready() {
+                    if let Ok(g) = uart.read_buffered(&mut buf[n..]) {
+                        n += g;
+                    }
+                } else {
+                    Timer::after(Duration::from_micros(500)).await;
+                }
+            }
+            if n == 0 {
+                println!("RADAR listen baud={} NONE", baud);
+            } else {
+                let mut hex: heapless::String<300> = heapless::String::new();
+                for (i, b) in buf[..n].iter().enumerate() {
+                    if i > 0 {
+                        let _ = hex.push(' ');
+                    }
+                    let _ = write!(hex, "{:02X}", b);
+                }
+                println!("RADAR listen baud={} n={} bytes={}", baud, n, hex);
+            }
+        }
+    }
+
+    /// The sweep: for each baud, scan addresses; on a CRC-valid presence reply dump holding+input regs
+    /// + device-id. Construct the Uart+Output in main(); this task owns the sweep.
+    #[embassy_executor::task]
+    pub async fn radar_probe_task(mut uart: Uart<'static, Blocking>, mut de_re: Output<'static>) {
+        let st1 = crc16_modbus(&[0x01, 0x04, 0x00, 0x00, 0x00, 0x01]) == 0xCA31;
+        let st2 = crc16_modbus(&[0x01, 0x03, 0x00, 0x00, 0x00, 0x0A]) == 0xCDC5;
+        println!(
+            "RADARPROBE crc-selftest v1={} v2={} -> {}",
+            st1, st2, if st1 && st2 { "PASS" } else { "FAIL" }
+        );
+        let timeout = Duration::from_millis(RADAR_RESP_TIMEOUT_MS);
+        let gap = Duration::from_millis(RADAR_INTERCHAR_GAP_MS);
+        let mut rxbuf = [0u8; 256];
+
+        // Phase 1: PASSIVE listen (safe, RX-only) — reveals a streaming radar + tests the RX path.
+        listen_only_sweep(&mut uart, &mut de_re).await;
+
+        // Phase 2: ACTIVE Modbus master sweep (parity × baud × addr).
+        for &parity in RADAR_PARITIES {
+            let ps = parity_str(parity);
+            for &baud in RADAR_BAUDS {
+                radar_set_line(&mut uart, baud, parity).await;
+                println!("RADAR baud={} parity={} START", baud, ps);
+                // 1 first, then dense 1..=20, then sparse — dedup the leading 1.
+                for addr in core::iter::once(1u8)
+                    .chain(2..=RADAR_ADDR_DENSE_HI)
+                    .chain(RADAR_ADDR_SPARSE.iter().copied())
+                {
+                    if addr == 0 {
+                        continue; // never broadcast
+                    }
+                    let req = build_read_request(addr, 0x03, 0x0000, 1); // presence probe
+                    let mut found = false;
+                    for _attempt in 0..2 {
+                        let n = modbus_txn(&mut uart, &mut de_re, &req, &mut rxbuf, timeout, gap).await;
+                        match parse_response(addr, 0x03, &rxbuf[..n]) {
+                            Probe::Ok { .. } | Probe::Exception { .. } => {
+                                println!("RADAR found baud={} parity={} addr={} (probe-fn=03)", baud, ps, addr);
+                                found = true;
+                                break;
+                            }
+                            Probe::Silence => break, // no device — no retry
+                            Probe::Garbage => {}     // collision/noise — retry once
+                        }
+                    }
+                    if !found {
+                        continue;
+                    }
+                    dump_regs(&mut uart, &mut de_re, &mut rxbuf, baud, addr, 0x03, timeout, gap).await;
+                    dump_regs(&mut uart, &mut de_re, &mut rxbuf, baud, addr, 0x04, timeout, gap).await;
+                    let mei = build_mei_request(addr);
+                    let n = modbus_txn(&mut uart, &mut de_re, &mei, &mut rxbuf, timeout, gap).await;
+                    print_mei(baud, addr, &rxbuf[..n]);
+                }
+                println!("RADAR baud={} parity={} DONE", baud, ps);
+            }
+        }
+        println!("RADAR SWEEP COMPLETE");
+        loop {
+            Timer::after(Duration::from_secs(3600)).await; // park
+        }
     }
 }
