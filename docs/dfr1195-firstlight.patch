+/// M7 CoC-connectivity test: the provider board (lowest of the 2 test boards). The M9 engine does
+/// real §4A.3 election (lowest eligible hive_id) — this const is just the 2-board CoC bring-up.
+#[cfg(feature = "ble")]
+const M7_PROVIDER_HIVE: u32 = 0x0dca_dbf8; // ACM11
