+/// R2 mesh UDP port (R2-WIFI §4).
+const R2_UDP_PORT: u16 = 21042;
+/// OTA network-receiver port (#17): START/DATA/COMMIT image transfer.
+const R2_OTA_PORT: u16 = 21043;
+/// IDENTIFY inject-bridge port: a board reads "IDENTIFY <wire_hex> <1|0>" from its USB-serial
+/// (composer's orchestrator writes it) + broadcasts the r2.hb.identify Directed frame.
+const R2_IDENTIFY_BRIDGE_PORT: u16 = 21045;
+
+/// #18 health telemetry: event_hash discriminator + the collector (AP) wire hive_id.
+/// Followers Direct r2.hb.health to the collector over TN; the collector logs it as hex
+/// for composer's orchestrator serial-reader (the AP↔tuxedo USB uplink feeds the dashboard).
+const HEALTH_HASH: u32 = r2_fnv::fnv1a_32(b"r2.hb.health");
+// FR-4 role-sim board ids (role is by hive_id = board MAC). DEFAULT = canonical pinned tuxedo D-rig.
+// `labrig` (off by default) = the RF-ISOLATED laptop rig (composer's X-rig) — laptop ids + a shifted LoRa freq
+// + a shifted ESP-NOW channel so it cannot collide with the co-located tuxedo rig (the run-1 confound).
+#[cfg(not(feature = "labrig"))]
+const FR4_SENSOR_HIVE: u32 = 0x480e_900e; // D1 originator/collector
+#[cfg(not(feature = "labrig"))]
+const FR4_ROUTER_HIVE: u32 = 0x2cab_5f69; // D2 relay
+#[cfg(not(feature = "labrig"))]
+const FR4_BRIDGE_HIVE: u32 = 0xf91c_8911; // D3 bridge
+#[cfg(not(feature = "labrig"))]
+const FR4_RECV_HIVE: u32 = 0x06ae_082b; // D4 receiver
+#[cfg(feature = "labrig")]
+const FR4_SENSOR_HIVE: u32 = 0x998d_e7fc; // laptop ttyACM2 originator/collector
+#[cfg(feature = "labrig")]
+const FR4_ROUTER_HIVE: u32 = 0xc210_6bd5; // laptop ttyACM4 relay
+#[cfg(feature = "labrig")]
+const FR4_BRIDGE_HIVE: u32 = 0xaf14_64f4; // laptop ttyACM1 bridge
+#[cfg(feature = "labrig")]
+const FR4_RECV_HIVE: u32 = 0x2c81_b4a3; // laptop ttyACM3 receiver
+const R2_COLLECTOR_HIVE: u32 = FR4_SENSOR_HIVE; // AP board KS1-canonical hive_id = collector
+
+/// IDENTIFY (Roy dashboard locate-a-board): a Directed r2.hb.identify frame (payload[0]=1 on /
+/// 0 off) addressed to a hive_id makes THAT board light its LED SOLID, overriding the lub-dub,
+/// for ~5s (or until an off frame). Set as a 50ms-tick countdown (no clock needed).
+const IDENTIFY_HASH: u32 = r2_fnv::fnv1a_32(b"r2.hb.identify");
+// BL-200 routetest: event_hash discriminator for distributed-trail request/reply Events (so the
+// §4.3.4 reinforcer acts ONLY on them, not health/identify/trust-demo Events).
+#[cfg(feature = "routetest")]
+const ROUTETEST_HASH: u32 = r2_fnv::fnv1a_32(b"r2.tn.routetest");
+// SENDTO target: if non-zero, THIS board is the origin (A) and sends directed requests to this dest (D).
+#[cfg(feature = "routetest")]
+static ROUTETEST_DEST: AtomicU32 = AtomicU32::new(0);
+static IDENTIFY_TICKS: AtomicU32 = AtomicU32::new(0); // 50ms LED-loop ticks of SOLID remaining
+
+// ─────────────────────────── Real-TG persona (#20) ───────────────────────────
+/// Flash offset of the provisioned persona bundle (composer write-bins it raw here).
+const PERSONA_OFFSET: u32 = 0x12000;
+
+/// A provisioned trust-group persona, read raw from flash (R2-KEYSTORE v0.2).
+struct Persona {
+    tg_label: heapless::String<40>, // tg_id UUID string — the real TG label (off "DEMO")
+    tg_hash: u32,                   // FNV-1a-32(tg_id) = frame target_group
+    hk: [u8; 32],                   // group HMAC key — RECEIVED, used directly by the gate
+    hive_id: u32,                   // FNV-1a-32(UUID(HKDF(master_secret, tg_id)))
+    tg_pk: [u8; 32],                // TG Ed25519 pubkey (bundle key 5) — §2.4 OTA acceptable-signer
+}
+
+/// Read + decode the persona bundle from flash @0x12000. None if absent/invalid
+/// (firmware then falls back to the demo TG). Called BEFORE the radio starts, so the
+/// esp-storage flash read can't collide with WiFi (esp-storage#31).
+fn read_persona() -> Option<Persona> {
+    use embedded_storage::ReadStorage;
+    let mut flash = esp_storage::FlashStorage::new();
+    // 512B (persona partition is 0x2000) — composer's c46383e persona grew to 336B; the old 256B buffer
+    // TRUNCATED it so parse_persona failed → spurious UNPROVISIONED fallback (metal-caught on the field
+    // triplet). parse_persona reads the self-delimiting CBOR prefix, so trailing erased 0xFF is ignored.
+    let mut buf = [0u8; 512];
+    flash.read(PERSONA_OFFSET, &mut buf).ok()?;
+    // SHARED parser (north-star, core 1b93108): r2_trust::parse_persona does the r2_cbor
+    // decode + canonical derive_hive_id + tg_hash internally, so consume can't disagree
+    // with composer's producer. Our only platform glue is the esp-storage flash read above.
+    let p = r2_trust::parse_persona(&buf)?;
+    let mut tg_label: heapless::String<40> = heapless::String::new();
+    tg_label.push_str(p.tg_id).ok()?;
+    let mut tg_pk = [0u8; 32];
+    if p.tg_pk.len() == 32 {
+        tg_pk.copy_from_slice(p.tg_pk);
+    }
+    Some(Persona { tg_label, tg_hash: p.tg_hash, hk: p.hk, hive_id: p.hive_id, tg_pk })
+}
+
+/// Carrier-aware board profile (9-board: one binary on DFR1195 + screenless XIAO-S3).
+/// Byte 0 @0x13000: 0x00 = no screen (XIAO), else/0xFF(erased) = screen (DFR1195).
+/// LED polarity DEFAULTS active-high; only an explicit byte1==0x01 forces active-low. Polarity is
+/// hardware/wiring-specific, NOT derivable from the SoC/has_screen (these XIAO have EXTERNAL
+/// active-high LEDs, confirmed by Roy). Robust: default active-high so a re-flash/re-provision
+/// can't re-invert. NOTE: composer's board.toml uses byte1=led_active_HIGH (1=high) — the OPPOSITE
+/// of this byte — so we do NOT consume composer's byte1; per Roy the real path is dedicated
+/// per-carrier builds + carrier-detection (this shared binary = active-high default, no byte1 needed).
+const BOARD_PROFILE_OFFSET: u32 = 0x13000;
+fn read_board_profile() -> (bool, bool) {
+    use embedded_storage::ReadStorage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 2];
+    if flash.read(BOARD_PROFILE_OFFSET, &mut b).is_err() {
+        return (true, false); // default: DFR1195 screen + active-high LED
+    }
+    let has_screen = b[0] != 0x00;
+    let led_active_low = b[1] == 0x01; // active-HIGH default; only explicit 0x01 overrides to active-low
+    (has_screen, led_active_low)
+}
+
+// ── 2-TG per-TG keying: runtime-PROVISION NVS custody (CROSS-HOST-2TG #20, §6) ──────────────
+// A board's active trust-group key can be (re)provisioned at runtime over the serial inject-bridge
+// (PROVISION mirrors IDENTIFY) — no re-flash. hive firmware owns L5 custody: parse_provision
+// validates, then we PERSIST {tg_id, 32B key} to a raw flash region and INSTALL it into the
+// io_task GroupHmac. Layout @0x14000 (free gap below ota_0, its own 4 KB sector — distinct from
+// persona@0x12000 + board-profile@0x13000): [magic u32 BE][tg_id u32 BE][key 32B] = 40 bytes.
+// `tg_id` (§6) is the WIRE trust-group id = fnv1a_32(UUID) decimal == the frame `target_group`,
+// so no FNV here: tg_id IS my_tg_hash. Re-PROVISION overwrites the sector (parser is stateless).
+#[cfg(feature = "multitg")]
+const PROVISIONED_TG_OFFSET: u32 = 0x14000;
+#[cfg(feature = "multitg")]
+const PROVISION_MAGIC: u32 = 0x5232_5447; // "R2TG"
+
+/// Runtime hand-off uart_rx_task (PROVISION writer) → io_task (GroupHmac installer): the newly
+/// provisioned (tg_id, key), set once and consumed when io_task rebuilds its GroupHmac. The
+/// engine RETAINS no key beyond the install (R2-RUNTIME §13.2) — this cell is the install conduit.
+#[cfg(feature = "multitg")]
+static PENDING_PROVISION: embassy_sync::blocking_mutex::Mutex<
+    CriticalSectionRawMutex,
+    core::cell::RefCell<Option<(u32, [u8; 32])>>,
+> = embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(None));
+
+/// Read the persisted provisioned-TG credential, if a valid one is stored. `None` = unprovisioned
+/// (erased/old board) → the caller keeps the persona/demo TG.
+#[cfg(feature = "multitg")]
+fn read_provisioned_tg() -> Option<(u32, [u8; 32])> {
+    use embedded_storage::ReadStorage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 40];
+    flash.read(PROVISIONED_TG_OFFSET, &mut b).ok()?;
+    let magic = u32::from_be_bytes([b[0], b[1], b[2], b[3]]);
+    if magic != PROVISION_MAGIC {
+        return None;
+    }
+    let tg_id = u32::from_be_bytes([b[4], b[5], b[6], b[7]]);
+    let mut key = [0u8; 32];
+    key.copy_from_slice(&b[8..40]);
+    Some((tg_id, key))
+}
+
+/// Persist a provisioned-TG credential to flash (erase+write its 4 KB sector). Returns Ok on a
+/// verified write. Called from uart_rx_task after parse_provision validates the PROVISION line.
+#[cfg(feature = "multitg")]
+fn write_provisioned_tg(tg_id: u32, key: &[u8; 32]) -> Result<(), ()> {
+    use embedded_storage::{ReadStorage, Storage};
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 40];
+    b[0..4].copy_from_slice(&PROVISION_MAGIC.to_be_bytes());
+    b[4..8].copy_from_slice(&tg_id.to_be_bytes());
+    b[8..40].copy_from_slice(key);
+    flash.write(PROVISIONED_TG_OFFSET, &b).map_err(|_| ())?;
+    // Read-back verify (custody must be durable before we ACK applied).
+    let mut rb = [0u8; 40];
+    flash.read(PROVISIONED_TG_OFFSET, &mut rb).map_err(|_| ())?;
+    if rb == b {
+        Ok(())
+    } else {
+        Err(())
+    }
+}
+
+// ─── Console persona-receiver (#14, REMOTE provisioning over the console — NO download mode) ───────────
+// Mirrors write_provisioned_tg's self-write-from-the-running-app path, but writes the IDENTITY records the
+// §3.5 boot reads: persona @0x12000 (exits INERT), RPF1 role-profile @0x17000, board-profile @0x13000.
+// WHITELISTED offsets only, each VALIDATED before commit (persona via r2_trust::parse_persona, RPF1 via the
+// RPF1 magic) — NEVER a generic write-anywhere. Used by BOTH uart_rx_task AND the §3.5 INERT loop (a fresh
+// inert board must accept its persona before it spawns any other task). The app runs from ota_0@0x20000, so
+// writing the 0x12000-0x17000 config gap is a different flash region (safe), same as write_provisioned_tg.
+fn hex_nib(c: u8) -> Option<u8> {
+    match c {
+        b'0'..=b'9' => Some(c - b'0'),
+        b'a'..=b'f' => Some(c - b'a' + 10),
+        b'A'..=b'F' => Some(c - b'A' + 10),
+        _ => None,
+    }
+}
+/// Decode hex into a fixed buffer; returns byte count or Err on bad hex / overflow.
+fn decode_hex_into(hex: &[u8], out: &mut [u8]) -> Result<usize, ()> {
+    if hex.len() % 2 != 0 || hex.len() / 2 > out.len() {
+        return Err(());
+    }
+    for (i, pair) in hex.chunks_exact(2).enumerate() {
+        out[i] = (hex_nib(pair[0]).ok_or(())? << 4) | hex_nib(pair[1]).ok_or(())?;
+    }
+    Ok(hex.len() / 2)
+}
+/// Raw-flash store + read-back verify (mirrors write_provisioned_tg) for a whitelisted config offset.
+fn store_blob_verify(offset: u32, bytes: &[u8]) -> bool {
+    use embedded_storage::{ReadStorage, Storage};
+    let mut flash = esp_storage::FlashStorage::new();
+    if bytes.len() > 512 || flash.write(offset, bytes).is_err() {
+        return false;
+    }
+    let mut rb = [0u8; 512];
+    if flash.read(offset, &mut rb[..bytes.len()]).is_err() {
+        return false;
+    }
+    rb[..bytes.len()] == *bytes
+}
+/// Handle ONE console persona-provision command line. Accumulates the chunked PERSONA, validates + stores the
+/// records to whitelisted offsets, ACKs on serial (composer's streamer waits for these exact strings). Returns
+/// true iff REBOOT was requested (caller resets → read_persona@0x12000 → exits INERT). NOT cfg-gated — used by
+/// uart_rx_task (running boards) + the §3.5 INERT loop (fresh boards).
+fn handle_persona_cmd(line: &[u8], accum: &mut [u8; 512], accum_len: &mut usize) -> bool {
+    if line == b"PERSONA BEGIN" {
+        *accum_len = 0;
+    } else if line == b"PERSONA END" {
+        match r2_trust::parse_persona(&accum[..*accum_len]) {
+            Some(p) => {
+                if store_blob_verify(PERSONA_OFFSET, &accum[..*accum_len]) {
+                    println!("r2-dfr1195: PERSONA OK {:08x}", p.hive_id);
+                } else {
+                    println!("r2-dfr1195: PERSONA ERR verify");
+                }
+            }
+            None => println!("r2-dfr1195: PERSONA ERR parse"),
+        }
+    } else if let Some(hex) = line.strip_prefix(b"PERSONA ") {
+        let nbytes = hex.len() / 2;
+        if hex.len() % 2 != 0 || *accum_len + nbytes > accum.len() {
+            println!("r2-dfr1195: PERSONA ERR len");
+        } else if decode_hex_into(hex, &mut accum[*accum_len..*accum_len + nbytes]).is_ok() {
+            *accum_len += nbytes;
+        } else {
+            println!("r2-dfr1195: PERSONA ERR hex");
+        }
+    } else if let Some(hex) = line.strip_prefix(b"RPF1 ") {
+        let mut b = [0u8; 48];
+        match decode_hex_into(hex, &mut b) {
+            Ok(48) if u32::from_be_bytes([b[0], b[1], b[2], b[3]]) == ROLE_PROFILE_MAGIC => {
+                if store_blob_verify(ROLE_PROFILE_OFFSET, &b) {
+                    println!("r2-dfr1195: RPF1 OK");
+                } else {
+                    println!("r2-dfr1195: RPF1 ERR verify");
+                }
+            }
+            Ok(48) => println!("r2-dfr1195: RPF1 ERR magic"),
+            _ => println!("r2-dfr1195: RPF1 ERR hex"),
+        }
+    } else if let Some(hex) = line.strip_prefix(b"BOARDPROF ") {
+        let mut b = [0u8; 2];
+        match decode_hex_into(hex, &mut b) {
+            Ok(2) => {
+                if store_blob_verify(BOARD_PROFILE_OFFSET, &b) {
+                    println!("r2-dfr1195: BOARDPROF OK");
+                } else {
+                    println!("r2-dfr1195: BOARDPROF ERR verify");
+                }
+            }
+            _ => println!("r2-dfr1195: BOARDPROF ERR hex"),
+        }
+    } else if line == b"REBOOT" {
+        println!("r2-dfr1195: REBOOT (console-provision) — restarting");
+        return true;
+    }
+    false
+}
+
+// ─── R2-RUNTIME §3.2 — device role as an ensemble PROFILE (one signed image, config-activated) ───
+// Roy's keystone (re-orient 2026-06-26): ONE no_std image; the ENSEMBLE differentiates, NOT the firmware
+// and NOT a compile-time-baked role. The four canonical profiles (§3.2.1) — sensor / repeater / bridge /
+// receiver — are NAMES for ensemble profiles selected at DEPLOY-TIME from the §3.2.2 role-profile config
+// record (NVS @0x17000, composer-emitted), not from hive_id pins or Cargo features. Relay is INTRINSIC
+// (every profile relays for the mesh, R2-ROUTE); the profile only adds the per-role behaviour deltas
+// (§3.2.1 table: sensor originates+Intermittent; receiver deliver-gate+absence; bridge cross-carrier;
+// repeater = the bare TN node). When NO record is provisioned the role DERIVES from the legacy signals
+// (hive pins + bridge feature) so the bench/demo is byte-for-byte preserved — the record is the OVERRIDE,
+// exactly like the persona/TG. carrier_set/carrier_creds (§3.2.2, bridge only) are composer-led sealed
+// material (R2-KEYSTORE §2) kept categorically distinct from TG trust; the firmware reads only the
+// behaviour knobs and the encoding is config-record detail, NOT a pinned wire layout (§3.2.2).
+#[derive(Clone, Copy, PartialEq, Eq)]
+enum Role {
+    Repeater,
+    Sensor,
+    Bridge,
+    Receiver,
+}
+
+impl Role {
+    fn from_wire(b: u8) -> Option<Role> {
+        match b {
+            0 => Some(Role::Repeater),
+            1 => Some(Role::Sensor),
+            2 => Some(Role::Bridge),
+            3 => Some(Role::Receiver),
+            _ => None,
+        }
+    }
+    fn label(self) -> &'static str {
+        match self {
+            Role::Repeater => "repeater",
+            Role::Sensor => "sensor",
+            Role::Bridge => "bridge",
+            Role::Receiver => "receiver",
+        }
+    }
+    /// §3.2.1: the SENSOR is the only originator; repeater/bridge are transit, receiver is a sink.
+    #[allow(dead_code)]
+    fn originates(self) -> bool {
+        matches!(self, Role::Sensor)
+    }
+    /// §3.2.2 default duty_class: Intermittent (sensor) / AlwaysOn (else).
+    fn default_duty(self) -> DutyClass {
+        match self {
+            Role::Sensor => DutyClass::Intermittent,
+            _ => DutyClass::AlwaysOn,
+        }
+    }
+}
+
+// §3.2.2 typical defaults (deployment-tunable policy, not normative SLAs — cf. R2-ROUTE §3B.1).
+const RP_DEFAULT_KEEPALIVE_MS: u32 = 30_000; // §1A "tens of s" ship default
+const RP_DEFAULT_SCF_CAP: u16 = 8;
+const RP_DEFAULT_SCF_TTL_S: u32 = 120;
+const RP_DEFAULT_REACH_CONF: f32 = 0.3;
+const RP_DEFAULT_SILENCE_S: u32 = 30;
+const RP_DEFAULT_PEER_TTL_S: u32 = 7;
+
+/// The §3.2.2 role-profile config record (the knobs an ensemble drives), resolved once at boot. `Copy`
+/// so it threads into io_task like the other provisioned scalars (my_hive/hk/tg).
+#[derive(Clone, Copy)]
+struct RoleProfile {
+    role: Role,
+    duty: DutyClass,
+    destination: u32,     // sensor: collector for originated events (0 = none / NVS SENDTO governs)
+    expected_sensor: u32, // receiver: pre-seed an expected sensor for absence-tracking (0 = dynamic-only)
+    keepalive_period_ms: u32,
+    #[allow(dead_code)]
+    scf_cap: u16,
+    scf_ttl_s: u32,
+    reach_conf: f32,
+    silence_s: u32,
+    peer_ttl_s: u32,
+    // §3.2.2 {wake_cadence, wake_window, sleep_policy} — the duty-cycle knobs. ADVERTISED, not yet ENFORCED
+    // (§3.2.3 boundary 1): a sensor sets duty_class=Intermittent + these knobs so neighbours size the SCF
+    // hold (§3B.2 TTL invariant), but real deep-sleep wake→read→send→sleep is net-new firmware on the
+    // SENTINEL→MCU custom-sensor HW (R2-LORA §6 Mode 1/2/3), NOT this DFR/XIAO stand-in. sleep_enforced
+    // stays false here (interim); enforcement is the metal-gated target.
+    #[allow(dead_code)]
+    wake_interval_s: u32,
+    #[allow(dead_code)]
+    wake_window_ms: u32,
+    #[allow(dead_code)]
+    sleep_enforced: bool,
+}
+
+impl RoleProfile {
+    fn defaults_for(role: Role) -> RoleProfile {
+        RoleProfile {
+            role,
+            duty: role.default_duty(),
+            destination: 0,
+            expected_sensor: 0,
+            keepalive_period_ms: RP_DEFAULT_KEEPALIVE_MS,
+            scf_cap: RP_DEFAULT_SCF_CAP,
+            scf_ttl_s: RP_DEFAULT_SCF_TTL_S,
+            reach_conf: RP_DEFAULT_REACH_CONF,
+            silence_s: RP_DEFAULT_SILENCE_S,
+            peer_ttl_s: RP_DEFAULT_PEER_TTL_S,
+            // Sensor: a sense-wake cadence (advertised); else AlwaysOn → 0 (no sleep). Interim: not enforced.
+            wake_interval_s: if matches!(role, Role::Sensor) { 300 } else { 0 },
+            wake_window_ms: if matches!(role, Role::Sensor) { 5_000 } else { 0 },
+            sleep_enforced: false,
+        }
+    }
+}
+
+const ROLE_PROFILE_OFFSET: u32 = 0x17000; // own 4 KB sector, after sendto@0x16000, below ota_0@0x20000
+const ROLE_PROFILE_MAGIC: u32 = 0x5250_4631; // "RPF1"
+
+/// Read the deploy-time role-profile record (§3.2.2) from NVS @0x17000. `None` = no record provisioned →
+/// the caller DERIVES the role (demo-preserving fallback). A 0/sentinel field falls back to the per-role
+/// default so a record may set only the knobs it cares about. Layout (big-endian, 40 B):
+/// [0..4] magic "RPF1" · [4] role · [5] duty_class (0xFF=role default) · [8..12] destination ·
+/// [12..16] expected_sensor · [16..20] keepalive_ms (0=default) · [24..26] scf_cap (0=default) ·
+/// [26..28] scf_ttl_s (0=default) · [28..30] reach_conf×1000 (0xFFFF=default) · [30..32] silence_s
+/// (0=default) · [32..34] peer_ttl_s (0=default) · [34..38] wake_interval_s (0=default) ·
+/// [38..42] wake_window_ms (0=default) · [42] sleep_enforced (1=enforce; interim ignores). (Encoding is
+/// config detail, not pinned wire — §3.2.2.)
+fn read_role_profile() -> Option<RoleProfile> {
+    use embedded_storage::ReadStorage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 48];
+    flash.read(ROLE_PROFILE_OFFSET, &mut b).ok()?;
+    if u32::from_be_bytes([b[0], b[1], b[2], b[3]]) != ROLE_PROFILE_MAGIC {
+        return None;
+    }
+    let role = Role::from_wire(b[4])?;
+    let mut rp = RoleProfile::defaults_for(role);
+    if let Some(d) = DutyClass::from_wire_uint(b[5]) {
+        rp.duty = d; // 0xFF / out-of-range keeps the role default
+    }
+    rp.destination = u32::from_be_bytes([b[8], b[9], b[10], b[11]]);
+    rp.expected_sensor = u32::from_be_bytes([b[12], b[13], b[14], b[15]]);
+    let ka = u32::from_be_bytes([b[16], b[17], b[18], b[19]]);
+    if ka != 0 {
+        rp.keepalive_period_ms = ka;
+    }
+    let cap = u16::from_be_bytes([b[24], b[25]]);
+    if cap != 0 {
+        rp.scf_cap = cap;
+    }
+    let ttl = u16::from_be_bytes([b[26], b[27]]);
+    if ttl != 0 {
+        rp.scf_ttl_s = ttl as u32;
+    }
+    let rc = u16::from_be_bytes([b[28], b[29]]);
+    if rc != 0xFFFF {
+        rp.reach_conf = rc as f32 / 1000.0;
+    }
+    let sil = u16::from_be_bytes([b[30], b[31]]);
+    if sil != 0 {
+        rp.silence_s = sil as u32;
+    }
+    let pt = u16::from_be_bytes([b[32], b[33]]);
+    if pt != 0 {
+        rp.peer_ttl_s = pt as u32;
+    }
+    let wi = u32::from_be_bytes([b[34], b[35], b[36], b[37]]);
+    if wi != 0 {
+        rp.wake_interval_s = wi;
+    }
+    let ww = u32::from_be_bytes([b[38], b[39], b[40], b[41]]);
+    if ww != 0 {
+        rp.wake_window_ms = ww;
+    }
+    rp.sleep_enforced = b[42] == 1; // interim: advertised-only regardless (§3.2.3 boundary 1)
+    Some(rp)
+}
+
+/// Resolve the device role-profile (§3.2.2). A provisioned NVS record wins; otherwise DERIVE the role
+/// from the legacy signals so the bench/demo is unchanged (sensor/receiver hive pins + the bridge
+/// feature). This is the migration seam: today's hardcoded behaviour becomes the *default* profile, and
+/// composer's record is the deploy-time override — the keystone "one image, config-activated".
+fn resolve_role_profile(my_hive: u32) -> RoleProfile {
+    if let Some(rp) = read_role_profile() {
+        return rp;
+    }
+    let role = if cfg!(feature = "bridge") {
+        Role::Bridge
+    } else if my_hive == FR4_SENSOR_HIVE {
+        Role::Sensor
+    } else if my_hive == FR4_RECV_HIVE {
+        Role::Receiver
+    } else {
+        Role::Repeater
+    };
+    let mut rp = RoleProfile::defaults_for(role);
+    if role == Role::Receiver {
+        rp.expected_sensor = FR4_SENSOR_HIVE; // D4 expects D1 from boot (preserves the fr4 silence seed)
+    }
+    #[cfg(feature = "benchkeepalive")]
+    {
+        rp.keepalive_period_ms = 8_000; // bench-watchable fade (the benchkeepalive feature)
+    }
+    rp
+}
+
+// ── TN-L2-IT-BL-100: per-neighbour RSSI-σ store + mobility classifier (R2-ROUTE §2.4) ───────────
+// HARDWARE-TIER: r2-route takes mobility as obs.mobility input (the classifier is in NO code — HIVE
+// FINDING B). We feed REAL ESP-NOW RSSI per neighbour, keep a rolling (n, sum, sum_sq) → σ, and
+// classify σ<RSSI_SIGMA_INFRA_DBM (over a settled window) = Infrastructure else Mobile. The metal
+// question: does σ<5dBm hold for STATIONARY nodes on real ESP-NOW, or does multipath/AGC/integer-dBm
+// jitter push stationary σ over the threshold → INFRA misclassified MOBILE → premature 5-min fade?
+// §2.4.1 CANON (hardened, post-FINDING-B): infrastructure if σ ≤ 8 dBm (was a naive 5 dBm). The
+// hysteresis DEMOTE-band (infra→mobile only above 1.5× = 12 dBm sustained ≥2min) + flap-prevention is
+// NOT yet exercised on metal (static bench never crosses 8 dBm — needs a mobility rig / RSSI-injection
+// sweep; queued as a BL-100 follow-up). Static result is decided by the promote threshold alone.
+#[cfg(feature = "rssicls")]
+const RSSI_SIGMA_INFRA_DBM: f32 = 8.0; // §2.4.1 hardened infrastructure threshold (dBm)
+#[cfg(feature = "rssicls")]
+#[allow(dead_code)]
+const RSSI_SIGMA_DEMOTE_DBM: f32 = 12.0; // §2.4.1 hysteresis demote band (1.5× — exercised w/ mobility rig)
+#[cfg(feature = "rssicls")]
+const RSSI_CLS_MIN_SAMPLES: u32 = 20; // settle the σ estimate before classifying (else default Mobile)
+
+#[cfg(feature = "rssicls")]
+#[derive(Clone, Copy, Default)]
+struct RssiStat {
+    hive: u32,
+    n: u32,
+    sum: f32,
+    sum_sq: f32,
+    last: i32,
+}
+#[cfg(feature = "rssicls")]
+impl RssiStat {
+    fn sigma(&self) -> f32 {
+        if self.n < 2 {
+            return 0.0;
+        }
+        let m = self.sum / self.n as f32;
+        let var = (self.sum_sq / self.n as f32) - m * m;
+        if var > 0.0 {
+            libm::sqrtf(var)
+        } else {
+            0.0
+        }
+    }
+    fn mean(&self) -> f32 {
+        if self.n == 0 {
+            0.0
+        } else {
+            self.sum / self.n as f32
+        }
+    }
+    /// §2.4 classification: settled + σ<threshold = Infrastructure, else Mobile (cold/jittery).
+    fn is_infra(&self) -> bool {
+        self.n >= RSSI_CLS_MIN_SAMPLES && self.sigma() < RSSI_SIGMA_INFRA_DBM
+    }
+}
+
+#[cfg(feature = "rssicls")]
+static RSSI_STATS: embassy_sync::blocking_mutex::Mutex<
+    CriticalSectionRawMutex,
+    core::cell::RefCell<[RssiStat; 16]>,
+> = embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new([RssiStat {
+    hive: 0,
+    n: 0,
+    sum: 0.0,
+    sum_sq: 0.0,
+    last: 0,
+}; 16]));
+
+/// Record one RSSI sample for `hive` (called from espnow_task on each heard Heartbeat). Rolling
+/// (n,sum,sum_sq) per neighbour — O(1), no ring. New neighbour takes the first free slot.
+#[cfg(feature = "rssicls")]
+fn rssi_record(hive: u32, rssi: i32) {
+    RSSI_STATS.lock(|c| {
+        let mut a = c.borrow_mut();
+        // existing slot
+        for s in a.iter_mut() {
+            if s.n > 0 && s.hive == hive {
+                s.n += 1;
+                s.sum += rssi as f32;
+                s.sum_sq += (rssi as f32) * (rssi as f32);
+                s.last = rssi;
+                return;
+            }
+        }
+        // free slot
+        for s in a.iter_mut() {
+            if s.n == 0 {
+                *s = RssiStat { hive, n: 1, sum: rssi as f32, sum_sq: (rssi as f32) * (rssi as f32), last: rssi };
+                return;
+            }
+        }
+    });
+}
+
+/// Mobility class for `hive` from its RSSI-σ (engine input). Defaults Mobile until settled.
+#[cfg(feature = "rssicls")]
+fn rssi_mobility(hive: u32) -> MobilityClass {
+    RSSI_STATS.lock(|c| {
+        let a = c.borrow();
+        for s in a.iter() {
+            if s.n > 0 && s.hive == hive {
+                return if s.is_infra() {
+                    MobilityClass::Infrastructure
+                } else {
+                    MobilityClass::Mobile
+                };
+            }
+        }
+        MobilityClass::Mobile
+    })
+}
+
+/// Log per-neighbour RSSI mean/σ/n/class — the BL-100 field.* measurement (serial capture).
+#[cfg(feature = "rssicls")]
+fn rssi_report() {
+    RSSI_STATS.lock(|c| {
+        let a = c.borrow();
+        for s in a.iter() {
+            if s.n >= 2 {
+                let cls = if s.is_infra() { "infra" } else { "mobile" };
+                println!(
+                    "r2-dfr1195: RSSI-CLS hive={:08x} mean={} sigma={} n={} last={} class={cls}",
+                    s.hive, s.mean() as i32, (s.sigma() * 100.0) as i32, s.n, s.last
+                );
+            }
+        }
+    });
+}
