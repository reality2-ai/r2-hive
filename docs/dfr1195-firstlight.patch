+/// LoRa MESH carrier bridge (loramesh) — the half-duplex analogue of espnow_task/serve_data_coc: drains
+/// DATA_TX (the io_task's PCO beats + routed Events) -> LoRa transmit, and feeds LoRa RX -> DATA_RX so the
+/// PROVEN io_task leaderless-PCO + r2-route run over LoRa. Single loop (LoRa is half-duplex): mostly RX,
+/// switch to TX when a frame is pending. SF7 bench (the 62B HB fits 222B; SF12's 51B MTU is too small).
+/// src_hive for DATA_RX = the HB payload hive (R2-WIRE extended frame: 22B header, then payload[0..4]).
+#[cfg(feature = "loramesh")]
+#[embassy_executor::task]
+async fn lora_mesh_task(mut radio: LoraRadioTy, mut rxen: Output<'static>, _my_hive: u32) {
+    let mut cfg = wairoa_as923_nz();
+    cfg.tx_power_dbm = -9; // bench close-range
+    cfg.spreading_factor = 7; // 62B HB fits SF7; SF12 MTU 51B too small for the HB (range test is later)
+    match radio.configure(&cfg) {
+        Ok(()) => {
+            println!("r2-dfr1195: LORA-MESH configure OK (SF7 BW125 916.8 sync0x21 -9dBm) — io_task PCO over LoRa")
+        }
+        Err(e) => println!("r2-dfr1195: LORA-MESH configure ERR {e:?}"),
+    }
+    rxen.set_high();
+    let _ = radio.listen();
+    loop {
+        // TX: drain one pending io_task beat -> LoRa (half-duplex: pause RX, transmit, poll TxDone, resume).
+        if let Ok((frame, n)) = DATA_TX.try_receive() {
+            rxen.set_low();
+            if radio.transmit(&frame[..n]).is_ok() {
+                for _ in 0..40 {
+                    if let Ok(Some(RadioEvent::TxDone)) = radio.poll() {
+                        break;
+                    }
+                    embassy_time::Timer::after(embassy_time::Duration::from_millis(5)).await;
+                }
+            }
+            rxen.set_high();
+            let _ = radio.listen();
+        }
+        // RX: a heard frame -> DATA_RX (io_task PCO couples + routes). src_hive = HB payload hive @ offset 22.
+        if let Ok(Some(RadioEvent::RxDone)) = radio.poll() {
+            let mut buf = [0u8; 256];
+            if let Ok(info) = radio.read(&mut buf) {
+                let src_hive = if info.len >= 26 {
+                    u32::from_be_bytes([buf[22], buf[23], buf[24], buf[25]])
+                } else {
+                    0
+                };
+                let _ = DATA_RX.try_send((buf, info.len, src_hive));
+            }
+        }
+        embassy_time::Timer::after(embassy_time::Duration::from_millis(10)).await;
+    }
+}
