+/// Carrier-aware board profile (9-board: one binary on DFR1195 + screenless XIAO-S3).
+/// Byte 0 @0x13000: 0x00 = no screen (XIAO), else/0xFF(erased) = screen (DFR1195).
+/// LED polarity DEFAULTS active-high; only an explicit byte1==0x01 forces active-low. Polarity is
+/// hardware/wiring-specific, NOT derivable from the SoC/has_screen (these XIAO have EXTERNAL
+/// active-high LEDs, confirmed by Roy). Robust: default active-high so a re-flash/re-provision
+/// can't re-invert. NOTE: composer's board.toml uses byte1=led_active_HIGH (1=high) — the OPPOSITE
+/// of this byte — so we do NOT consume composer's byte1; per Roy the real path is dedicated
+/// per-carrier builds + carrier-detection (this shared binary = active-high default, no byte1 needed).
+const BOARD_PROFILE_OFFSET: u32 = 0x13000;
+fn read_board_profile() -> (bool, bool) {
+    use embedded_storage::ReadStorage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 2];
+    if flash.read(BOARD_PROFILE_OFFSET, &mut b).is_err() {
+        return (true, false); // default: DFR1195 screen + active-high LED
+    }
+    let has_screen = b[0] != 0x00;
+    let led_active_low = b[1] == 0x01; // active-HIGH default; only explicit 0x01 overrides to active-low
+    (has_screen, led_active_low)
+}
+
+// ── 2-TG per-TG keying: runtime-PROVISION NVS custody (CROSS-HOST-2TG #20, §6) ──────────────
+// A board's active trust-group key can be (re)provisioned at runtime over the serial inject-bridge
+// (PROVISION mirrors IDENTIFY) — no re-flash. hive firmware owns L5 custody: parse_provision
+// validates, then we PERSIST {tg_id, 32B key} to a raw flash region and INSTALL it into the
+// io_task GroupHmac. Layout @0x14000 (free gap below ota_0, its own 4 KB sector — distinct from
+// persona@0x12000 + board-profile@0x13000): [magic u32 BE][tg_id u32 BE][key 32B] = 40 bytes.
+// `tg_id` (§6) is the WIRE trust-group id = fnv1a_32(UUID) decimal == the frame `target_group`,
+// so no FNV here: tg_id IS my_tg_hash. Re-PROVISION overwrites the sector (parser is stateless).
+#[cfg(feature = "multitg")]
+const PROVISIONED_TG_OFFSET: u32 = 0x14000;
+#[cfg(feature = "multitg")]
+const PROVISION_MAGIC: u32 = 0x5232_5447; // "R2TG"
+
+/// Runtime hand-off uart_rx_task (PROVISION writer) → io_task (GroupHmac installer): the newly
+/// provisioned (tg_id, key), set once and consumed when io_task rebuilds its GroupHmac. The
+/// engine RETAINS no key beyond the install (R2-RUNTIME §13.2) — this cell is the install conduit.
+#[cfg(feature = "multitg")]
+static PENDING_PROVISION: embassy_sync::blocking_mutex::Mutex<
+    CriticalSectionRawMutex,
+    core::cell::RefCell<Option<(u32, [u8; 32])>>,
+> = embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(None));
+
+/// Read the persisted provisioned-TG credential, if a valid one is stored. `None` = unprovisioned
+/// (erased/old board) → the caller keeps the persona/demo TG.
+#[cfg(feature = "multitg")]
+fn read_provisioned_tg() -> Option<(u32, [u8; 32])> {
+    use embedded_storage::ReadStorage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 40];
+    flash.read(PROVISIONED_TG_OFFSET, &mut b).ok()?;
+    let magic = u32::from_be_bytes([b[0], b[1], b[2], b[3]]);
+    if magic != PROVISION_MAGIC {
+        return None;
+    }
+    let tg_id = u32::from_be_bytes([b[4], b[5], b[6], b[7]]);
+    let mut key = [0u8; 32];
+    key.copy_from_slice(&b[8..40]);
+    Some((tg_id, key))
+}
+
+/// Persist a provisioned-TG credential to flash (erase+write its 4 KB sector). Returns Ok on a
+/// verified write. Called from uart_rx_task after parse_provision validates the PROVISION line.
+#[cfg(feature = "multitg")]
+fn write_provisioned_tg(tg_id: u32, key: &[u8; 32]) -> Result<(), ()> {
+    use embedded_storage::{ReadStorage, Storage};
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 40];
+    b[0..4].copy_from_slice(&PROVISION_MAGIC.to_be_bytes());
+    b[4..8].copy_from_slice(&tg_id.to_be_bytes());
+    b[8..40].copy_from_slice(key);
+    flash.write(PROVISIONED_TG_OFFSET, &b).map_err(|_| ())?;
+    // Read-back verify (custody must be durable before we ACK applied).
+    let mut rb = [0u8; 40];
+    flash.read(PROVISIONED_TG_OFFSET, &mut rb).map_err(|_| ())?;
+    if rb == b {
+        Ok(())
+    } else {
+        Err(())
+    }
+}
