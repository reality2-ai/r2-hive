+/// #24 BLE control plane: bt-hci ExternalController over the esp-radio BLE connector → trouble-host
+/// → advertise an R2 beacon. MILESTONE 3 = advertise (observable by a scanner) while WiFi coex holds.
+/// (Placeholder AD carries the hive_id; the real RBID/R2-BEACON AD codec from r2-core lands next,
+/// then scan → L2CAP CoC → NegotiationRadio over core's engine.)
+#[cfg(feature = "ble")]
+#[embassy_executor::task]
+async fn ble_task(
+    connector: esp_radio::ble::controller::BleConnector<'static>,
+    my_hive: u32,
+    my_tg_hash: u32,
+    hk: [u8; 32],
+) {
+    use bt_hci::param::{AddrKind, BdAddr};
+    use embassy_futures::join::{join, join3};
+    use r2_discovery::beacon::{
+        compute_rbid, derive_beacon_session_key, encode_advert, BeaconFlags, LegacyBeacon,
+        PowerState, ADVERT_PAYLOAD_LEN, BEACON_VERSION,
+    };
+    use trouble_host::prelude::*; // ExternalController + DefaultPacketPool (bt-hci version-matched to esp-radio)
+    let controller: ExternalController<_, 20> = ExternalController::new(connector);
+    let mut resources: HostResources<DefaultPacketPool, 1, 1> = HostResources::new();
+    let addr = Address::random([
+        (my_hive & 0xff) as u8,
+        ((my_hive >> 8) & 0xff) as u8,
+        ((my_hive >> 16) & 0xff) as u8,
+        ((my_hive >> 24) & 0xff) as u8,
+        0x52,
+        0xC0,
+    ]);
+    let stack = trouble_host::new(controller, &mut resources).set_random_address(addr);
+    let Host { mut peripheral, mut central, mut runner, .. } = stack.build();
+    // Real R2-BEACON advert (r2_discovery::beacon, byte-exact). PER-MEMBER session_key =
+    // derive_beacon_session_key(hk, my_hive) (HKDF(hk, salt=r2-beacon-rbid-v1, info=hive_be32)) — distinct
+    // per member, resolvable by TG peers (shared hk), opaque to strangers. RBID = HMAC(key, epoch)[0:8].
+    // epoch=0 placeholder until the shared coarse-time base wires in alongside scan→resolve_rbid_windowed.
+    let my_key = derive_beacon_session_key(&hk, my_hive);
+    let epoch: u64 = 0;
+    let rbid = compute_rbid(&my_key, epoch);
+    let beacon = LegacyBeacon {
+        version: BEACON_VERSION,
+        // provider_capable=true: DFR1195 has full WiFi → can be the SoftAP data-plane provider (§4A.3
+        // election eligibility = provider_capable AND power Normal/Eco). The scan reads this bit-2 for NegObservation.
+        flags: BeaconFlags { power_state: PowerState::Normal, provider_capable: true, ..Default::default() },
+        rbid,
+        class_hash: my_tg_hash.to_le_bytes(),
+        tx_power: 0,
+        anti_collision: 0,
+    };
+    let mut payload = [0u8; ADVERT_PAYLOAD_LEN];
+    let plen = encode_advert(&beacon, &mut payload);
+    // AD = flags + manufacturer-specific (0xFF) carrying the canonical R2-BEACON payload.
+    let mut adv = [0u8; 31];
+    adv[0] = 0x02;
+    adv[1] = 0x01;
+    adv[2] = 0x06; // flags: LE General Discoverable, BR/EDR not supported
+    adv[3] = (plen + 1) as u8;
+    adv[4] = 0xFF;
+    adv[5..5 + plen].copy_from_slice(&payload[..plen]);
+    let alen = 5 + plen;
+    let _ = (rbid, plen, epoch); // (beacon vals reused as the connectable adv_data below)
+    // M8b — feed the engine bridge so two boards NEGOTIATE over the CoC. Provider (lowest test hive)
+    // connectable-advertises + accepts the CoC; joiner connects. Both inject the known peer obs (each
+    // engine then elects the lower as provider) + serve the CoC bidirectionally: recv→CTRL_IN (poll_control),
+    // CTRL_OUT→send (send_control). So the engines' WifiReq/Offer/Done cross. (2-board; M8c = real WiFi data plane.)
+    let am_provider = my_hive == M7_PROVIDER_HIVE;
+    let peer_hive: u32 = if am_provider { 0x2cab_5f69 } else { M7_PROVIDER_HIVE };
+    push_scan_obs(peer_hive, true, 0); // inject the peer (provider_capable, power Normal) so the engine sees it
+    if am_provider {
+        let work = async {
+            loop {
+                let advertiser = match peripheral
+                    .advertise(
+                        &AdvertisementParameters::default(),
+                        Advertisement::ConnectableScannableUndirected { adv_data: &adv[..alen], scan_data: &[] },
+                    )
+                    .await
+                {
+                    Ok(a) => a,
+                    Err(_) => {
+                        println!("r2-dfr1195: NEG provider adv ERR");
+                        Timer::after(Duration::from_secs(1)).await;
+                        continue;
+                    }
+                };
+                println!("r2-dfr1195: NEG provider connectable-adv (hive {my_hive:08x})");
+                let conn = match advertiser.accept().await {
+                    Ok(c) => c,
+                    Err(_) => continue,
+                };
+                let ch = match L2capChannel::accept(&stack, &conn, &[R2_PSM], &L2capChannelConfig::default()).await {
+                    Ok(c) => c,
+                    Err(_) => {
+                        println!("r2-dfr1195: NEG provider CoC accept ERR");
+                        continue;
+                    }
+                };
+                println!("r2-dfr1195: NEG provider — CoC up, serving {COC_PLANE}");
+                #[cfg(not(feature = "blemesh"))]
+                serve_coc(&stack, ch, peer_hive).await;
+                #[cfg(feature = "blemesh")]
+                serve_data_coc(&stack, ch, peer_hive).await;
+                println!("r2-dfr1195: NEG provider — CoC closed");
+            }
+        };
+        let refresh = async {
+            loop {
+                push_scan_obs(peer_hive, true, 0); // keep the peer alive in the engine's roster
+                Timer::after(Duration::from_secs(1)).await;
+            }
+        };
+        let _ = join3(runner.run(), work, refresh).await;
+    } else {
+        let work = async {
+            let paddr = BdAddr::new([
+                (M7_PROVIDER_HIVE & 0xff) as u8,
+                ((M7_PROVIDER_HIVE >> 8) & 0xff) as u8,
+                ((M7_PROVIDER_HIVE >> 16) & 0xff) as u8,
+                ((M7_PROVIDER_HIVE >> 24) & 0xff) as u8,
+                0x52,
+                0xC0,
+            ]);
+            Timer::after(Duration::from_secs(3)).await; // let the provider come up
+            loop {
+                let cfg = ConnectConfig {
+                    scan_config: ScanConfig {
+                        active: false,
+                        filter_accept_list: &[(AddrKind::RANDOM, &paddr)],
+                        phys: PhySet::M1,
+                        interval: Duration::from_millis(100),
+                        window: Duration::from_millis(100),
+                        timeout: Duration::from_secs(0),
+                    },
+                    connect_params: RequestedConnParams::default(),
+                };
+                println!("r2-dfr1195: NEG joiner connecting to {M7_PROVIDER_HIVE:08x}");
+                let conn = match central.connect(&cfg).await {
+                    Ok(c) => c,
+                    Err(_) => {
+                        Timer::after(Duration::from_secs(2)).await;
+                        continue;
+                    }
+                };
+                let ch = match L2capChannel::create(&stack, &conn, R2_PSM, &L2capChannelConfig::default()).await {
+                    Ok(c) => c,
+                    Err(_) => {
+                        println!("r2-dfr1195: NEG joiner CoC create ERR");
+                        Timer::after(Duration::from_secs(2)).await;
+                        continue;
+                    }
+                };
+                println!("r2-dfr1195: NEG joiner — CoC up, serving {COC_PLANE}");
+                #[cfg(not(feature = "blemesh"))]
+                serve_coc(&stack, ch, peer_hive).await;
+                #[cfg(feature = "blemesh")]
+                serve_data_coc(&stack, ch, peer_hive).await;
+                println!("r2-dfr1195: NEG joiner — CoC closed");
+            }
+        };
+        let refresh = async {
+            loop {
+                push_scan_obs(peer_hive, true, 0); // keep the peer alive in the engine's roster
+                Timer::after(Duration::from_secs(1)).await;
+            }
+        };
+        let _ = join3(runner.run(), work, refresh).await;
+    }
+}
