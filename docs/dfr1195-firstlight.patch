+
+/// Gentle dimmed LED pulse — software PWM at ~500 Hz to `duty_pct` brightness for
+/// `ms` milliseconds. (Hardware LEDC would also work; software PWM keeps first-light
+/// dependency-free. The mono LED's brightness becomes the `dimmable` descriptor trait.)
+fn dim_pulse(led: &mut Output<'_>, delay: &Delay, ms: u32, duty_pct: u32) {
+    let period_us: u32 = 2000; // 500 Hz — no visible flicker
+    let on_us = period_us * duty_pct / 100;
+    let off_us = period_us - on_us;
+    let cycles = (ms * 1000) / period_us;
+    for _ in 0..cycles {
+        led.set_high();
+        delay.delay_micros(on_us);
+        led.set_low();
+        delay.delay_micros(off_us);
+    }
+}
+
+/// Push an event line, evicting the oldest when the log is full (scroll up).
+fn push_event(events: &mut EventLog, s: &str) {
+    if events.is_full() {
+        let _ = events.pop_front();
+    }
+    let mut line: heapless::String<26> = heapless::String::new();
+    let _ = line.push_str(s);
+    let _ = events.push_back(line);
+}
+
+/// Render: two header lines (green device line, cyan TG/build line) then the white
+/// event log below (oldest→newest, so new events appear at the bottom and scroll up).
+fn render<D>(display: &mut D, header_dev: &str, header_id: &str, events: &EventLog)
+where
+    D: DrawTarget<Color = Rgb565>,
+{
+    let _ = display.clear(Rgb565::BLACK);
+    let dev_style = MonoTextStyle::new(&FONT_6X10, Rgb565::GREEN);
+    let id_style = MonoTextStyle::new(&FONT_6X10, Rgb565::CYAN);
+    let event_style = MonoTextStyle::new(&FONT_6X10, Rgb565::WHITE);
+    let _ = Text::new(header_dev, Point::new(2, 8), dev_style).draw(display);
+    let _ = Text::new(header_id, Point::new(2, 18), id_style).draw(display);
+    let mut y = 30;
+    for e in events.iter() {
+        let _ = Text::new(e.as_str(), Point::new(2, y), event_style).draw(display);
+        y += 10;
     }
