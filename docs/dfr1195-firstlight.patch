+    let mut tick: u32 = 0;
     loop {
-        embassy_time::Timer::after(embassy_time::Duration::from_secs(5)).await;
-        esp_println::println!("r2-dfr1195: alive (transports: skeleton)");
+        render(&mut display, "R2 DFR1195  S3 UP", &events);
+        esp_println::println!("r2-dfr1195: alive (tick {tick})");
