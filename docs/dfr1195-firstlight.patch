+/// Serve a CoC bidirectionally as the bridge data path: recv frames → CTRL_IN (tagged with `peer`),
+/// CTRL_OUT → send frames. Frame = [len_lo,len_hi, payload] (R2-BLE §6.4 LE prefix). Returns on disconnect.
+#[cfg(feature = "ble")]
+async fn serve_coc<'d, C: trouble_host::prelude::Controller>(
+    stack: &trouble_host::prelude::Stack<'d, C, trouble_host::prelude::DefaultPacketPool>,
+    ch: trouble_host::prelude::L2capChannel<'d, trouble_host::prelude::DefaultPacketPool>,
+    peer: u32,
+) {
+    use embassy_futures::select::{select, Either};
+    let (mut tx, mut rx) = ch.split();
+    let recv = async {
+        let mut buf = [0u8; 256];
+        loop {
+            match rx.receive(stack, &mut buf).await {
+                Ok(n) if n >= 2 => {
+                    let len = buf[0] as usize | ((buf[1] as usize) << 8);
+                    if 2 + len <= n {
+                        let l = len.min(103);
+                        let mut pb = [0u8; 103];
+                        pb[..l].copy_from_slice(&buf[2..2 + l]);
+                        CTRL_IN.lock(|c| {
+                            let mut q = c.borrow_mut();
+                            if q.is_full() {
+                                let _ = q.pop_front();
+                            }
+                            let _ = q.push_back((peer, pb, l));
+                        });
+                        println!("r2-dfr1195: NEG CoC RECV from {peer:08x} ({l} B)");
+                    }
+                }
+                Ok(_) => {}
+                Err(_) => break,
+            }
+        }
+    };
+    let send = async {
+        loop {
+            let item = CTRL_OUT.lock(|c| c.borrow_mut().pop_front());
+            if let Some((target, b, n)) = item {
+                let mut frame = [0u8; 105];
+                frame[0] = (n & 0xff) as u8;
+                frame[1] = ((n >> 8) & 0xff) as u8;
+                frame[2..2 + n].copy_from_slice(&b[..n]);
+                if tx.send(stack, &frame[..2 + n]).await.is_err() {
+                    break;
+                }
+                println!("r2-dfr1195: NEG CoC SENT to {target:08x} ({n} B)");
+            } else {
+                Timer::after(Duration::from_millis(50)).await;
+            }
+        }
+    };
+    match select(recv, send).await {
+        Either::First(()) | Either::Second(()) => {}
+    }
+}
+
+/// L2CAP CoC PSM for the R2 control plane (R2-WIRE event transport, R2-BLE §6). OTA = 0x00D3.
+#[cfg(feature = "ble")]
+const R2_PSM: u16 = 0x00D2;
+
+/// M7 CoC-connectivity test: the provider board (lowest of the 2 test boards). The M9 engine does
+/// real §4A.3 election (lowest eligible hive_id) — this const is just the 2-board CoC bring-up.
+#[cfg(feature = "ble")]
+const M7_PROVIDER_HIVE: u32 = 0x0dca_dbf8; // ACM11
+
+/// Known TG hive_ids (bring-up registry for RBID→hive_id resolution; the real roster comes from
+/// peers.rs / the persona later). KS1-canonical ids of the 9-board TG. (Used by M8 scan/resolve.)
+#[cfg(feature = "ble")]
+#[allow(dead_code)]
+const KNOWN_HIVE_IDS: &[u32] = &[0x480e_900e, 0x2cab_5f69, 0x06ae_082b, 0x0dca_dbf8];
+
+/// Scan event handler: decode each observed R2-BEACON + resolve its RBID → hive_id.
+#[cfg(feature = "ble")]
+struct R2ScanHandler<'a> {
+    registry: &'a [(u32, [u8; 16])],
+    epoch: u64,
+}
+
+#[cfg(feature = "ble")]
+impl trouble_host::prelude::EventHandler for R2ScanHandler<'_> {
+    fn on_adv_reports(&self, reports: bt_hci::param::LeAdvReportsIter) {
+        use r2_discovery::beacon::{decode_advert, resolve_rbid_windowed};
+        for rep in reports.flatten() {
+            let Some(payload) = ble_find_mfg_ad(rep.data) else { continue };
+            let Ok(b) = decode_advert(payload) else { continue };
+            // ±1 epoch window absorbs clock skew (R2-DISCOVERY §3.3)
+            match resolve_rbid_windowed(&b.rbid, self.registry, self.epoch, 1) {
+                Some(hive) => println!(
+                    "r2-dfr1195: BLE scan -> peer hive={hive:08x} (rbid {:02x}{:02x}..)",
+                    b.rbid[0], b.rbid[1]
+                ),
+                None => println!(
+                    "r2-dfr1195: BLE scan -> R2-BEACON rbid={:02x}{:02x}.. unresolved",
+                    b.rbid[0], b.rbid[1]
+                ),
+            }
+        }
+    }
+}
+
+/// Walk BLE AD structures, return the manufacturer-specific (0xFF) element's data.
+#[cfg(feature = "ble")]
+fn ble_find_mfg_ad(data: &[u8]) -> Option<&[u8]> {
+    let mut i = 0;
+    while i + 1 < data.len() {
+        let len = data[i] as usize;
+        if len == 0 || i + 1 + len > data.len() {
+            break;
+        }
+        if data[i + 1] == 0xFF {
+            return Some(&data[i + 2..i + 1 + len]);
+        }
+        i += 1 + len;
+    }
+    None
+}
+
+// ── M8: NegotiationRadio sync↔async bridge ─────────────────────────────────────
+// The trait is SYNC (engine.poll); BLE is async. Bridge via static queues: the async BLE tasks
+// (scan handler / conn-manager) fill+drain them; the sync EspNegRadio façade push/pops for the engine.
+#[cfg(feature = "ble")]
+type CtrlItem = (u32, [u8; 103], usize); // (peer_hive, encoded ControlMsg, len)
+#[cfg(feature = "ble")]
+static SCAN_OBS: embassy_sync::blocking_mutex::Mutex<CriticalSectionRawMutex, core::cell::RefCell<heapless::Deque<(u32, bool, u8), 16>>> =
+    embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(heapless::Deque::new()));
+#[cfg(feature = "ble")]
+static CTRL_OUT: embassy_sync::blocking_mutex::Mutex<CriticalSectionRawMutex, core::cell::RefCell<heapless::Deque<CtrlItem, 8>>> =
+    embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(heapless::Deque::new()));
+#[cfg(feature = "ble")]
+static CTRL_IN: embassy_sync::blocking_mutex::Mutex<CriticalSectionRawMutex, core::cell::RefCell<heapless::Deque<CtrlItem, 8>>> =
+    embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(heapless::Deque::new()));
+#[cfg(feature = "ble")]
+static DATA_PLANE_AVAIL: AtomicBool = AtomicBool::new(false);
+/// Signalled by join_provider → the wifi task connects the joiner to the provider's SoftAP (M8c).
+#[cfg(feature = "ble")]
+static DATA_PLANE_JOIN: Signal<CriticalSectionRawMutex, ()> = Signal::new();
+
+/// Heartbeat-over-ESP-NOW BRIDGE (mesh): io_task's PROVEN conductor-PLL drives these channels instead of
+/// the UDP socket (cfg-gated). ESPNOW_TX = beats io_task wants broadcast → espnow_task ESP-NOW-broadcasts.
+/// ESPNOW_RX = frames espnow_task received → io_task's recv-select reads them. Reuses the exact PLL, no AP.
+#[cfg(feature = "ble")]
+type MeshFrame = ([u8; 256], usize);
+#[cfg(feature = "ble")]
+static ESPNOW_TX: embassy_sync::channel::Channel<CriticalSectionRawMutex, MeshFrame, 4> =
+    embassy_sync::channel::Channel::new();
+#[cfg(feature = "ble")]
+static ESPNOW_RX: embassy_sync::channel::Channel<CriticalSectionRawMutex, MeshFrame, 4> =
+    embassy_sync::channel::Channel::new();
+
+/// M-ESPNOW-2: hive_id↔WiFi-MAC map, LEARNED from the ESP-NOW recv src (core's design — no MAC in the
+/// beacon). Populated from each received frame's originator hive + its L2 src MAC. r2-route unicast
+/// (M-ESPNOW-3) looks up map[hive_id] → ESP-NOW send_to(mac). Broadcast (heartbeat) needs no map.
+#[cfg(feature = "ble")]
+static HIVE_MAC: embassy_sync::blocking_mutex::Mutex<
+    CriticalSectionRawMutex,
+    core::cell::RefCell<heapless::Vec<(u32, [u8; 6]), 16>>,
+> = embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(heapless::Vec::new()));
+
+/// Upsert a learned hive_id↔MAC pair (M-ESPNOW-2). Returns true if newly mapped (for logging).
+#[cfg(feature = "ble")]
+fn map_peer(hive: u32, mac: [u8; 6]) -> bool {
+    HIVE_MAC.lock(|c| {
+        let mut v = c.borrow_mut();
+        if let Some(e) = v.iter_mut().find(|(h, _)| *h == hive) {
+            e.1 = mac;
+            false
+        } else {
+            let _ = v.push((hive, mac));
+            true
+        }
+    })
+}
+
+/// Push a resolved scan observation for the engine's poll_scan (called from on_adv_reports).
+#[cfg(feature = "ble")]
+#[allow(dead_code)]
+fn push_scan_obs(hive: u32, provider_capable: bool, power_bits: u8) {
+    SCAN_OBS.lock(|c| {
+        let mut q = c.borrow_mut();
+        if q.is_full() {
+            let _ = q.pop_front();
+        }
+        let _ = q.push_back((hive, provider_capable, power_bits));
+    });
+}
+
+/// Sync NegotiationRadio façade over the async BLE bridge + the WiFi data plane.
+#[cfg(feature = "ble")]
+struct EspNegRadio;
+#[cfg(feature = "ble")]
+impl r2_discovery::negotiation::NegotiationRadio for EspNegRadio {
+    fn advertise(&mut self, _beacon: &r2_discovery::negotiation::BeaconAd) {
+        // the async advertise loop keeps the beacon up continuously (S0–S4); nothing per-poll.
+    }
+    fn poll_scan(&mut self) -> Option<r2_discovery::negotiation::NegObservation> {
+        let obs = SCAN_OBS.lock(|c| c.borrow_mut().pop_front());
+        obs.map(|(h, pc, ps)| {
+            r2_discovery::negotiation::NegObservation::new(h, pc, r2_discovery::beacon::PowerState::from_bits(ps))
+        })
+    }
+    fn send_control(&mut self, peer: r2_discovery::HiveId, msg: &r2_discovery::negotiation::ControlMsg) {
+        let mut b = [0u8; r2_discovery::negotiation::ControlMsg::MAX_ENCODED_LEN];
+        let n = msg.encode(&mut b);
+        CTRL_OUT.lock(|c| {
+            let mut q = c.borrow_mut();
+            if q.is_full() {
+                let _ = q.pop_front();
+            }
+            let _ = q.push_back((peer, b, n));
+        });
+    }
+    fn poll_control(&mut self) -> Option<(r2_discovery::HiveId, r2_discovery::negotiation::ControlMsg)> {
+        let item = CTRL_IN.lock(|c| c.borrow_mut().pop_front());
+        item.and_then(|(h, b, n)| r2_discovery::negotiation::ControlMsg::decode(&b[..n]).map(|m| (h, m)))
+    }
+    fn bring_up_provider(&mut self, _p: &r2_discovery::negotiation::DataPlaneParams) -> bool {
+        // M8c: the provider already serves the "r2-tn-form" SoftAP from boot → data plane is up.
+        DATA_PLANE_AVAIL.store(true, Ordering::Relaxed);
+        true
+    }
+    fn join_provider(&mut self, _p: &r2_discovery::negotiation::DataPlaneParams) -> bool {
+        // M8c: signal the wifi task to connect this joiner to the provider's SoftAP (real WiFi form).
+        // DATA_PLANE_AVAIL is set by the wifi task once the link is actually up.
+        DATA_PLANE_JOIN.signal(());
+        true
+    }
+    fn data_plane_state(&self) -> r2_discovery::negotiation::DataPlaneState {
+        if DATA_PLANE_AVAIL.load(Ordering::Relaxed) {
+            r2_discovery::negotiation::DataPlaneState::Available
+        } else {
+            r2_discovery::negotiation::DataPlaneState::Unavailable
+        }
+    }
+    fn teardown_data_plane(&mut self) {
+        DATA_PLANE_AVAIL.store(false, Ordering::Relaxed);
+    }
+    fn now_ms(&self) -> u64 {
+        embassy_time::Instant::now().as_millis()
+    }
+}
+
+/// M9: run the S0–S4 negotiation engine over the sync EspNegRadio (driven by the async bridge).
+#[cfg(feature = "ble")]
+#[embassy_executor::task]
+async fn engine_task(my_hive: u32) {
+    use r2_discovery::beacon::PowerState;
+    use r2_discovery::negotiation::{NegotiationEngine, NegotiationState, NodeCaps};
+    let mut radio = EspNegRadio;
+    let mut eng = NegotiationEngine::<16>::new(my_hive, NodeCaps::new(true, PowerState::Normal), 5000, 10000);
+    let mut prev: Option<NegotiationState> = None;
+    let mut ticks = 0u32;
+    let mut requested = false;
+    loop {
+        // Discover for ~3s first (let the roster fill from scans/injected obs) BEFORE requesting the
+        // data plane, so the election sees peers instead of self-electing alone.
+        if !requested && ticks >= 15 {
+            eng.request_data_plane();
+            requested = true;
+            println!("r2-dfr1195: NEG requesting data plane (roster discovered)");
+        }
+        ticks += 1;
+        let st = eng.poll(&mut radio);
+        if prev != Some(st) {
+            println!("r2-dfr1195: NEG state -> {st:?} provider={:?}", eng.provider());
+            prev = Some(st);
+        }
+        Timer::after(Duration::from_millis(200)).await;
+    }
+}
+
+/// ESP-NOW true-mesh data plane (Mode 2) — M-ESPNOW-1: validate broadcast/recv on metal. Every device
+/// peers connectionlessly (no AP); the src MAC on each frame learns the hive_id↔MAC map (core's design).
+/// Broadcasts an R2M probe + logs observed peers. Next: feed r2-route + heartbeat-over-broadcast + unicast.
+#[cfg(feature = "ble")]
+#[embassy_executor::task]
+async fn espnow_task(esp_now: esp_radio::esp_now::EspNow<'static>, my_hive: u32) {
+    use embassy_futures::join::join;
+    use esp_radio::esp_now::BROADCAST_ADDRESS;
+    let (manager, mut sender, mut receiver) = esp_now.split();
+    // Pin a FIXED mesh channel so all boards' ESP-NOW radios align WITHOUT an AP (no AP-join to set the
+    // channel). Every mesh node must use the same channel; ch1 is the R2 mesh default.
+    let _ = manager.set_channel(1);
+    println!("r2-dfr1195: ESP-NOW mesh up (hive {my_hive:08x}) ch1 — heartbeat over ESP-NOW broadcast");
+    // BRIDGE: drain ESPNOW_TX (io_task's conductor beats) → ESP-NOW broadcast; ESP-NOW recv → ESPNOW_RX
+    // (io_task's PROVEN conductor-PLL decodes + syncs). M-ESPNOW-2: learn peer hive↔src-MAC from the recv.
+    let tx = async {
+        loop {
+            let (frame, n) = ESPNOW_TX.receive().await;
+            let _ = sender.send_async(&BROADCAST_ADDRESS, &frame[..n]).await;
+        }
+    };
+    let rx = async {
+        let mut logged = 0u32;
+        loop {
+            let r = receiver.receive_async().await;
+            let d = r.data();
+            let n = d.len().min(256);
+            let mut f = [0u8; 256];
+            f[..n].copy_from_slice(&d[..n]);
+            let _ = ESPNOW_RX.try_send((f, n)); // → io_task PLL (the sync)
+            // M-ESPNOW-2: learn hive_id↔MAC from the recv — the R2-WIRE Heartbeat payload carries the
+            // originator hive (be32), the L2 src MAC is r.info.src_address. Map for r2-route unicast (M-ESPNOW-3).
+            let s = r.info.src_address;
+            if let Ok(m) = r2_wire::decode_extended(&d[..n]) {
+                if m.header.msg_type == MsgType::Heartbeat && m.payload.len() >= 4 {
+                    let origin =
+                        u32::from_be_bytes([m.payload[0], m.payload[1], m.payload[2], m.payload[3]]);
+                    if map_peer(origin, s) {
+                        println!(
+                            "r2-dfr1195: ESP-NOW peer MAPPED hive={origin:08x} mac={:02x}:{:02x}:{:02x}:{:02x}:{:02x}:{:02x}",
+                            s[0], s[1], s[2], s[3], s[4], s[5]
+                        );
+                    }
+                }
+            }
+            let _ = logged;
+        }
+    };
+    join(tx, rx).await;
+}
+
+/// IDENTIFY inject-bridge: read "IDENTIFY <wire_hex> <1|0>" lines off the USB-Serial-JTAG RX
+/// (composer's orchestrator writes them to the chosen board's USB-serial) and broadcast the
+/// r2.hb.identify Directed frame so the target board lights SOLID. Runs on every board (the RX
+/// FIFO is empty unless composer's --identify-port targets it; esp-println keeps the TX FIFO).
+#[embassy_executor::task]
+async fn uart_rx_task(
+    stack: embassy_net::Stack<'static>,
+    my_tg_hash: u32,
+    mut usb_rx: UsbSerialJtagRx<'static, esp_hal::Blocking>,
+) {
+    let mut rx_meta = [PacketMetadata::EMPTY; 2];
+    let mut rx_buf = [0u8; 128];
+    let mut tx_meta = [PacketMetadata::EMPTY; 2];
+    let mut tx_buf = [0u8; 128];
+    let mut socket = UdpSocket::new(stack, &mut rx_meta, &mut rx_buf, &mut tx_meta, &mut tx_buf);
+    let _ = socket.bind(R2_IDENTIFY_BRIDGE_PORT);
+    let bcast = IpEndpoint::new(IpAddress::Ipv4(Ipv4Address::new(192, 168, 4, 255)), R2_UDP_PORT);
+    let mut line = [0u8; 64];
+    let mut n = 0usize;
+    loop {
+        if let Ok(c) = usb_rx.read_byte() {
+            if c == b'\n' || c == b'\r' {
+                if n > 0 {
+                    if let Some((target, on)) = parse_identify(&line[..n]) {
+                        let payload = [u8::from(on)];
+                        let hdr = ExtendedHeader {
+                            version: 0,
+                            msg_type: MsgType::Event,
+                            flags: Flags { mcu_origin: true, ..Default::default() },
+                            ttl: 2,
+                            k: 1,
+                            msg_id: 0,
+                            event_hash: IDENTIFY_HASH,
+                            payload_len: 1,
+                            target_group: my_tg_hash,
+                            target_hive: target,
+                        };
+                        let m = ExtendedMessage { header: hdr, route: None, payload: &payload, hmac_tag: None };
+                        let mut txb = [0u8; 64];
+                        if let Ok(sz) = encode_extended(&m, &mut txb) {
+                            let _ = socket.send_to(&txb[..sz], bcast).await;
+                        }
+                        println!("r2-dfr1195: IDENTIFY-inject target={target:08x} on={on}");
+                    }
+                    n = 0;
+                }
+            } else if n < line.len() {
+                line[n] = c;
+                n += 1;
+            }
+        } else {
+            Timer::after(Duration::from_millis(20)).await;
+        }
+    }
+}
+
+/// Parse "IDENTIFY <wire_hex> <1|0>" → (target_hive, on).
+fn parse_identify(s: &[u8]) -> Option<(u32, bool)> {
+    let s = core::str::from_utf8(s).ok()?;
+    let mut it = s.split_ascii_whitespace();
+    if it.next()? != "IDENTIFY" {
+        return None;
+    }
+    let target = u32::from_str_radix(it.next()?, 16).ok()?;
+    let on = it.next()? != "0";
+    Some((target, on))
+}
+
+/// OTA network receiver (#17) — FLASH-WRITE-WHILE-WIFI DE-RISK (esp-storage#31).
+/// The slot-switch/commit path is already proven (test b). The open hardware question is
+/// whether an esp-storage flash write (cache-suspend) RETURNS PROMPTLY with esp-radio
+/// running, or hangs/browns-out. Self-triggered ~15 s after boot (mesh synced, WiFi
+/// active): erase+write one 4 KB sector to the INACTIVE OTA slot (harmless — not booted)
+/// and report the elapsed time. A printed "wtest write_ok=.. Nms" = per-chunk streaming is
+/// viable; a hang (no line, heartbeat stops) = the radio must be quiesced around the burst.
+/// Board-to-board auto-OTA push is TEST scaffolding only — OFF for the live mesh so the
+/// AP behaves as a normal soft-AP/conductor candidate. The receiver stays active on STAs;
+/// real OTA pushes come from the orchestrator over the same START/DATA/COMMIT protocol.
+const OTA_SELFTEST: bool = false;
+
+#[embassy_executor::task]
+async fn ota_task(is_ap: bool, stack: embassy_net::Stack<'static>) {
+    Timer::after(Duration::from_secs(12)).await; // let WiFi + the mesh settle
+    if is_ap {
+        if OTA_SELFTEST {
+            ota_sender(stack).await; // TEST: one-shot board-to-board push
+        }
+    } else {
+        ota_receiver(stack).await; // the deliverable: accept a streamed network OTA
+    }
+}
+
+/// OTA network receiver (#17). Streams an image over UDP into the INACTIVE OTA slot and,
+/// on a SHA-256-verified COMMIT, activates it + reboots — the no-USB update path. The
+/// flash writes run with WiFi up (de-risked: ~20ms/sector, heartbeat-safe), so no quiesce.
+/// Protocol (stop-and-wait): OST<total:4><sha:32> -> OAK; ODT<off:4><payload> -> OAK<written:4>;
+/// OCM -> verify -> ODN + activate + reboot (or OER).
+async fn ota_receiver(stack: embassy_net::Stack<'static>) {
+    use embedded_storage::{ReadStorage, Storage};
+    use sha2::{Digest, Sha256};
+    let mut rx_meta = [PacketMetadata::EMPTY; 8];
+    let mut rx_buf = [0u8; 2048];
+    let mut tx_meta = [PacketMetadata::EMPTY; 4];
+    let mut tx_buf = [0u8; 256];
+    let mut socket = UdpSocket::new(stack, &mut rx_meta, &mut rx_buf, &mut tx_meta, &mut tx_buf);
+    socket.bind(R2_OTA_PORT).expect("bind OTA port");
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut tbl = [0u8; esp_bootloader_esp_idf::partitions::PARTITION_TABLE_MAX_LEN];
+    let mut ota = match esp_bootloader_esp_idf::ota_updater::OtaUpdater::new(&mut flash, &mut tbl) {
+        Ok(o) => o,
+        Err(_) => return,
+    };
+    let mut region = None;
+    let mut hasher = Sha256::new();
+    let mut expected = [0u8; 32];
+    let mut total = 0u32;
+    let mut written = 0u32;
+    let mut secbuf = [0u8; 4096];
+    let mut secfill = 0usize;
+    let mut secbase = 0u32;
+    let mut pkt = [0u8; 1500];
+    loop {
+        let (n, from) = match socket.recv_from(&mut pkt).await {
+            Ok(v) => v,
+            Err(_) => continue,
+        };
+        if n < 3 {
+            continue;
+        }
+        match &pkt[0..3] {
+            b"OST" if n >= 39 => {
+                total = u32::from_be_bytes([pkt[3], pkt[4], pkt[5], pkt[6]]);
+                expected.copy_from_slice(&pkt[7..39]);
+                region = match ota.next_partition() {
+                    Ok((r, _)) => Some(r),
+                    Err(_) => None,
+                };
+                hasher = Sha256::new();
+                written = 0;
+                secfill = 0;
+                secbase = 0;
+                println!("r2-dfr1195: OTA RX start total={total}");
+                let _ = socket.send_to(b"OAK\0\0\0\0", from).await;
+            }
+            b"ODT" if n >= 7 => {
+                let off = u32::from_be_bytes([pkt[3], pkt[4], pkt[5], pkt[6]]);
+                if off == written {
+                    if let Some(r) = region.as_mut() {
+                        let mut p = &pkt[7..n];
+                        while !p.is_empty() {
+                            let take = core::cmp::min(4096 - secfill, p.len());
+                            secbuf[secfill..secfill + take].copy_from_slice(&p[..take]);
+                            secfill += take;
+                            p = &p[take..];
+                            if secfill == 4096 {
+                                let _ = r.write(secbase, &secbuf);
+                                secbase += 4096;
+                                secfill = 0;
+                            }
+                        }
+                        hasher.update(&pkt[7..n]);
+                        written += (n - 7) as u32;
+                    }
+                }
+                let mut ack = *b"OAK\0\0\0\0";
+                ack[3..7].copy_from_slice(&written.to_be_bytes());
+                let _ = socket.send_to(&ack, from).await;
+            }
+            b"OCM" => {
+                let mut magic = [0u8; 4];
+                if let Some(r) = region.as_mut() {
+                    if secfill > 0 {
+                        let _ = r.write(secbase, &secbuf[..secfill]);
+                    }
+                    let _ = r.read(0, &mut magic); // read back ota_1 image header (expect 0xE9)
+                }
+                let got = hasher.finalize_reset();
+                let sha_ok = got.as_slice() == expected;
+                let ok = written == total && sha_ok;
+                println!(
+                    "r2-dfr1195: OTA RX commit written={written}/{total} sha_ok={sha_ok} ota1_hdr={:02x}{:02x}{:02x}{:02x}",
+                    magic[0], magic[1], magic[2], magic[3]
+                );
+                if ok {
+                    region = None; // drop the FlashRegion borrow before activate
+                    let _ = socket.send_to(b"ODN\0\0\0\0", from).await;
+                    let ar = ota.activate_next_partition();
+                    println!("r2-dfr1195: OTA activate ok={}", ar.is_ok());
+                    Timer::after(Duration::from_millis(300)).await;
+                    esp_hal::system::software_reset();
+                } else {
+                    let _ = socket.send_to(b"OER\0\0\0\0", from).await;
+                }
+            }
+            _ => {}
+        }
+    }
+}
+
+/// TEST scaffolding (one-shot, AP only): push our running ota_0 image to the STA's OTA
+/// receiver so the OTA path is verifiable board-to-board (no soft-AP host needed). Reads
+/// ota_0[0..LEN], SHA-256s it, streams OST/ODT/OCM to 192.168.4.16:21043 stop-and-wait.
+async fn ota_sender(stack: embassy_net::Stack<'static>) {
+    use embedded_storage::ReadStorage;
+    use sha2::{Digest, Sha256};
+    const LEN: u32 = 0x8_0000; // 512 KB covers the ~512 KB app image (+ 0xFF tail)
+    const SRC: u32 = 0x2_0000; // ota_0 base
+    let mut rx_meta = [PacketMetadata::EMPTY; 4];
+    let mut rx_buf = [0u8; 256];
+    let mut tx_meta = [PacketMetadata::EMPTY; 4];
+    let mut tx_buf = [0u8; 1500];
+    let mut socket = UdpSocket::new(stack, &mut rx_meta, &mut rx_buf, &mut tx_meta, &mut tx_buf);
+    socket.bind(R2_OTA_PORT + 1).expect("bind OTA sender port");
+    let dst = IpEndpoint::new(IpAddress::Ipv4(Ipv4Address::new(192, 168, 4, 16)), R2_OTA_PORT);
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut buf = [0u8; 1024];
+    let mut ack = [0u8; 16];
+
+    // 1) SHA-256 over the image bytes we'll send.
+    let mut hasher = Sha256::new();
+    let mut off = 0u32;
+    while off < LEN {
+        let take = core::cmp::min(1024, (LEN - off) as usize);
+        if flash.read(SRC + off, &mut buf[..take]).is_err() {
+            println!("r2-dfr1195: OTA TX read err");
+            return;
+        }
+        hasher.update(&buf[..take]);
+        off += take as u32;
+    }
+    let sha = hasher.finalize();
+
+    // 2) START (retry until OAK).
+    let mut start = [0u8; 39];
+    start[0..3].copy_from_slice(b"OST");
+    start[3..7].copy_from_slice(&LEN.to_be_bytes());
+    start[7..39].copy_from_slice(&sha);
+    for _ in 0..10 {
+        let _ = socket.send_to(&start, dst).await;
+        match select(Timer::after(Duration::from_millis(800)), socket.recv_from(&mut ack)).await {
+            Either::Second(Ok(_)) => break,
+            _ => continue,
+        }
+    }
+    println!("r2-dfr1195: OTA TX start sent (LEN={LEN})");
+
+    // 3) DATA stop-and-wait (ACK echoes cumulative `written`).
+    off = 0;
+    let mut pktbuf = [0u8; 1031];
+    while off < LEN {
+        let take = core::cmp::min(1024, (LEN - off) as usize);
+        let _ = flash.read(SRC + off, &mut buf[..take]);
+        pktbuf[0..3].copy_from_slice(b"ODT");
+        pktbuf[3..7].copy_from_slice(&off.to_be_bytes());
+        pktbuf[7..7 + take].copy_from_slice(&buf[..take]);
+        let mut acked = false;
+        for _ in 0..12 {
+            let _ = socket.send_to(&pktbuf[..7 + take], dst).await;
+            if let Either::Second(Ok((an, _))) =
+                select(Timer::after(Duration::from_millis(400)), socket.recv_from(&mut ack)).await
+            {
+                if an >= 7 && &ack[0..3] == b"OAK" {
+                    let w = u32::from_be_bytes([ack[3], ack[4], ack[5], ack[6]]);
+                    if w >= off + take as u32 {
+                        acked = true;
+                        break;
+                    }
+                }
+            }
+        }
+        if !acked {
+            println!("r2-dfr1195: OTA TX stalled at off={off}");
+            return;
+        }
+        off += take as u32;
+        if off % 0x10000 == 0 {
+            println!("r2-dfr1195: OTA TX {off}/{LEN}");
+        }
+    }
+
+    // 4) COMMIT.
+    for _ in 0..10 {
+        let _ = socket.send_to(b"OCM", dst).await;
+        match select(Timer::after(Duration::from_millis(800)), socket.recv_from(&mut ack)).await {
+            Either::Second(Ok((an, _))) if an >= 3 && &ack[0..3] == b"ODN" => {
+                println!("r2-dfr1195: OTA TX done — STA committed + rebooting");
+                return;
+            }
+            Either::Second(Ok((an, _))) if an >= 3 && &ack[0..3] == b"OER" => {
+                println!("r2-dfr1195: OTA TX commit REJECTED (sha/len mismatch)");
+                return;
+            }
+            _ => continue,
+        }
+    }
+}
+
+/// WiFi event loop. STA: connect + reconnect on drop. AP: already up; observe joins.
+#[embassy_executor::task]
+async fn wifi_task(mut controller: WifiController<'static>, serve_ap: bool) {
+    if serve_ap {
+        loop {
+            match controller.wait_for_access_point_connected_event_async().await {
+                Ok(_) => println!("r2-dfr1195: [ap] station joined"),
+                Err(e) => println!("r2-dfr1195: [ap] event err {e:?}"),
+            }
+        }
+    } else {
+        // M8c joiner (ble): connect to the formed SoftAP ONLY when the engine elects+offers
+        // (join_provider → DATA_PLANE_JOIN). The boot controller config is already "r2-tn-form".
+        #[cfg(feature = "ble")]
+        loop {
+            DATA_PLANE_JOIN.wait().await;
+            println!("r2-dfr1195: data plane — joining provider SoftAP r2-tn-form (on negotiation)");
+            match controller.connect_async().await {
+                Ok(_) => {
+                    DATA_PLANE_AVAIL.store(true, Ordering::Relaxed);
+                    println!("r2-dfr1195: data plane UP — joined r2-tn-form (REAL WiFi formed, B->W)");
+                    let _ = controller.wait_for_disconnect_async().await;
+                    DATA_PLANE_AVAIL.store(false, Ordering::Relaxed);
+                    println!("r2-dfr1195: data plane LOST — r2-tn-form disconnected");
+                }
+                Err(e) => {
+                    println!("r2-dfr1195: data plane join failed {e:?}, retry 2s");
+                    Timer::after(Duration::from_secs(2)).await;
+                }
+            }
+        }
+        // Default (mesh) STA: auto-connect to r2-fieldlab (UNCHANGED).
+        #[cfg(not(feature = "ble"))]
+        loop {
+            match controller.connect_async().await {
+                Ok(_) => {
+                    println!("r2-dfr1195: [sta] connected to {FIELDLAB_SSID}");
+                    let _ = controller.wait_for_disconnect_async().await;
+                    println!("r2-dfr1195: [sta] disconnected, retrying");
+                }
+                Err(e) => {
+                    println!("r2-dfr1195: [sta] connect failed {e:?}, retry 2s");
+                    Timer::after(Duration::from_secs(2)).await;
+                }
+            }
+        }
     }
 }
