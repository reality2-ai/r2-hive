+/// R2 mesh UDP port (R2-WIFI §4).
+const R2_UDP_PORT: u16 = 21042;
+
+// ─────────────────────────── Real-TG persona (#20) ───────────────────────────
+/// Flash offset of the provisioned persona bundle (composer write-bins it raw here).
+const PERSONA_OFFSET: u32 = 0x12000;
+
+/// A provisioned trust-group persona, read raw from flash (R2-KEYSTORE v0.2).
+struct Persona {
+    tg_label: heapless::String<40>, // tg_id UUID string — the real TG label (off "DEMO")
+    tg_hash: u32,                   // FNV-1a-32(tg_id) = frame target_group
+    hk: [u8; 32],                   // group HMAC key — RECEIVED, used directly by the gate
+    hive_id: u32,                   // FNV-1a-32(UUID(HKDF(master_secret, tg_id)))
+}
+
+/// Read + decode the persona bundle from flash @0x12000. None if absent/invalid
+/// (firmware then falls back to the demo TG). Called BEFORE the radio starts, so the
+/// esp-storage flash read can't collide with WiFi (esp-storage#31).
+fn read_persona() -> Option<Persona> {
+    use embedded_storage::ReadStorage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut buf = [0u8; 256];
+    flash.read(PERSONA_OFFSET, &mut buf).ok()?;
+    // CBOR int-keyed map {0:tg_id,1:dek,2:hk,3:master_secret,4:cert,5:tg_pk,6:issued_at}.
+    let mut dec = Decoder::new(&buf);
+    let n = match dec.next().ok()? {
+        Item::Map(n) => n,
+        _ => return None, // erased flash (0xFF) / not a map → no persona
+    };
+    let mut tg_id: Option<&[u8]> = None;
+    let mut hk: Option<[u8; 32]> = None;
+    let mut master: Option<[u8; 32]> = None;
+    for _ in 0..n {
+        let key = match dec.next().ok()? {
+            Item::UInt(k) => k,
+            _ => return None,
+        };
+        match (key, dec.next().ok()?) {
+            (0, Item::Text(t)) => tg_id = Some(t),
+            (2, Item::Bytes(b)) if b.len() == 32 => {
+                let mut a = [0u8; 32];
+                a.copy_from_slice(b);
+                hk = Some(a);
+            }
+            (3, Item::Bytes(b)) if b.len() == 32 => {
+                let mut a = [0u8; 32];
+                a.copy_from_slice(b);
+                master = Some(a);
+            }
+            _ => {}
+        }
+    }
+    let tg_id = tg_id?;
+    let hk = hk?;
+    let master = master?;
+    if tg_id.is_empty() || tg_id.len() > 40 {
+        return None;
+    }
+    let mut tg_label: heapless::String<40> = heapless::String::new();
+    tg_label.push_str(core::str::from_utf8(tg_id).ok()?).ok()?;
+    Some(Persona { tg_label, tg_hash: r2_fnv::fnv1a_32(tg_id), hk, hive_id: derive_hive_id(&master, tg_id) })
+}
+
+/// Canonical TG-scoped hive id (R2-WIRE §6.2.1): FNV-1a-32 of the RFC-4122 UUID string
+/// formed from HKDF-SHA256(ikm=master_secret, salt="r2-hive-id-v1", info=tg_id)[0:16].
+fn derive_hive_id(master: &[u8; 32], tg_id: &[u8]) -> u32 {
+    let hk = hkdf::Hkdf::<sha2::Sha256>::new(Some(b"r2-hive-id-v1"), master);
+    let mut okm = [0u8; 16];
+    if hk.expand(tg_id, &mut okm).is_err() {
+        return 0;
+    }
+    okm[6] = (okm[6] & 0x0F) | 0x40; // version 4
+    okm[8] = (okm[8] & 0x3F) | 0x80; // variant
+    r2_fnv::fnv1a_32(format_uuid(&okm).as_bytes())
+}
+
+/// 16 bytes → lowercase RFC-4122 UUID string (8-4-4-4-12).
+fn format_uuid(b: &[u8; 16]) -> heapless::String<36> {
+    const HEX: &[u8; 16] = b"0123456789abcdef";
+    let mut s: heapless::String<36> = heapless::String::new();
+    for (i, byte) in b.iter().enumerate() {
+        if i == 4 || i == 6 || i == 8 || i == 10 {
+            let _ = s.push('-');
+        }
+        let _ = s.push(HEX[(byte >> 4) as usize] as char);
+        let _ = s.push(HEX[(byte & 0x0F) as usize] as char);
+    }
+    s
+}
