+                            println!("r2-dfr1195: DEDUP msg_id={} dropped", h.msg_id);
+                        } else {
+                            // AP L3 RELAY (B1: trust-agnostic) — re-broadcast forwarded
+                            // frames with ttl-1 so STA-to-STA works across the (cross-arch)
+                            // mesh, independent of any soft-AP L2 rebroadcast. dedup-guarded
+                            // (above) + ttl-bounded. The HMAC covers IMMUTABLE fields only
+                            // (ttl excluded, §10.6) so it survives the decrement.
+                            if is_ap
+                                && h.ttl > 1
+                                && matches!(
+                                    advice.action,
+                                    ForwardAction::Directed(_) | ForwardAction::Flood(_)
+                                )
+                            {
+                                let mut fwd = m; // ExtendedMessage is Copy
+                                fwd.header.ttl -= 1;
+                                if let Ok(n) = encode_extended(&fwd, &mut txbuf) {
+                                    let _ = socket.send_to(&txbuf[..n], peer_ep).await;
+                                    RELAYED.fetch_add(1, Ordering::Relaxed);
+                                    println!(
+                                        "r2-dfr1195: RELAY msg_id={} ttl {}->{}",
+                                        h.msg_id, h.ttl, fwd.header.ttl
+                                    );
+                                }
+                            }
+                            if for_me {
+                                // B1 DELIVER-GATE — trust checked ONLY here (relay above is
+                                // independent). Deliverable iff dest TG is mine AND HMAC ok.
+                                let tg_ok = h.target_group == my_tg_hash || h.target_group == 0;
+                                let hmac_ok = verify_extended(&m, &group_hmac);
+                                if tg_ok && hmac_ok {
+                                    DELIVERED.fetch_add(1, Ordering::Relaxed);
+                                    let body = core::str::from_utf8(m.payload).unwrap_or("?");
+                                    println!(
+                                        "r2-dfr1195: DELIVERED msg_id={} '{}' (tg+hmac ok)",
+                                        h.msg_id, body
+                                    );
+                                } else {
+                                    BLOCKED.fetch_add(1, Ordering::Relaxed);
+                                    println!(
+                                        "r2-dfr1195: DELIVER-BLOCKED msg_id={} tg_ok={tg_ok} hmac_ok={hmac_ok} (relay unaffected)",
+                                        h.msg_id
+                                    );
+                                }
+                            }
+                        }
+                    }
+                },
+                Err(e) => println!("r2-dfr1195: decode err {e:?}"),
+                }
+            }
+        }
+    }
+}
