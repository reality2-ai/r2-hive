+                                // Dashboard liveness: mark this peer heard now (fast join/leave for the mesh size).
+                                if let Some(e) = seen.iter_mut().find(|(h, _)| *h == sender_hive) {
+                                    e.1 = now_s;
+                                } else {
+                                    let _ = seen.push((sender_hive, now_s));
+                                }
+                            }
+                            // ── Leaderless reachback-PCO coupling (R2-HEARTBEAT v0.4 §4.1) ──
+                            // Couple toward THIS neighbour's fire on EVERY heard beat — flat, no conductor,
+                            // no election to thrash (that flatness is exactly why the canon survives the
+                            // 3-node flap = HBSYNC-01). The sender emitted on its own fire (phase 0);
+                            // single-transport ESP-NOW transit << T so delay-comp ≈ 0 here (the §4.2
+                            // reachback term is added with the frame tx_time for the LoRa/HBSYNC-03 gate).
+                            let e = if phase <= 0.5 { -phase } else { 1.0 - phase }; // wrap(0 − phase) ∈ [−0.5,0.5)
+                            let w: f32 = 1.0; // uniform ESP-NOW link weight (per-neighbour w = HBSYNC-09)
+                            phase += K_PHI * w * phase_response(e); // concave bidirectional kick (§4.1)
+                            if phase < 0.0 {
+                                phase += 1.0;
+                            }
+                            if phase >= 1.0 {
+                                phase -= 1.0;
+                            }
+                            // ── §4.3 rate/skew consensus (distributed-β) — converge toward the neighbour RATE
+                            //    on the RECEIVER's LOCAL clock, so each node's rate is pre-matched BEFORE a
+                            //    connectivity blackout drops coupling (HBSYNC-06). β=0 (feature rateoff) = the
+                            //    refuted OFF arm (free-runs on the raw crystal → drifts in the blackout).
+                            let now_ms = embassy_time::Instant::now().as_millis();
+                            if RATE_BETA > 0.0 {
+                                let n_heard = last_rx.len().max(1); // Σw = heard-set size (capture before iter_mut borrow)
+                                if let Some(slot) = last_rx.iter_mut().find(|(h, _)| *h == sender_hive) {
+                                    let interval = now_ms.saturating_sub(slot.1) as f32; // LOCAL rx-interval (ms)
+                                    // A1 (core): only learn rate from SANE intervals (~[0.5, 3] periods). Skip the
+                                    // huge first-post-blackout interval (~15 periods → misrounded k = garbage rate
+                                    // sample exactly when measuring); the phase term re-locks phase anyway.
+                                    if interval > 0.5 * HB_PERIOD_MS && interval < 3.0 * HB_PERIOD_MS {
+                                        let mut k = libm::roundf(interval * rate); // de-alias missed beats
+                                        if k < 1.0 {
+                                            k = 1.0;
+                                        }
+                                        let r_src = k / interval; // sender's apparent rate in MY ms-units
+                                        // A3 (core): Σw over the HEARD/coupling set (distinct senders in last_rx),
+                                        // NOT total mesh size — else under-relax/bias when some counted nodes aren't heard.
+                                        let sum_w = n_heard as f32;
+                                        rate += RATE_BETA * (w / sum_w) * (r_src - rate);
+                                        // A2 (core): clamp around the CANONICAL nominal (not this board's own period)
+                                        // so the consensus has room to pull a rate-biased board back. ±1% ≫ real xtal drift.
+                                        let nom = 1.0 / CANON_PERIOD_MS;
+                                        if rate > nom * 1.01 {
+                                            rate = nom * 1.01;
+                                        }
+                                        if rate < nom * 0.99 {
+                                            rate = nom * 0.99;
+                                        }
+                                    }
+                                    slot.1 = now_ms; // always refresh last-rx (even when the interval is gated out)
+                                } else {
+                                    let _ = last_rx.push((sender_hive, now_ms));
+                                }
+                            }
+                            let eabs = if e < 0.0 { -e } else { e };
+                            last_err_ms = (eabs * HB_PERIOD_MS) as u32; // leaderless spread_ms metric
+                            SYNCED.store(eabs < 0.04, Ordering::Relaxed); // <~80ms = phase-converged
+                            println!(
+                                "r2-dfr1195: HB<-{from} from={sender_hive:06x} e={e:.3} spread={last_err_ms}ms (leaderless)"
+                            );
+                        }
+                    }
+                    _ => {
+                        let h = &m.header;
+                        if h.event_hash == IDENTIFY_HASH {
+                            // Roy dashboard locate: target board lights SOLID for ~5s (override).
+                            if h.target_hive == my_hive {
+                                let on = !m.payload.is_empty() && m.payload[0] != 0;
+                                IDENTIFY_TICKS.store(if on { 100 } else { 0 }, Ordering::Relaxed);
+                                println!(
+                                    "r2-dfr1195: IDENTIFY {}",
+                                    if on { "ON (solid LED ~5s)" } else { "OFF" }
+                                );
+                            }
+                            continue;
+                        }
+                        if h.event_hash == HEALTH_HASH {
+                            // #18 health to the collector (AP): log hex for the orchestrator
+                            // serial-reader. Not a routable Event.
+                            if is_ap || h.target_hive == my_hive {
+                                log_health(m.payload);
+                            }
+                            continue;
+                        }
+                        let now = embassy_time::Instant::now().as_secs() as u32;
+                        // BL-200 §4.3.4: feed the reinforcer for routetest Events (origin in payload[0..4],
+                        // marker in payload[4..]). on_received does weak(forward)/strong(reply-i-forwarded)
+                        // + the black-hole guard internally; we just supply (frame_origin, marker, sender).
+                        #[cfg(feature = "routetest")]
+                        if h.event_hash == ROUTETEST_HASH && m.payload.len() >= 4 {
+                            let frame_origin = u32::from_be_bytes([
+                                m.payload[0], m.payload[1], m.payload[2], m.payload[3],
+                            ]);
+                            // INSTRUMENTATION (specs pivotal test): for REPLIES, log marker(origin,msgid) +
+                            // sender + in-window so we see if R1 SHOULD reinforce (D, sender) — pinpoints
+                            // CAP-eviction vs threshold vs wiring vs structural spec-gap.
+                            if let Some((mo, mm)) = r2_route::trail::parse_reply_marker(&m.payload[4..]) {
+                                let in_win = rt_dbg_fwd.iter().any(|&(o, mid)| o == mo && mid == mm);
+                                println!(
+                                    "r2-dfr1195: RT-DBG REPLY replier={frame_origin:08x} sender={src_hive:08x} marker_origin={mo:08x} marker_msgid={mm} in_window={in_win} fwd_calls={rt_fwd_calls} uniq={}",
+                                    rt_dbg_fwd.len()
+                                );
+                            }
+                            reinforcer.on_received(&mut engine, frame_origin, &m.payload[4..], src_hive, now);
+                            // After reinforce: probe the resulting best path to the replier (dest). conf==0
+                            // => reinforcement not firing; conf>0 but still flooding => plan_forward/threshold
+                            // /viable issue (forwarding_threshold defaults 0.0, so any conf>0 SHOULD direct).
+                            if r2_route::trail::parse_reply_marker(&m.payload[4..]).is_some() {
+                                match engine.paths().best_for(frame_origin) {
+                                    Some(p) => println!(
+                                        "r2-dfr1195: RT-DBG PATH to_dest={frame_origin:08x} best_next_hop={:08x} conf={}",
+                                        p.next_hop, (p.confidence * 1000.0) as i32
+                                    ),
+                                    None => println!(
+                                        "r2-dfr1195: RT-DBG PATH to_dest={frame_origin:08x} NONE (conf=0, no path entry)"
+                                    ),
+                                }
+                            }
+                        }
+                        let req = ForwardRequest {
+                            now,
+                            msg_id: h.msg_id as u16,
+                            // R2-WIRE v0.4 dedup origin (originator hive). These fw frames are route:None
+                            // (no carried originator) → 0 here = dedup-by-msg_id (the star/field.lab behavior,
+                            // unchanged). MESH TODO (M-ESPNOW-3): carry the originator in the frame (route_stack[0])
+                            // so multi-hop relay dedups per-origin, not just per-msg_id.
+                            origin: 0,
+                            source_hop: (my_hive & 0xFFFF) as u16,
+                            ttl: h.ttl,
+                            k: h.k,
+                            destination: Target::Address(h.target_hive),
+                            msg_type: h.msg_type,
+                            payload_len: m.payload.len(),
+                            relay_enabled: true,
+                            congested: false,
+                            dice_roll: 0.0,
+                        };
+                        let advice = engine.plan_forward(req);
+                        #[cfg(feature = "ble")]
+                        {
+                            let nbrs = engine.neighbours().len();
+                            match &advice.action {
+                                ForwardAction::Drop(r) => println!(
+                                    "r2-dfr1195: RX-EV msg_id={} tgt={:08x} DROP {:?} nbrs={nbrs}",
+                                    h.msg_id, h.target_hive, r
+                                ),
+                                ForwardAction::DeliverOnly => println!(
+                                    "r2-dfr1195: RX-EV msg_id={} DeliverOnly nbrs={nbrs}",
+                                    h.msg_id
+                                ),
+                                // directed_via{from:me,next_hop:Y} = single directed relay (specs schema).
+                                ForwardAction::Directed(hop) => println!(
+                                    "r2-dfr1195: RX-EV msg_id={} directed_via from={my_hive:08x} next_hop={:08x} nbrs={nbrs}",
+                                    h.msg_id, hop.neighbour
+                                ),
+                                // flooded{from:me} fanout = eligible-neighbour count (specs schema).
+                                ForwardAction::Flood(hops) => println!(
+                                    "r2-dfr1195: RX-EV msg_id={} flooded from={my_hive:08x} fanout={} nbrs={nbrs}",
+                                    h.msg_id, hops.len()
+                                ),
+                            }
+                        }
+                        let for_me = h.target_hive == my_hive || h.target_hive == 0;
+                        if matches!(advice.action, ForwardAction::Drop(DropReason::Duplicate)) {
+                            println!("r2-dfr1195: DEDUP msg_id={} dropped", h.msg_id);
+                        } else {
+                            // AP L3 RELAY (B1: trust-agnostic) — re-broadcast forwarded
+                            // frames with ttl-1 so STA-to-STA works across the (cross-arch)
+                            // mesh, independent of any soft-AP L2 rebroadcast. dedup-guarded
+                            // (above) + ttl-bounded. The HMAC covers IMMUTABLE fields only
+                            // (ttl excluded, §10.6) so it survives the decrement.
+                            // RELAY role: infra = the AP forwards; MESH = ANY node forwards (no AP) —
+                            // dedup (msg_id,origin) + ttl bound it; the allow-list shapes the topology.
+                            #[cfg(not(feature = "ble"))]
+                            let relay_role = is_ap;
+                            #[cfg(feature = "ble")]
+                            let relay_role = true;
+                            if relay_role
+                                && h.ttl > 1
+                                && matches!(
+                                    advice.action,
+                                    ForwardAction::Directed(_) | ForwardAction::Flood(_)
+                                )
+                            {
+                                // BL-200: relaying puts us on this msg's forward path → note it so the
+                                // returning reply strong-reinforces the trail through us (used-path-wins).
+                                #[cfg(feature = "routetest")]
+                                if h.event_hash == ROUTETEST_HASH && m.payload.len() >= 4 {
+                                    let o = u32::from_be_bytes([
+                                        m.payload[0], m.payload[1], m.payload[2], m.payload[3],
+                                    ]);
+                                    reinforcer.note_forwarded(o, h.msg_id as u16);
+                                    rt_fwd_calls += 1;
+                                    if !rt_dbg_fwd.iter().any(|&(oo, mm)| oo == o && mm == h.msg_id as u16) {
+                                        let _ = rt_dbg_fwd.push((o, h.msg_id as u16));
+                                    }
+                                }
+                                let mut fwd = m; // ExtendedMessage is Copy
+                                fwd.header.ttl -= 1;
+                                if let Ok(n) = encode_extended(&fwd, &mut txbuf) {
+                                    // MESH: re-broadcast over ESP-NOW (Flood one-shot reaches all in-range
+                                    // allow-listed neighbours). INFRA: UDP re-broadcast.
+                                    #[cfg(feature = "ble")]
+                                    {
+                                        let mut f = [0u8; 256];
+                                        let mm = n.min(256);
+                                        f[..mm].copy_from_slice(&txbuf[..mm]);
+                                        let _ = DATA_TX.try_send((f, mm));
+                                    }
+                                    #[cfg(not(feature = "ble"))]
+                                    let _ = socket.send_to(&txbuf[..n], peer_ep).await;
+                                    RELAYED.fetch_add(1, Ordering::Relaxed);
+                                    println!(
+                                        "r2-dfr1195: RELAY msg_id={} ttl {}->{}",
+                                        h.msg_id, h.ttl, fwd.header.ttl
+                                    );
+                                }
+                            }
+                            if for_me {
+                                // B1 DELIVER-GATE — trust checked ONLY here (relay above is
+                                // independent). Deliverable iff dest TG is mine AND HMAC ok.
+                                let tg_ok = h.target_group == my_tg_hash || h.target_group == 0;
+                                let hmac_ok = verify_extended(&m, &group_hmac);
+                                if tg_ok && hmac_ok {
+                                    DELIVERED.fetch_add(1, Ordering::Relaxed);
+                                    let body = core::str::from_utf8(m.payload).unwrap_or("?");
+                                    println!(
+                                        "r2-dfr1195: DELIVERED msg_id={} '{}' (tg+hmac ok)",
+                                        h.msg_id, body
+                                    );
+                                    // BL-200: D replies to a delivered REQUEST → the reply retraces +
+                                    // STRONG-reinforces the trail hop-by-hop (normal routing back to origin,
+                                    // NOT route-stack reversal). payload = my_hive(4B)++reply_marker(orig,id).
+                                    #[cfg(feature = "routetest")]
+                                    if h.event_hash == ROUTETEST_HASH
+                                        && m.payload.len() >= 7
+                                        && &m.payload[4..7] == b"req"
+                                    {
+                                        let req_origin = u32::from_be_bytes([
+                                            m.payload[0], m.payload[1], m.payload[2], m.payload[3],
+                                        ]);
+                                        let marker =
+                                            r2_route::trail::reply_marker(req_origin, h.msg_id as u16);
+                                        let mb = marker.as_bytes();
+                                        let ml = mb.len().min(24);
+                                        let mut rp = [0u8; 28];
+                                        rp[0..4].copy_from_slice(&my_hive.to_be_bytes());
+                                        rp[4..4 + ml].copy_from_slice(&mb[..ml]);
+                                        let plen = 4 + ml;
+                                        let rhdr = ExtendedHeader {
+                                            version: 0,
+                                            msg_type: MsgType::Event,
+                                            flags: Flags { mcu_origin: true, ..Default::default() },
+                                            ttl: 5,
+                                            k: 3,
+                                            // BL-200 ROOT-CAUSE FIX (metal-pinpointed): the reply MUST carry a
+                                            // DISTINCT msg_id from the request — dedup is by msg_id (origin=0), so
+                                            // reusing h.msg_id made every relay DROP the reply as a Duplicate of the
+                                            // request it already forwarded -> the reply died at the hop adjacent to
+                                            // dest (which reinforced via on_received-before-dedup) and NEVER
+                                            // propagated upstream = the "converges adjacent-to-dest only, upstream
+                                            // floods" divergence. High bit separates reply-space from request-space
+                                            // (request ids are small u16); the request msg_id stays in the
+                                            // reply_marker payload for correlation. NOT a spec gap.
+                                            // SHARED helper (core e23e7d4, one-codebase like reply_marker):
+                                            // reply ids live in [0x8000,0xFFFF], requests in [0,0x7FFF] —
+                                            // DISJOINT by construction (masks to 15 bits first), so the reply
+                                            // never collides with the request under the u16-truncated dedup.
+                                            // Harness reply-emit uses the same helper. (Deeper canonical fix =
+                                            // carry frame-origin=D + (origin,msg_id) dedup = M-ESPNOW-3 TODO.)
+                                            msg_id: r2_route::trail::reply_msg_id(h.msg_id as u16) as u32,
+                                            event_hash: ROUTETEST_HASH,
+                                            payload_len: plen as u32,
+                                            target_group: my_tg_hash,
+                                            target_hive: req_origin,
+                                        };
+                                        let mut rmsg = ExtendedMessage {
+                                            header: rhdr,
+                                            route: None,
+                                            payload: &rp[..plen],
+                                            hmac_tag: None,
+                                        };
+                                        let (rf, rt) = sign_extended(&rmsg, &group_hmac);
+                                        rmsg.header.flags = rf;
+                                        rmsg.hmac_tag = Some(rt);
+                                        if let Ok(rn) = encode_extended(&rmsg, &mut txbuf) {
+                                            let mut f = [0u8; 256];
+                                            let mm = rn.min(256);
+                                            f[..mm].copy_from_slice(&txbuf[..mm]);
+                                            let _ = DATA_TX.try_send((f, mm));
+                                            println!(
+                                                "r2-dfr1195: RT-REPLY -> {req_origin:08x} req_msg_id={}",
+                                                h.msg_id
+                                            );
+                                        }
+                                    }
+                                } else {
+                                    BLOCKED.fetch_add(1, Ordering::Relaxed);
+                                    println!(
+                                        "r2-dfr1195: DELIVER-BLOCKED msg_id={} tg_ok={tg_ok} hmac_ok={hmac_ok} (relay unaffected)",
+                                        h.msg_id
+                                    );
+                                }
+                            }
+                        }
+                    }
+                },
+                Err(e) => println!("r2-dfr1195: decode err {e:?}"),
+                }
+            }
+        }
+    }
+}
