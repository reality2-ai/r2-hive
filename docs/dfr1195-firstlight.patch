+/// PHASE 2a — raw UDP board↔board over the WiFi link. Sends an R2-PING to the peer
+/// every 2 s and prints every datagram received. Proves the transport pipe (real
+/// frames over real radio) before the R2-WIRE + RouteEngine layer (Phase 2b).
+#[embassy_executor::task]
+async fn io_task(stack: embassy_net::Stack<'static>, peer: Ipv4Address) {
+    let mut rx_meta = [PacketMetadata::EMPTY; 4];
+    let mut rx_buf = [0u8; 1024];
+    let mut tx_meta = [PacketMetadata::EMPTY; 4];
+    let mut tx_buf = [0u8; 1024];
+    let mut socket = UdpSocket::new(stack, &mut rx_meta, &mut rx_buf, &mut tx_meta, &mut tx_buf);
+    socket.bind(21042).expect("bind 21042");
+    let peer_ep = IpEndpoint::new(IpAddress::Ipv4(peer), 21042);
+    let mut scratch = [0u8; 256];
+    let mut seq: u32 = 0;
+    loop {
+        match select(Timer::after(Duration::from_secs(2)), socket.recv_from(&mut scratch)).await {
+            Either::First(_) => {
+                let mut msg: heapless::String<32> = heapless::String::new();
+                let _ = write!(msg, "R2-PING {seq}");
+                match socket.send_to(msg.as_bytes(), peer_ep).await {
+                    Ok(()) => println!("r2-dfr1195: TX -> {peer}:21042  {msg}"),
+                    Err(e) => println!("r2-dfr1195: TX err {e:?}"),
+                }
+                seq = seq.wrapping_add(1);
+            }
+            Either::Second(Ok((n, from))) => {
+                let body = core::str::from_utf8(&scratch[..n]).unwrap_or("<binary>");
+                println!("r2-dfr1195: RX <- {from}  {n}B: {body}");
+            }
+            Either::Second(Err(e)) => println!("r2-dfr1195: RX err {e:?}"),
         }
     }
+}
 
