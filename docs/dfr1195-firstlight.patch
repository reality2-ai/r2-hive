diff --git a/platforms/dfr1195/build.rs b/platforms/dfr1195/build.rs
new file mode 100644
index 0000000..c645602
--- /dev/null
+++ b/platforms/dfr1195/build.rs
@@ -0,0 +1,37 @@
+//! Capture a firmware BUILD ID into the binary so the LCD can show which build is
+//! running (essential for verifying an OTA actually landed). The build command
+//! exports `R2_BUILD_ID` (e.g. `date +%m%d.%H%M`); absent that, it reads "dev".
+fn main() {
+    println!("cargo:rerun-if-env-changed=R2_BUILD_ID");
+    let id = std::env::var("R2_BUILD_ID").unwrap_or_else(|_| "dev".into());
+    println!("cargo:rustc-env=R2_BUILD_ID={id}");
+
+    // staota (#17) WiFi-STA-to-Alfred creds — INJECTED AT FLASH, never hardcoded. Source order: the
+    // R2_WIFI_SSID/R2_WIFI_PASS env vars (e.g. `R2_WIFI_SSID=lab R2_WIFI_PASS=… cargo build`), else
+    // wifi_config.toml (gitignored), else EMPTY (a creds-less build still COMPILES for build-verify; it just
+    // can't associate). Always emit the rustc-env so `env!("R2_WIFI_*")` resolves in every build.
+    println!("cargo:rerun-if-env-changed=R2_WIFI_SSID");
+    println!("cargo:rerun-if-env-changed=R2_WIFI_PASS");
+    println!("cargo:rerun-if-changed=wifi_config.toml");
+    let (mut ssid, mut pass) = (
+        std::env::var("R2_WIFI_SSID").unwrap_or_default(),
+        std::env::var("R2_WIFI_PASS").unwrap_or_default(),
+    );
+    if (ssid.is_empty() || pass.is_empty()) && std::path::Path::new("wifi_config.toml").exists() {
+        if let Ok(toml) = std::fs::read_to_string("wifi_config.toml") {
+            for line in toml.lines() {
+                let line = line.trim();
+                if let Some((k, v)) = line.split_once('=') {
+                    let v = v.trim().trim_matches('"');
+                    match k.trim() {
+                        "ssid" if ssid.is_empty() => ssid = v.to_string(),
+                        "password" if pass.is_empty() => pass = v.to_string(),
+                        _ => {}
+                    }
+                }
+            }
+        }
+    }
+    println!("cargo:rustc-env=R2_WIFI_SSID={ssid}");
+    println!("cargo:rustc-env=R2_WIFI_PASS={pass}");
+}
