+/// Report the active OTA slot at boot. The otadata slot-switch was PROVEN on metal
+/// (test b: wrote a valid image to ota_1 → activate_next_partition() → reboot → ESP-IDF
+/// BL booted ota_1 @0x200000). Now report-only — the real network receiver (#17) does
+/// the write+activate on COMMIT, not auto-on-boot, so this is safe/dormant on the mesh.
+fn ota_slot_report() {
+    use esp_bootloader_esp_idf::ota_updater::OtaUpdater;
+    use esp_bootloader_esp_idf::partitions::{AppPartitionSubType, PARTITION_TABLE_MAX_LEN};
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut tbl = [0u8; PARTITION_TABLE_MAX_LEN];
+    if let Ok(mut ota) = OtaUpdater::new(&mut flash, &mut tbl) {
+        // ANCHOR otadata if erased/Factory: a fresh board (espflash doesn't init otadata)
+        // reads as Factory, and activating ota_1 from Factory computes seq=0 (selects ota_0,
+        // not ota_1) — so OTA wouldn't switch. Anchoring to the running slot (ota_0) makes
+        // current=ota_0 (seq=1), so a later activate -> ota_1 (seq=2) selects correctly.
+        if matches!(
+            ota.ota_data().and_then(|mut o| o.current_app_partition()),
+            Ok(AppPartitionSubType::Factory)
+        ) {
+            let _ = ota
+                .ota_data()
+                .and_then(|mut o| o.set_current_app_partition(AppPartitionSubType::Ota0));
+            println!("r2-dfr1195: OTA otadata anchored -> ota_0 (was erased/Factory)");
+        }
+        if let Ok((_region, next_sub)) = ota.next_partition() {
+            // next == ota_1 ⇒ we're running from ota_0, and vice-versa.
+            let slot = if next_sub == AppPartitionSubType::Ota1 { "ota_0" } else { "ota_1" };
+            println!("r2-dfr1195: OTA slot={slot} (otadata slot-switch verified — test b PASS)");
+        }
+    }
+}
