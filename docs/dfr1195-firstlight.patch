+/// IDENTIFY inject-bridge: read "IDENTIFY <wire_hex> <1|0>" lines off the USB-Serial-JTAG RX
+/// (composer's orchestrator writes them to the chosen board's USB-serial) and broadcast the
+/// r2.hb.identify Directed frame so the target board lights SOLID. Runs on every board (the RX
+/// FIFO is empty unless composer's --identify-port targets it; esp-println keeps the TX FIFO).
+#[embassy_executor::task]
+async fn uart_rx_task(
+    stack: embassy_net::Stack<'static>,
+    my_tg_hash: u32,
+    #[allow(unused_variables)] my_hive: u32,
+    mut usb_rx: UsbSerialJtagRx<'static, esp_hal::Blocking>,
+) {
+    let mut rx_meta = [PacketMetadata::EMPTY; 2];
+    let mut rx_buf = [0u8; 128];
+    let mut tx_meta = [PacketMetadata::EMPTY; 2];
+    let mut tx_buf = [0u8; 128];
+    let mut socket = UdpSocket::new(stack, &mut rx_meta, &mut rx_buf, &mut tx_meta, &mut tx_buf);
+    let _ = socket.bind(R2_IDENTIFY_BRIDGE_PORT);
+    let bcast = IpEndpoint::new(IpAddress::Ipv4(Ipv4Address::new(192, 168, 4, 255)), R2_UDP_PORT);
+    // 128 B: an IDENTIFY line is short, but a PROVISION line is ~94 B ("PROVISION " + 8-hex wire +
+    // decimal tg_id + 64-hex key) — a 64 B buffer truncated the key → BadKeyLength (metal-found).
+    let mut line = [0u8; 128];
+    let mut n = 0usize;
+    loop {
+        if let Ok(c) = usb_rx.read_byte() {
+            if c == b'\n' || c == b'\r' {
+                if n > 0 {
+                    // PROVISION (#20, CROSS-HOST-2TG §6) — same serial inject-bridge as IDENTIFY. Parse +
+                    // validate via core's primitive (do NOT re-implement), persist to NVS, then hand the key
+                    // to io_task (PENDING_PROVISION) to install into the GroupHmac. ACK on serial for composer.
+                    #[cfg(feature = "multitg")]
+                    let is_provision = line[..n].starts_with(b"PROVISION");
+                    #[cfg(not(feature = "multitg"))]
+                    let is_provision = false;
+                    #[cfg(feature = "multitg")]
+                    if is_provision {
+                        match r2_trust::provision::parse_provision(&line[..n], my_hive) {
+                            Ok(Some(cred)) => match write_provisioned_tg(cred.tg_id, &cred.group_hmac_key) {
+                                Ok(()) => {
+                                    PENDING_PROVISION.lock(|c| {
+                                        *c.borrow_mut() = Some((cred.tg_id, cred.group_hmac_key));
+                                    });
+                                    // ACK r2.provision.applied (§6). CBOR {0:wire,1:tg_id} over /r2 is pending
+                                    // specs' canonical key-map pin; serial line is composer's coverage feed now.
+                                    println!(
+                                        "r2-dfr1195: PROVISION-APPLIED wire={my_hive:08x} tg_id={}",
+                                        cred.tg_id
+                                    );
+                                }
+                                Err(()) => println!(
+                                    "r2-dfr1195: PROVISION-ERR wire={my_hive:08x} nvs-write-failed"
+                                ),
+                            },
+                            Ok(None) => {} // not for me (wire != my_hive) — ignore (§6)
+                            Err(e) => {
+                                println!("r2-dfr1195: PROVISION-ERR wire={my_hive:08x} {e:?}")
+                            }
+                        }
+                    }
+                    // routetest: 'MASK <aa:bb:cc:dd:ee:ff> ...' sets THIS board's allowed-neighbour list
+                    // (topology shaping for BL-200/103). Sent to the board's own tty; applies to self.
+                    #[cfg(feature = "routetest")]
+                    let is_mask = line[..n].starts_with(b"MASK ");
+                    #[cfg(not(feature = "routetest"))]
+                    let is_mask = false;
+                    #[cfg(feature = "routetest")]
+                    if is_mask {
+                        let mut macs: heapless::Vec<[u8; 6], 8> = heapless::Vec::new();
+                        if let Ok(s) = core::str::from_utf8(&line[..n]) {
+                            for tok in s.split_ascii_whitespace().skip(1) {
+                                if let Some(mac) = parse_mac(tok) {
+                                    let _ = macs.push(mac);
+                                }
+                            }
+                        }
+                        set_mask(&macs);
+                        println!("r2-dfr1195: MASK-SET allowed_neighbours={}", macs.len());
+                    }
+                    // routetest: 'SENDTO <dest_hex>' makes THIS board the BL-200 origin (A) sending
+                    // directed requests to <dest> (D). 'SENDTO 0' clears it. Self-applied per-tty.
+                    #[cfg(feature = "routetest")]
+                    let is_sendto = line[..n].starts_with(b"SENDTO ");
+                    #[cfg(not(feature = "routetest"))]
+                    let is_sendto = false;
+                    #[cfg(feature = "routetest")]
+                    if is_sendto {
+                        if let Ok(s) = core::str::from_utf8(&line[..n]) {
+                            if let Some(tok) = s.split_ascii_whitespace().nth(1) {
+                                if let Ok(dest) = u32::from_str_radix(tok, 16) {
+                                    ROUTETEST_DEST.store(dest, Ordering::Relaxed);
+                                    write_dest_nvs(dest); // persist so origin survives the capture DTR-reset
+                                    println!("r2-dfr1195: SENDTO-SET dest={dest:08x} (this board = BL-200 origin)");
+                                }
+                            }
+                        }
+                    }
+                    if !is_provision && !is_mask && !is_sendto {
+                    if let Some((target, on)) = parse_identify(&line[..n]) {
+                        let payload = [u8::from(on)];
+                        let hdr = ExtendedHeader {
+                            version: 0,
+                            msg_type: MsgType::Event,
+                            flags: Flags { mcu_origin: true, ..Default::default() },
+                            ttl: 2,
+                            k: 1,
+                            msg_id: 0,
+                            event_hash: IDENTIFY_HASH,
+                            payload_len: 1,
+                            target_group: my_tg_hash,
+                            target_hive: target,
+                        };
+                        let m = ExtendedMessage { header: hdr, route: None, payload: &payload, hmac_tag: None };
+                        let mut txb = [0u8; 64];
+                        if let Ok(sz) = encode_extended(&m, &mut txb) {
+                            let _ = socket.send_to(&txb[..sz], bcast).await;
+                        }
+                        println!("r2-dfr1195: IDENTIFY-inject target={target:08x} on={on}");
+                    }
+                    } // end !is_provision
+                    n = 0;
+                }
+            } else if n < line.len() {
+                line[n] = c;
+                n += 1;
+            }
+        } else {
+            Timer::after(Duration::from_millis(20)).await;
+        }
+    }
+}
+
+/// Parse "IDENTIFY <wire_hex> <1|0>" → (target_hive, on).
+fn parse_identify(s: &[u8]) -> Option<(u32, bool)> {
+    let s = core::str::from_utf8(s).ok()?;
+    let mut it = s.split_ascii_whitespace();
+    if it.next()? != "IDENTIFY" {
+        return None;
+    }
+    let target = u32::from_str_radix(it.next()?, 16).ok()?;
+    let on = it.next()? != "0";
+    Some((target, on))
+}
+
+/// Parse a colon-hex MAC "aa:bb:cc:dd:ee:ff" → [u8;6] (routetest topology MASK).
+#[cfg(feature = "routetest")]
+fn parse_mac(tok: &str) -> Option<[u8; 6]> {
+    let mut mac = [0u8; 6];
+    let mut parts = tok.split(':');
+    for b in mac.iter_mut() {
+        *b = u8::from_str_radix(parts.next()?, 16).ok()?;
+    }
+    if parts.next().is_some() {
+        return None; // too many octets
+    }
+    Some(mac)
+}
