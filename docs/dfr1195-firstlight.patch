+/// WiFi event loop. STA: connect + reconnect on drop. AP: already up; observe joins.
+#[embassy_executor::task]
+async fn wifi_task(mut controller: WifiController<'static>, is_ap: bool) {
+    if is_ap {
+        loop {
+            match controller.wait_for_access_point_connected_event_async().await {
+                Ok(_) => println!("r2-dfr1195: [ap] station joined"),
+                Err(e) => println!("r2-dfr1195: [ap] event err {e:?}"),
+            }
+        }
+    } else {
+        loop {
+            match controller.connect_async().await {
+                Ok(_) => {
+                    println!("r2-dfr1195: [sta] connected to {FIELDLAB_SSID}");
+                    let _ = controller.wait_for_disconnect_async().await;
+                    println!("r2-dfr1195: [sta] disconnected, retrying");
+                }
+                Err(e) => {
+                    println!("r2-dfr1195: [sta] connect failed {e:?}, retry 2s");
+                    Timer::after(Duration::from_secs(2)).await;
+                }
+            }
+        }
     }
