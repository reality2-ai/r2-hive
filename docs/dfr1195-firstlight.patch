--- /dev/null
+++ b/platforms/dfr1195/build.rs
@@ -0,0 +1,8 @@
+//! Capture a firmware BUILD ID into the binary so the LCD can show which build is
+//! running (essential for verifying an OTA actually landed). The build command
+//! exports `R2_BUILD_ID` (e.g. `date +%m%d.%H%M`); absent that, it reads "dev".
+fn main() {
+    println!("cargo:rerun-if-env-changed=R2_BUILD_ID");
+    let id = std::env::var("R2_BUILD_ID").unwrap_or_else(|_| "dev".into());
+    println!("cargo:rustc-env=R2_BUILD_ID={id}");
+}
