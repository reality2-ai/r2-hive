+/// Scan event handler: decode each observed R2-BEACON + resolve its RBID → hive_id.
+#[cfg(feature = "ble")]
+struct R2ScanHandler<'a> {
+    registry: &'a [(u32, [u8; 16])],
+    epoch: u64,
+}
+
+#[cfg(feature = "ble")]
+impl trouble_host::prelude::EventHandler for R2ScanHandler<'_> {
+    fn on_adv_reports(&self, reports: bt_hci::param::LeAdvReportsIter) {
+        use r2_discovery::beacon::{decode_advert, resolve_rbid_windowed};
+        for rep in reports.flatten() {
+            let Some(payload) = ble_find_mfg_ad(rep.data) else { continue };
+            let Ok(b) = decode_advert(payload) else { continue };
+            // ±1 epoch window absorbs clock skew (R2-DISCOVERY §3.3)
+            match resolve_rbid_windowed(&b.rbid, self.registry, self.epoch, 1) {
+                Some(hive) => println!(
+                    "r2-dfr1195: BLE scan -> peer hive={hive:08x} (rbid {:02x}{:02x}..)",
+                    b.rbid[0], b.rbid[1]
+                ),
+                None => println!(
+                    "r2-dfr1195: BLE scan -> R2-BEACON rbid={:02x}{:02x}.. unresolved",
+                    b.rbid[0], b.rbid[1]
+                ),
+            }
+        }
+    }
+}
+
+/// Walk BLE AD structures, return the manufacturer-specific (0xFF) element's data.
+#[cfg(feature = "ble")]
+fn ble_find_mfg_ad(data: &[u8]) -> Option<&[u8]> {
+    let mut i = 0;
+    while i + 1 < data.len() {
+        let len = data[i] as usize;
+        if len == 0 || i + 1 + len > data.len() {
+            break;
+        }
+        if data[i + 1] == 0xFF {
+            return Some(&data[i + 2..i + 1 + len]);
+        }
+        i += 1 + len;
+    }
+    None
+}
