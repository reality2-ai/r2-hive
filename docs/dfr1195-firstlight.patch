+use mipidsi::models::ST7735s;
+use mipidsi::options::{ColorInversion, Orientation, Rotation};
+use mipidsi::Builder;
+
+/// Live state shared from io_task → the LCD render loop in main.
+static FIRE_COUNT: AtomicU32 = AtomicU32::new(0);
+static DELIVERED: AtomicU32 = AtomicU32::new(0);
+static BLOCKED: AtomicU32 = AtomicU32::new(0);
+static RELAYED: AtomicU32 = AtomicU32::new(0); // AP L3-relayed frames (STA↔STA forwarding)
+static SYNCED: AtomicBool = AtomicBool::new(false);
+// Dashboard telemetry (composer): mesh neighbour count (join→++ / leave→-- via decay) + the current sync
+// conductor hive (a CHANGE = a reform/re-elect). Published each beat; surfaced on the status serial line.
+static NBRS: AtomicU32 = AtomicU32::new(0);
+static CONDUCTOR: AtomicU32 = AtomicU32::new(0);
+static SPREAD_MS: AtomicU32 = AtomicU32::new(0); // leaderless phase-spread (ms) = convergence tightness (dashboard)
+/// io_task signals a heartbeat FIRE → main renders the organic lub-DUB LED envelope.
+static FIRE_SIGNAL: Signal<CriticalSectionRawMutex, ()> = Signal::new();
+
+// App descriptor — required by espflash 4.4.0 to flash an esp-hal 1.x image.
+esp_bootloader_esp_idf::esp_app_desc!();
+
+const HEAP_SIZE: usize = 96 * 1024; // WiFi needs a larger heap than bare-metal.
+const BUILD_ID: &str = env!("R2_BUILD_ID");
+// Human-readable firmware version — surfaced on the LCD + the status line (Roy reads SCREENS as ground truth;
+// composer parses fw= from telemetry). cfg-correct so each board self-declares its sync model + canon version.
+#[cfg(feature = "ble")]
+const FW_VERSION: &str = "leaderless-0.4";
+#[cfg(not(feature = "ble"))]
+const FW_VERSION: &str = "conductor-0.3";
+const FIELDLAB_SSID: &str = "r2-fieldlab";
+const FIELDLAB_PASS: &str = "r2fieldlab"; // >=8 chars (WPA2)
+const AP_MAC_MATCH: u32 = 0x0050_2698; // low-3 MAC bytes selecting the soft-AP role
+const TG_ID: &str = "DEMO"; // demo-fallback TG label when no persona is provisioned
+// Intra-TG trust (demo): both boards share the TG id + group HMAC key = one TG.
+// CANON (R2-WIRE §6.2.1 / R2-TRUST §2.3, core 5f8798b): target_group = FNV-1a-32 of
+// the trust_group_id UUID STRING (NOT of the TG pubkey). Demo uses a fixed TG UUID
+// string; the real one is self-generated at first boot + HKDF-scoped. The wire
+// encoding (FNV-1a-32 of the string) is unchanged when master-secret provisioning
+// lands, so this is a drop-in. `hk` is the shared group HMAC key (from the join
+// protocol; hardcoded stand-in here).
+const TG_UUID: &str = "r2tg-demo-0000-0000-0000-000000000001";
+const MY_TG_HASH: u32 = r2_fnv::fnv1a_32(TG_UUID.as_bytes()); // frame target_group
+const TG_HK_DEMO: [u8; 32] = [0x5C; 32]; // shared intra-TG group HMAC key (hk)
+/// Firmware version tag for telemetry (#18) — FNV of the build id, carried in the heartbeat.
+const VERSION_FNV: u32 = r2_fnv::fnv1a_32(BUILD_ID.as_bytes());
+
+#[esp_rtos::main]
+async fn main(spawner: Spawner) -> ! {
+    // 1. esp-hal init — WiFi needs >= 80 MHz; use max.
+    let p = esp_hal::init(esp_hal::Config::default().with_cpu_clock(CpuClock::max()));
+    esp_alloc::heap_allocator!(size: HEAP_SIZE);
+
+    // 1a. OTA test (b) — otadata slot-switch validation (#17), BEFORE the radio (the
+    //     flash op can't collide with WiFi). One-shot + safe: if a VALID image (0xE9
+    //     magic) sits in the INACTIVE slot AND we booted from ota_0, activate it +
+    //     reboot. When we come back booted from ota_1 (next slot = ota_0), the ESP-IDF
+    //     BL's otadata slot-switch + activate_next_partition() are PROVEN. No flip if
+    //     the next slot is empty (no boot-loop) — this is the receiver's COMMIT path.
+    ota_slot_report();
+
+    // 1b. Read identity + the provisioned PERSONA (#20) BEFORE the radio starts, so the
+    //     efuse/flash reads can't collide with WiFi. Real TG (hk/tg/hive) if a persona is
+    //     present at 0x12000; else fall back to the demo TG.
+    let mac_low3 = esp_hal::efuse::read_field_le::<u32>(esp_hal::efuse::MAC0) & 0x00FF_FFFF;
+    let persona = read_persona();
+    #[allow(unused_mut)]
+    let (mut hk, mut my_tg_hash, my_hive, tg_label) = match &persona {
+        Some(p) => (p.hk, p.tg_hash, p.hive_id, p.tg_label.as_str()),
+        None => (TG_HK_DEMO, MY_TG_HASH, mac_low3, TG_ID),
+    };
+    // 2-TG (#20): a runtime-PROVISIONED key (NVS @0x14000) OVERRIDES the persona/demo TG. my_hive
+    // (the wire id) is unchanged — provisioning swaps the TRUST GROUP, not the board identity. The
+    // io_task picks up later re-PROVISIONs live via PENDING_PROVISION; this is the boot-time restore.
+    #[cfg(feature = "multitg")]
+    if let Some((tg_id, key)) = read_provisioned_tg() {
+        hk = key;
+        my_tg_hash = tg_id;
+        println!("r2-dfr1195: PROVISIONED TG restored from NVS — tg_id={tg_id} (overrides persona/demo)");
+    }
+    let is_ap = mac_low3 == AP_MAC_MATCH; // soft-AP role stays MAC-based
+    let (has_screen, led_active_low) = read_board_profile(); // DFR1195 vs XIAO-S3 (LED polarity)
+    // BL-200 routetest: restore the persisted topology MASK BEFORE the radio starts, so can_hear is armed
+    // from boot (survives the capture's serial-open DTR-reset that clears the RAM-only list).
+    #[cfg(feature = "routetest")]
+    if let Some(macs) = read_mask_nvs() {
+        set_mask(&macs);
+        println!("r2-dfr1195: MASK restored from NVS — {} allowed neighbours", macs.len());
+    }
+    #[cfg(feature = "routetest")]
+    if let Some(dest) = read_dest_nvs() {
+        ROUTETEST_DEST.store(dest, Ordering::Relaxed);
+        println!("r2-dfr1195: SENDTO restored from NVS — origin -> {dest:08x}");
+    }
+
+    // 2. Start the esp-rtos scheduler (required before esp-radio). TimerSource = TIMG0.
