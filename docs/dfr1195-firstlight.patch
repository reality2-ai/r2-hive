-//! r2-dfr1195 — Path B no_std firmware entry (esp-hal/embassy) for the
-//! DFRobot DFR1195 (FireBeetle 2 ESP32-S3) + SX1262 LoRa.
+//! r2-dfr1195 — Path B no_std firmware (esp-rtos/embassy) for the DFRobot DFR1195
+//! (LoRaWAN ESP32-S3).
 //!
-//! AUTHOR-ONLY skeleton (core-expert authors; hive validates on hardware).
-//! The R2 seam (transport bindings + host-centralised peer resolution) is the
-//! rigorous part; the esp-hal/esp-wifi/embassy init below is written against
-//! the Cargo.toml-pinned versions and marked `HIVE:` where the board-specific
-//! wiring must be confirmed against the installed toolchain.
-//!
-//! ## What this firmware does (target behaviour)
-//! 1. Bring up the ESP32-S3: clocks, heap, embassy time driver.
-//! 2. Join WiFi (STA) → embassy-net stack → bind the R2 UDP port.
-//! 3. Bring up BLE (esp-wifi controller + trouble-host) for R2-BEACON
-//!    discovery + R2-BLE frame transport.
-//! 4. Bring up the SX1262 over SPI behind composer's chip-agnostic radio
-//!    trait (R2-LORA) — generic, see `lora.rs`.
-//! 5. Run the r2-route engine over the three `Transport` bindings; the host
-//!    map resolves hive ids → per-medium addresses (R2-DISCOVERY §5).
-//!
-//! First hardware milestone (per the D3b plan): laptop ⇄ DFR1195 over WiFi-UDP.
+//! **PHASE 1a — WiFi-up smoke (field.lab bring-up).** Migrates from the bare-metal
+//! first-light to the esp-rtos/embassy async runtime and brings WiFi up via esp-radio
+//! (the renamed esp-wifi for the esp-hal 1.1.x line). One image, role auto-selected
+//! by MAC: device 0x502698 = soft-AP `r2-fieldlab` (192.168.4.1), else STA that joins
+//! it (192.168.4.2). STATIC IPs both sides (embassy-net 0.9 has no DHCP *server*) — a
+//! deterministic 2-node IP network for the board↔board TN test. A non-blocking LED
+//! heartbeat keeps the board visibly alive. The LCD proof surface (with WiFi role/IP)
+//! + the WifiTransport/RouteEngine wiring come next (Phase 1b/2).
 
 #![no_std]
 #![no_main]
 
 extern crate alloc;
 
-mod ble;
-mod lora;
-mod peers;
-mod wifi;
+use core::fmt::Write as _;
 
+use embassy_executor::Spawner;
+use embassy_futures::select::{select, Either};
+use embassy_net::udp::{PacketMetadata, UdpSocket};
+use embassy_net::{
+    Config, IpAddress, IpEndpoint, Ipv4Address, Ipv4Cidr, Runner, StackResources, StaticConfigV4,
+};
+use embassy_time::{Duration, Timer};
 use esp_backtrace as _;
+use esp_hal::clock::CpuClock;
+use esp_hal::gpio::{Level, Output, OutputConfig};
+use esp_hal::interrupt::software::SoftwareInterruptControl;
+use esp_hal::timer::timg::TimerGroup;
+use esp_radio::wifi::ap::AccessPointConfig;
+use esp_radio::wifi::sta::StationConfig;
+use esp_radio::wifi::{
+    self, AuthenticationMethod, Config as WifiConfig, ControllerConfig, Interfaces, WifiController,
+};
+use esp_println::println;
+use static_cell::StaticCell;
+
+// R2 transient-networking core (no_std, the portable substance — unchanged on metal).
+use r2_cbor::Encoder;
+use r2_route::{
+    DropReason, ForwardAction, ForwardRequest, MobilityClass, Observation, QualitySample,
+    RouteEngine, Target, Transport,
+};
+use r2_trust::GroupHmac;
+use r2_wire::{
+    decode_extended, encode_extended, sign_extended, verify_extended, ExtendedHeader,
+    ExtendedMessage, Flags, MsgType,
+};
+
+// On-device proof-surface LCD (ST7735S) — restored after the WiFi refactor.
+use core::sync::atomic::{AtomicBool, AtomicU32, Ordering};
+use embedded_graphics::mono_font::ascii::FONT_6X10;
+use embedded_graphics::mono_font::MonoTextStyle;
+use embedded_graphics::pixelcolor::Rgb565;
+use embedded_graphics::prelude::*;
+use embedded_graphics::text::Text;
+use embedded_hal_bus::spi::ExclusiveDevice;
+use esp_hal::spi::master::{Config as SpiConfig, Spi};
+use esp_hal::spi::Mode;
+use esp_hal::time::Rate;
+use esp_hal::delay::Delay;
+use esp_hal::gpio::DriveMode;
+// LoRa (#21/#22): the SX1262 driver + its BUSY input + the LoRaRadio trait. cfg-gated so non-lora builds
+// are unchanged. Input/InputConfig for BUSY40; r2_sx1262 = core's concrete driver; the trait for its methods.
+#[cfg(feature = "lora")]
+use esp_hal::gpio::{Input, InputConfig};
+#[cfg(feature = "lora")]
+use r2_sx1262::{wairoa_as923_nz, Sx1262, TcxoVoltage};
+#[cfg(feature = "lora")]
+use r2_transport::lora::{LoRaRadio, RadioEvent};
+use esp_hal::usb_serial_jtag::{UsbSerialJtag, UsbSerialJtagRx};
+use esp_hal::ledc::channel::ChannelIFace;
+use esp_hal::ledc::timer::TimerIFace;
+use esp_hal::ledc::{channel, timer, LSGlobalClkSource, Ledc, LowSpeed};
+use embassy_sync::blocking_mutex::raw::CriticalSectionRawMutex;
+use embassy_sync::signal::Signal;
