+/// Known TG hive_ids (bring-up registry for RBID→hive_id resolution; the real roster comes from
+/// peers.rs / the persona later). KS1-canonical ids of the 9-board TG. (Used by M8 scan/resolve.)
+#[cfg(feature = "ble")]
+#[allow(dead_code)]
+const KNOWN_HIVE_IDS: &[u32] = &[FR4_SENSOR_HIVE, 0x2cab_5f69, FR4_RECV_HIVE, 0x0dca_dbf8];
