+// protocol; hardcoded stand-in here).
+const TG_UUID: &str = "r2tg-demo-0000-0000-0000-000000000001";
+const MY_TG_HASH: u32 = r2_fnv::fnv1a_32(TG_UUID.as_bytes()); // frame target_group
