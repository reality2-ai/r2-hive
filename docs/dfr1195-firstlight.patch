+/// §5 health-gate for confirmed-boot. MINIMAL: reaching this call (booted past esp-hal init + the early
+/// otadata reads) = healthy enough to confirm. A richer self-test (radio init OK, persona valid, …) is a
+/// follow-up; kept a real fn (not a const) so the rollback branch below isn't dead-code-eliminated.
+#[inline(never)]
+fn ota_health_check() -> bool {
+    true
+}
+
+/// R2-UPDATE §5.1 CONFIRMED-BOOT (mirror r2-core esp32 `confirm_or_rollback_on_boot`; items 2+3). A freshly
+/// OTA'd image boots with ota_state ∈ {New, PendingVerify} (OCM staged it `New`; a rollback-enabled
+/// bootloader transitions New→PendingVerify + arms auto-rollback). Run the §5 health-gate: PASS → mark
+/// `Valid` + COMMIT the staged (seq,floor) to the live anti-rollback floor (the AFTER-CONFIRM bump — item 3);
+/// FAIL → mark `Invalid` + roll back to the previous slot + reboot. A normal boot (Valid/Undefined) just
+/// clears any stale pending. Called once at boot, after `ota_slot_report`. (Auto-rollback of a CRASH-ON-BOOT
+/// image that never reaches this gate needs CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE in the staged bootloader.)
+fn ota_confirm_or_rollback_on_boot() {
+    use esp_bootloader_esp_idf::ota::OtaImageState;
+    use esp_bootloader_esp_idf::partitions::PARTITION_TABLE_MAX_LEN;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut tbl = [0u8; PARTITION_TABLE_MAX_LEN];
+    let mut ota = match esp_bootloader_esp_idf::ota_updater::OtaUpdater::new(&mut flash, &mut tbl) {
+        Ok(o) => o,
+        Err(_) => return,
+    };
+    match ota.current_ota_state() {
+        Ok(OtaImageState::New) | Ok(OtaImageState::PendingVerify) => {
+            if ota_health_check() {
+                if ota.set_current_ota_state(OtaImageState::Valid).is_ok() {
+                    // AFTER-CONFIRM: the live floor advances NOW (not at OCM activate).
+                    if let Some((seq, floor)) = read_ota_pending() {
+                        let (cs, cf) = read_anti_rollback();
+                        write_anti_rollback(cs.max(seq), cf.max(floor));
+                        println!("r2-dfr1195: §5.1 OTA CONFIRMED — image Valid; anti-rollback floor committed seq={seq} floor={floor}");
+                    } else {
+                        println!("r2-dfr1195: §5.1 OTA CONFIRMED — image Valid (no staged seq)");
+                    }
+                    clear_ota_pending();
+                }
+            } else {
+                // §5 health FAIL → revert. Mark Invalid + switch boot back to the previous slot + reboot.
+                let _ = ota.set_current_ota_state(OtaImageState::Invalid);
+                let _ = ota.activate_next_partition();
+                clear_ota_pending();
+                println!("r2-dfr1195: §5.1 OTA ROLLBACK — §5 health FAIL; reverting to previous slot + reboot");
+                esp_hal::system::software_reset();
+            }
+        }
+        _ => {
+            // Normal boot (Valid/Undefined/etc.): drop any stale pending so it can't mis-commit later.
+            if read_ota_pending().is_some() {
+                clear_ota_pending();
+            }
+        }
+    }
+}
