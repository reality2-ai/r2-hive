+# ---- OTA confirmed-boot rollback (R2-UPDATE §5/§9.1) ----
+# Required by core's platforms/esp32 ota_tcp::confirm_or_rollback_on_boot(): enables ESP-IDF NATIVE app
+# rollback — a freshly-OTA'd image boots in PENDING_VERIFY and the bootloader rolls it back on the next
+# reset UNLESS the app calls esp_ota_mark_app_valid_cancel_rollback() (the §5 health-gate CONFIRM). Without
+# this flag esp_ota_get_state_partition never reports PENDING_VERIFY and the confirmed-boot SLA is inert.
+CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y
+# CONFIG_BOOTLOADER_APP_ANTI_ROLLBACK (eFuse security_version, R2-UPDATE §9.2) is INTENTIONALLY LEFT OFF:
+# these are the NON-eFuse tier (R2-UPDATE v0.22 §9.2 — MAY collapse security_version into current_seq), and
+# the firmware NVS anti-rollback floor already covers §9.1. Enabling it burns eFuses IRREVERSIBLY, so it is
+# a deliberate per-deployment choice on eFuse-secured hardware, not a default.
+
