+/// Push a resolved scan observation for the engine's poll_scan (called from on_adv_reports).
+#[cfg(feature = "ble")]
+#[allow(dead_code)]
+fn push_scan_obs(hive: u32, provider_capable: bool, power_bits: u8) {
+    SCAN_OBS.lock(|c| {
+        let mut q = c.borrow_mut();
+        if q.is_full() {
+            let _ = q.pop_front();
+        }
+        let _ = q.push_back((hive, provider_capable, power_bits));
+    });
+}
