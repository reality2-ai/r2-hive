+/// Followers Direct r2.hb.health to the collector over TN; the collector logs it as hex
+/// for composer's orchestrator serial-reader (the AP↔tuxedo USB uplink feeds the dashboard).
+const HEALTH_HASH: u32 = r2_fnv::fnv1a_32(b"r2.hb.health");
+const R2_COLLECTOR_HIVE: u32 = 0x480e_900e; // AP board KS1-canonical hive_id = collector
