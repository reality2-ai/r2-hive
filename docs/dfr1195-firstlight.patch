+/// IDENTIFY (Roy dashboard locate-a-board): a Directed r2.hb.identify frame (payload[0]=1 on /
+/// 0 off) addressed to a hive_id makes THAT board light its LED SOLID, overriding the lub-dub,
+/// for ~5s (or until an off frame). Set as a 50ms-tick countdown (no clock needed).
+const IDENTIFY_HASH: u32 = r2_fnv::fnv1a_32(b"r2.hb.identify");
+static IDENTIFY_TICKS: AtomicU32 = AtomicU32::new(0); // 50ms LED-loop ticks of SOLID remaining
