+const HEAP_SIZE: usize = 96 * 1024; // WiFi needs a larger heap than bare-metal.
+const BUILD_ID: &str = env!("R2_BUILD_ID");
+const FIELDLAB_SSID: &str = "r2-fieldlab";
+const FIELDLAB_PASS: &str = "r2fieldlab"; // >=8 chars (WPA2)
+const AP_MAC_MATCH: u32 = 0x0050_2698; // low-3 MAC bytes selecting the soft-AP role
+
+#[esp_rtos::main]
+async fn main(spawner: Spawner) -> ! {
+    // 1. esp-hal init — WiFi needs >= 80 MHz; use max.
+    let p = esp_hal::init(esp_hal::Config::default().with_cpu_clock(CpuClock::max()));
+    esp_alloc::heap_allocator!(size: HEAP_SIZE);
+
+    // 2. Start the esp-rtos scheduler (required before esp-radio). TimerSource = TIMG0.
+    let timg0 = TimerGroup::new(p.TIMG0);
+    let sw_int = SoftwareInterruptControl::new(p.SW_INTERRUPT);
+    esp_rtos::start(timg0.timer0, sw_int.software_interrupt0);
+
+    println!("r2-dfr1195: PHASE 1a — esp-rtos/embassy + esp-radio WiFi (build {BUILD_ID})");
+
+    // 3. Role from the low-3 MAC bytes.
+    let mac_low3 = esp_hal::efuse::read_field_le::<u32>(esp_hal::efuse::MAC0) & 0x00FF_FFFF;
+    let is_ap = mac_low3 == AP_MAC_MATCH;
+    println!("r2-dfr1195: DEV {mac_low3:06x} role={}", if is_ap { "SOFT-AP" } else { "STA" });
+
+    // 4. LED heartbeat — non-blocking, keeps the board alive (dimmed PWM returns in 1b).
+    let led = Output::new(p.GPIO21, Level::Low, OutputConfig::default());
+    spawner.spawn(led_task(led).unwrap());
+
+    // 5. WiFi config for the role.
+    let wifi_cfg = if is_ap {
+        WifiConfig::AccessPoint(
+            AccessPointConfig::default()
+                .with_ssid(FIELDLAB_SSID)
+                .with_channel(6)
+                .with_auth_method(AuthenticationMethod::Wpa2Personal)
+                .with_password(FIELDLAB_PASS.into()),
+        )
+    } else {
+        WifiConfig::Station(
+            StationConfig::default()
+                .with_ssid(FIELDLAB_SSID)
+                .with_auth_method(AuthenticationMethod::Wpa2Personal)
+                .with_password(FIELDLAB_PASS.into()),
+        )
+    };
+
+    // 6. Create the WiFi controller + interfaces (this also starts WiFi).
+    let controller_cfg = ControllerConfig::default().with_initial_config(wifi_cfg);
+    let (controller, interfaces): (WifiController<'static>, Interfaces<'static>) =
+        wifi::new(p.WIFI, controller_cfg).expect("wifi::new");
+
+    // 7. Static IPs by role (deterministic 2-node net; no DHCP server needed).
+    let (device, ip) = if is_ap {
+        (interfaces.access_point, Ipv4Address::new(192, 168, 4, 1))
+    } else {
+        (interfaces.station, Ipv4Address::new(192, 168, 4, 2))
+    };
+    let net_config = Config::ipv4_static(StaticConfigV4 {
+        address: Ipv4Cidr::new(ip, 24),
+        gateway: Some(Ipv4Address::new(192, 168, 4, 1)),
+        dns_servers: Default::default(),
+    });
+
+    // 8. embassy-net stack.
+    static RESOURCES: StaticCell<StackResources<4>> = StaticCell::new();
+    let resources = RESOURCES.init(StackResources::new());
+    let seed = 0x0123_4567_89ab_cdef_u64 ^ (mac_low3 as u64);
+    let (stack, runner) = embassy_net::new(device, net_config, resources, seed);
+    spawner.spawn(net_task(runner).unwrap());
+    spawner.spawn(wifi_task(controller, is_ap).unwrap());
 
