+/// Build the #18 r2.hb.health CBOR (int-keyed map, composer's contract) into `buf`.
+/// Keys: 0 hive_id, 1 tg, 2 role-bitset (1=conductor|2=AP|4=STA|8=relay), 3 ip, 4 fw_version,
+/// 5 fw_sha, 6 ota_status, 7 sync_state, 8 phase_err_ms, 9 link_q, 10 transports, 11 uptime, 12 beat_seq.
+fn build_health(
+    buf: &mut [u8],
+    my_hive: u32,
+    tg: u32,
+    is_ap: bool,
+    conductor: bool,
+    ip: Ipv4Address,
+    synced: bool,
+    phase_err_ms: u32,
+    beat_seq: u32,
+) -> Option<usize> {
+    let role: u64 = (if conductor { 1 } else { 0 }) | (if is_ap { 2 | 8 } else { 4 }); // AP relays (bit3)
+    let o = ip.octets();
+    let mut ip_s: heapless::String<16> = heapless::String::new();
+    let _ = write!(ip_s, "{}.{}.{}.{}", o[0], o[1], o[2], o[3]);
+    let mut sha_s: heapless::String<10> = heapless::String::new();
+    let _ = write!(sha_s, "{VERSION_FNV:08x}");
+    let uptime = embassy_time::Instant::now().as_secs();
+    let mut e = Encoder::new(buf);
+    e.map(15).ok()?;
+    e.uint(0).ok()?; e.uint(my_hive as u64).ok()?;
+    e.uint(1).ok()?; e.uint(tg as u64).ok()?;
+    e.uint(2).ok()?; e.uint(role).ok()?;
+    e.uint(3).ok()?; e.text(&ip_s).ok()?;
+    e.uint(4).ok()?; e.text(BUILD_ID).ok()?;
+    e.uint(5).ok()?; e.text(&sha_s).ok()?;
+    e.uint(6).ok()?; e.uint(0).ok()?; // ota_status=0 (running slot is current)
+    e.uint(7).ok()?; e.uint(if synced { 2 } else { 1 }).ok()?; // sync_state: 2=locked, 1=converging
+    e.uint(8).ok()?; e.uint(phase_err_ms as u64).ok()?;
+    e.uint(9).ok()?; e.uint(0).ok()?; // link_q (RSSI not wired yet)
+    e.uint(10).ok()?; e.uint(1).ok()?; // transports bitset: WiFi
+    e.uint(11).ok()?; e.uint(uptime).ok()?;
+    e.uint(12).ok()?; e.uint(beat_seq as u64).ok()?;
+    // Dashboard dynamics (composer): key13 = current conductor hive (a CHANGE = reform/re-elect),
+    // key14 = neighbor_count (live mesh size — grows on join, shrinks on leave).
+    e.uint(13).ok()?; e.uint(CONDUCTOR.load(Ordering::Relaxed) as u64).ok()?;
+    e.uint(14).ok()?; e.uint(NBRS.load(Ordering::Relaxed) as u64).ok()?;
+    Some(e.len())
+}
+
+/// Log an aggregated/received health CBOR as a hex line for composer's serial-reader.
+fn log_health(cbor: &[u8]) {
+    let mut hx: heapless::String<320> = heapless::String::new();
+    for b in cbor {
+        let _ = write!(hx, "{b:02x}");
+    }
+    println!("r2-dfr1195: HEALTH {hx}");
+}
+
+/// TN-FR msg.* telemetry (composer's mesh-demo live hookup; specs-pinned shape, R2-CBOR compact-int map,
+/// event NAME = discriminator like r2.provision.applied). Emitted as 'r2-dfr1195: <name> <hexcbor>'
+/// (mirrors HEALTH). Correlation key = (id, origin) — the BL-200/(msg_id,origin) canon in telemetry, so a
+/// route-walk is unambiguous even when two origins reuse a msg_id (specs CATCH). k3=origin (None on msg.tx,
+/// where k1 already IS the origin/from). The events: msg.tx{0:id,1:origin,2:to} / msg.rx{0:id,1:at,2:from_hop,
+/// 3:origin} / msg.relay{0:id,1:at,2:next_hop(0=flood),3:origin} / msg.delivered{0:id,1:at,2:dup,3:origin}.
+#[cfg(feature = "routetest")]
+fn emit_msg(name: &str, k0: u32, k1: u32, k2: u32, origin: Option<u32>, transport: Option<u8>) {
+    let mut buf = [0u8; 48];
+    let len = {
+        let mut e = Encoder::new(&mut buf);
+        // keep `n` type-INFERRED to Encoder::map's param (usize) — do NOT pin it (an `as u64` cast here
+        // broke the field/r2-cbor combos where map takes usize).
+        let mut n = 3;
+        if origin.is_some() {
+            n += 1;
+        }
+        if transport.is_some() {
+            n += 1;
+        }
+        if e.map(n).is_err() {
+            return;
+        }
+        let _ = e.uint(0);
+        let _ = e.uint(k0 as u64);
+        let _ = e.uint(1);
+        let _ = e.uint(k1 as u64);
+        let _ = e.uint(2);
+        let _ = e.uint(k2 as u64);
+        if let Some(o) = origin {
+            let _ = e.uint(3);
+            let _ = e.uint(o as u64);
+        }
+        // k4 = per-hop transport ordinal (r2_route::Transport: Ble0/Wifi1/Lora2/Internet3/Usb4/EspNow5/
+        // Udp6 — the SAME 7-bit space as transport_allow_mask, so bench per-link counts map to host mask
+        // semantics). Observability only; never goes on-air.
+        if let Some(t) = transport {
+            let _ = e.uint(4);
+            let _ = e.uint(t as u64);
+        }
+        e.len()
+    };
+    let mut hx: heapless::String<96> = heapless::String::new();
+    for b in &buf[..len] {
+        let _ = write!(hx, "{b:02x}");
+    }
+    println!("r2-dfr1195: {name} {hx}");
+}
