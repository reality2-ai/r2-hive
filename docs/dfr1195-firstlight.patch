+// The runner pushes 'MASK <mac>...' to each board's own tty to shape an arbitrary topology (chain,
+// diamond, …) on the full-mesh RF. Mirrors the hardcoded meshmask but configurable per scenario.
+#[cfg(feature = "routetest")]
+static MASK_LIST: embassy_sync::blocking_mutex::Mutex<
+    CriticalSectionRawMutex,
+    core::cell::RefCell<heapless::Vec<[u8; 6], 8>>,
+> = embassy_sync::blocking_mutex::Mutex::new(core::cell::RefCell::new(heapless::Vec::new()));
+
+/// Set this board's allowed-neighbour MAC list (from a 'MASK' serial command). Empty = hear all.
+#[cfg(feature = "routetest")]
+fn set_mask(macs: &[[u8; 6]]) {
+    MASK_LIST.lock(|c| {
+        let mut v = c.borrow_mut();
+        v.clear();
+        for m in macs.iter().take(8) {
+            let _ = v.push(*m);
+        }
+    });
+    write_mask_nvs(macs); // persist so it survives the capture's serial-open DTR-reset (NVS @0x15000)
+}
+
+// MASK persisted to NVS @0x15000 (own 4KB sector, after provision@0x14000, below ota_0@0x20000) so the
+// topology survives a board reset (the capture's serial-open toggles DTR -> reset -> RAM MASK would clear).
+// Layout: [magic u32 BE]["R2MK"][count u8][count×6 MAC bytes].
+#[cfg(feature = "routetest")]
+const MASK_NVS_OFFSET: u32 = 0x15000;
+#[cfg(feature = "routetest")]
+const MASK_NVS_MAGIC: u32 = 0x5232_4d4b; // "R2MK"
+
+#[cfg(feature = "routetest")]
+fn write_mask_nvs(macs: &[[u8; 6]]) {
+    use embedded_storage::Storage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 64];
+    b[0..4].copy_from_slice(&MASK_NVS_MAGIC.to_be_bytes());
+    let n = macs.len().min(8);
+    b[4] = n as u8;
+    for (i, m) in macs.iter().take(8).enumerate() {
+        b[5 + i * 6..5 + i * 6 + 6].copy_from_slice(m);
+    }
+    let _ = flash.write(MASK_NVS_OFFSET, &b);
+}
+
+// SENDTO (BL-200 origin dest) persisted to NVS @0x16000 — survives the capture DTR-reset like the MASK.
+#[cfg(feature = "routetest")]
+const DEST_NVS_OFFSET: u32 = 0x16000;
+#[cfg(feature = "routetest")]
+const DEST_NVS_MAGIC: u32 = 0x5232_4453; // "R2DS"
+
+#[cfg(feature = "routetest")]
+fn write_dest_nvs(dest: u32) {
+    use embedded_storage::Storage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 8];
+    b[0..4].copy_from_slice(&DEST_NVS_MAGIC.to_be_bytes());
+    b[4..8].copy_from_slice(&dest.to_be_bytes());
+    let _ = flash.write(DEST_NVS_OFFSET, &b);
+}
+
+#[cfg(feature = "routetest")]
+fn read_dest_nvs() -> Option<u32> {
+    use embedded_storage::ReadStorage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 8];
+    flash.read(DEST_NVS_OFFSET, &mut b).ok()?;
+    if u32::from_be_bytes([b[0], b[1], b[2], b[3]]) != DEST_NVS_MAGIC {
+        return None;
+    }
+    Some(u32::from_be_bytes([b[4], b[5], b[6], b[7]]))
+}
+
+/// Restore the persisted MASK at boot (None if unset/erased). Re-arms can_hear before the radio starts.
+#[cfg(feature = "routetest")]
+fn read_mask_nvs() -> Option<heapless::Vec<[u8; 6], 8>> {
+    use embedded_storage::ReadStorage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 64];
+    flash.read(MASK_NVS_OFFSET, &mut b).ok()?;
+    if u32::from_be_bytes([b[0], b[1], b[2], b[3]]) != MASK_NVS_MAGIC {
+        return None;
+    }
+    let n = (b[4] as usize).min(8);
+    let mut v: heapless::Vec<[u8; 6], 8> = heapless::Vec::new();
+    for i in 0..n {
+        let mut m = [0u8; 6];
+        m.copy_from_slice(&b[5 + i * 6..5 + i * 6 + 6]);
+        let _ = v.push(m);
+    }
+    Some(v)
+}
+
+/// True if `src` is in the allow-list (or the list is empty = hear all). The topology gate.
+#[cfg(feature = "routetest")]
+fn mask_allows(src: &[u8; 6]) -> bool {
+    MASK_LIST.lock(|c| {
+        let v = c.borrow();
+        v.is_empty() || v.iter().any(|m| m == src)
+    })
+}
+
+fn can_hear(_my_hive: u32, _src: &[u8; 6]) -> bool {
+    // routetest: the runtime allow-list shapes the topology (set per-scenario via the MASK cmd).
+    #[cfg(feature = "routetest")]
+    {
+        return mask_allows(_src);
+    }
+    // GENERAL no-AP mesh (default): every node hears every in-range peer → self-growing (N-join) +
+    // self-healing (reform). This is the real-world TN case for mobile wearables.
+    #[cfg(all(not(feature = "meshmask"), not(feature = "routetest")))]
+    {
+        true
+    }
+    // BENCH multi-hop mask (meshmask): hide A↔C so A→B→C relay is forced on a bench (no physical range).
+    #[cfg(all(feature = "meshmask", not(feature = "routetest")))]
+    {
+        const A: [u8; 6] = [0xf4, 0x12, 0xfa, 0x50, 0x23, 0xe4]; // 0dcadbf8
+        const B: [u8; 6] = [0xf4, 0x12, 0xfa, 0xb7, 0x90, 0x10]; // 2cab5f69
+        const C: [u8; 6] = [0xf4, 0x12, 0xfa, 0xb6, 0x0a, 0xa0]; // f91c8911
+        match _my_hive {
+            0x0dca_dbf8 => *_src == B,
+            0x2cab_5f69 => *_src == A || *_src == C,
+            0xf91c_8911 => *_src == B,
+            _ => true,
+        }
+    }
+}
+
+/// Upsert a learned hive_id↔MAC pair (M-ESPNOW-2). Returns true if newly mapped (for logging).
+#[cfg(feature = "ble")]
+fn map_peer(hive: u32, mac: [u8; 6]) -> bool {
+    HIVE_MAC.lock(|c| {
+        let mut v = c.borrow_mut();
+        if let Some(e) = v.iter_mut().find(|(h, _)| *h == hive) {
+            e.1 = mac;
+            false
+        } else {
+            let _ = v.push((hive, mac));
+            true
+        }
+    })
+}
+
+/// Reverse lookup: the immediate-sender hive for an L2 src MAC (learned from heartbeats). 0 = unknown
+/// (peer not heartbeated yet). Used to thread src_hive into DATA_RX for the §4.3.4 TrailReinforcer.
+#[cfg(feature = "ble")]
+fn hive_for_mac(mac: &[u8; 6]) -> u32 {
+    HIVE_MAC.lock(|c| {
+        c.borrow()
+            .iter()
+            .find(|(_, m)| m == mac)
+            .map(|(h, _)| *h)
+            .unwrap_or(0)
+    })
+}
