+/// Leaderless reachback-PCO concave Mirollo–Strogatz phase response (R2-HEARTBEAT v0.4 §4.1, ported from
+/// r2-harness firefly::Coupling::ConcaveMs{b:3}). Returns the bidirectional concave nudge factor for a phase
+/// error e ∈ [-0.5, 0.5); the full phase kick is K_phi · w_ij · phase_response(e). Concave (not a linear/
+/// constant kick) is load-bearing: linear clusters for N>2, the concave M&S form provably synchronises for any N.
+fn phase_response(e: f32) -> f32 {
+    // resp = ln(1 + (e^3 − 1)·m) / 3, m = min(2|e|, 1).  e^3 = Euler^3 (precomputed constant), NOT phase err.
+    const EXP3_MINUS_1: f32 = 19.085_537; // e^3 − 1, b = 3
+    let m = (e.abs() * 2.0).min(1.0);
+    let resp = libm::logf(1.0 + EXP3_MINUS_1 * m) / 3.0; // concave ∈ [0,1]
+    0.5 * resp * e.signum()
+}
