+/// ESP-NOW true-mesh data plane (Mode 2) — M-ESPNOW-1: validate broadcast/recv on metal. Every device
+/// peers connectionlessly (no AP); the src MAC on each frame learns the hive_id↔MAC map (core's design).
+/// Broadcasts an R2M probe + logs observed peers. Next: feed r2-route + heartbeat-over-broadcast + unicast.
+#[cfg(all(feature = "ble", not(feature = "blemesh")))]
+#[embassy_executor::task]
+async fn espnow_task(esp_now: esp_radio::esp_now::EspNow<'static>, my_hive: u32) {
+    use embassy_futures::join::join;
+    use esp_radio::esp_now::BROADCAST_ADDRESS;
+    let (manager, mut sender, mut receiver) = esp_now.split();
+    // Pin a FIXED mesh channel so all boards' ESP-NOW radios align WITHOUT an AP (no AP-join to set the
+    // channel). Every mesh node must use the same channel; ch1 is the R2 mesh default.
+    // labrig: RF-ISOLATE the laptop rig — shift ESP-NOW to ch11 (non-overlapping with tuxedo's ch1) so the
+    // laptop bridge+recv stop drowning in the co-located tuxedo rig's ESP-NOW crosstalk (run-1 confound).
+    // staota (#17 RF channel constraint — ONE radio, ONE channel): under staota the WiFi STA associates to the
+    // lab AP (Alfred's router), which DICTATES the radio channel; ESP-NOW MUST follow it (you cannot pin a
+    // different channel without breaking the STA assoc / the mesh). So do NOT set_channel here — ESP-NOW uses the
+    // STA's associated channel; all boards STA-joined to the SAME router share it → the mesh coheres on it.
+    // (METAL-VALIDATE: confirm ESP-NOW broadcast reaches peers on the STA channel once associated.)
+    #[cfg(all(not(feature = "labrig"), not(feature = "staota")))]
+    let _ = manager.set_channel(1);
+    #[cfg(all(feature = "labrig", not(feature = "staota")))]
+    let _ = manager.set_channel(11);
+    #[cfg(feature = "staota")]
+    let _ = &manager; // channel follows the STA association (lab AP) — no pin
+    #[cfg(not(feature = "staota"))]
+    println!("r2-dfr1195: ESP-NOW mesh up (hive {my_hive:08x}) ch1 — heartbeat over ESP-NOW broadcast");
+    #[cfg(feature = "staota")]
+    println!("r2-dfr1195: ESP-NOW mesh up (hive {my_hive:08x}) on STA channel (staota) — heartbeat over ESP-NOW broadcast");
+    // BRIDGE: drain DATA_TX (io_task's conductor beats) → ESP-NOW broadcast; ESP-NOW recv → DATA_RX
+    // (io_task's PROVEN conductor-PLL decodes + syncs). M-ESPNOW-2: learn peer hive↔src-MAC from the recv.
+    let tx = async {
+        loop {
+            let (frame, n) = DATA_TX.receive().await;
+            let _ = sender.send_async(&BROADCAST_ADDRESS, &frame[..n]).await;
+        }
+    };
+    let rx = async {
+        loop {
+            let r = receiver.receive_async().await;
+            let s = r.info.src_address;
+            // BL-100: real per-recv RSSI (dBm) from the WiFi rx control info.
+            #[cfg(feature = "rssicls")]
+            let rssi = r.info.rx_control.rssi;
+            // M-ESPNOW-3b bench allow-list: drop non-neighbour src BEFORE r2-route (shapes the topology).
+            if !can_hear(my_hive, &s) {
+                continue;
+            }
+            let d = r.data();
+            let n = d.len().min(256);
+            let mut f = [0u8; 256];
+            f[..n].copy_from_slice(&d[..n]);
+            // src_hive = immediate-sender hive (reverse-lookup the L2 src MAC; 0 until it heartbeats).
+            let src_hive = hive_for_mac(&s);
+            let _ = DATA_RX.try_send((f, n, src_hive, r2_route::Transport::EspNow as u8)); // → io_task PLL (the sync) + §4.3.4 reinforce
+            // M-ESPNOW-2: learn hive_id↔MAC from the recv — the R2-WIRE Heartbeat payload carries the
+            // originator hive (be32), the L2 src MAC is r.info.src_address. Map for r2-route unicast (M-ESPNOW-3).
+            if let Ok(m) = r2_wire::decode_extended(&d[..n]) {
+                if m.header.msg_type == MsgType::Heartbeat && m.payload.len() >= 4 {
+                    let origin =
+                        u32::from_be_bytes([m.payload[0], m.payload[1], m.payload[2], m.payload[3]]);
+                    // BL-100: record the RSSI sample for this neighbour (rolling σ).
+                    #[cfg(feature = "rssicls")]
+                    rssi_record(origin, rssi);
+                    if map_peer(origin, s) {
+                        println!(
+                            "r2-dfr1195: ESP-NOW peer MAPPED hive={origin:08x} mac={:02x}:{:02x}:{:02x}:{:02x}:{:02x}:{:02x}",
+                            s[0], s[1], s[2], s[3], s[4], s[5]
+                        );
+                    }
+                }
+            }
+        }
+    };
+    join(tx, rx).await;
+}
+
+/// IDENTIFY inject-bridge: read "IDENTIFY <wire_hex> <1|0>" lines off the USB-Serial-JTAG RX
+/// (composer's orchestrator writes them to the chosen board's USB-serial) and broadcast the
+/// r2.hb.identify Directed frame so the target board lights SOLID. Runs on every board (the RX
+/// FIFO is empty unless composer's --identify-port targets it; esp-println keeps the TX FIFO).
+#[embassy_executor::task]
+async fn uart_rx_task(
+    stack: embassy_net::Stack<'static>,
+    my_tg_hash: u32,
+    #[allow(unused_variables)] my_hive: u32,
+    mut usb_rx: UsbSerialJtagRx<'static, esp_hal::Blocking>,
+) {
+    let mut rx_meta = [PacketMetadata::EMPTY; 2];
+    let mut rx_buf = [0u8; 128];
+    let mut tx_meta = [PacketMetadata::EMPTY; 2];
+    let mut tx_buf = [0u8; 128];
+    let mut socket = UdpSocket::new(stack, &mut rx_meta, &mut rx_buf, &mut tx_meta, &mut tx_buf);
+    let _ = socket.bind(R2_IDENTIFY_BRIDGE_PORT);
+    let bcast = IpEndpoint::new(IpAddress::Ipv4(Ipv4Address::new(192, 168, 4, 255)), R2_UDP_PORT);
+    // 128 B: an IDENTIFY line is short, but a PROVISION line is ~94 B ("PROVISION " + 8-hex wire +
+    // decimal tg_id + 64-hex key) — a 64 B buffer truncated the key → BadKeyLength (metal-found).
+    let mut line = [0u8; 160]; // 160B: holds the longest persona-receiver line 'PERSONA <128hex>' (136 chars)
+    let mut n = 0usize;
+    let mut paccum = [0u8; 512]; // #14 console-persona accumulator (chunked PERSONA → ≤512B record)
+    let mut paccum_len = 0usize;
+    loop {
+        if let Ok(c) = usb_rx.read_byte() {
+            if c == b'\n' || c == b'\r' {
+                if n > 0 {
+                    // PROVISION (#20, CROSS-HOST-2TG §6) — same serial inject-bridge as IDENTIFY. Parse +
+                    // validate via core's primitive (do NOT re-implement), persist to NVS, then hand the key
+                    // to io_task (PENDING_PROVISION) to install into the GroupHmac. ACK on serial for composer.
+                    #[cfg(feature = "multitg")]
+                    let is_provision = line[..n].starts_with(b"PROVISION");
+                    #[cfg(not(feature = "multitg"))]
+                    let is_provision = false;
+                    #[cfg(feature = "multitg")]
+                    if is_provision {
+                        match r2_trust::provision::parse_provision(&line[..n], my_hive) {
+                            Ok(Some(cred)) => match write_provisioned_tg(cred.tg_id, &cred.group_hmac_key) {
+                                Ok(()) => {
+                                    PENDING_PROVISION.lock(|c| {
+                                        *c.borrow_mut() = Some((cred.tg_id, cred.group_hmac_key));
+                                    });
+                                    // ACK r2.provision.applied (§6). CBOR {0:wire,1:tg_id} over /r2 is pending
+                                    // specs' canonical key-map pin; serial line is composer's coverage feed now.
+                                    println!(
+                                        "r2-dfr1195: PROVISION-APPLIED wire={my_hive:08x} tg_id={}",
+                                        cred.tg_id
+                                    );
+                                }
+                                Err(()) => println!(
+                                    "r2-dfr1195: PROVISION-ERR wire={my_hive:08x} nvs-write-failed"
+                                ),
+                            },
+                            Ok(None) => {} // not for me (wire != my_hive) — ignore (§6)
+                            Err(e) => {
+                                println!("r2-dfr1195: PROVISION-ERR wire={my_hive:08x} {e:?}")
+                            }
+                        }
+                    }
+                    // routetest: 'MASK <aa:bb:cc:dd:ee:ff> ...' sets THIS board's allowed-neighbour list
+                    // (topology shaping for BL-200/103). Sent to the board's own tty; applies to self.
+                    #[cfg(feature = "routetest")]
+                    let is_mask = line[..n].starts_with(b"MASK ");
+                    #[cfg(not(feature = "routetest"))]
+                    let is_mask = false;
+                    #[cfg(feature = "routetest")]
+                    if is_mask {
+                        let mut macs: heapless::Vec<[u8; 6], 8> = heapless::Vec::new();
+                        if let Ok(s) = core::str::from_utf8(&line[..n]) {
+                            for tok in s.split_ascii_whitespace().skip(1) {
+                                if let Some(mac) = parse_mac(tok) {
+                                    let _ = macs.push(mac);
+                                }
+                            }
+                        }
+                        set_mask(&macs);
+                        println!("r2-dfr1195: MASK-SET allowed_neighbours={}", macs.len());
+                    }
+                    // routetest: 'SENDTO <dest_hex>' makes THIS board the BL-200 origin (A) sending
+                    // directed requests to <dest> (D). 'SENDTO 0' clears it. Self-applied per-tty.
+                    #[cfg(feature = "routetest")]
+                    let is_sendto = line[..n].starts_with(b"SENDTO ");
+                    #[cfg(not(feature = "routetest"))]
+                    let is_sendto = false;
+                    #[cfg(feature = "routetest")]
+                    if is_sendto {
+                        if let Ok(s) = core::str::from_utf8(&line[..n]) {
+                            if let Some(tok) = s.split_ascii_whitespace().nth(1) {
+                                if let Ok(dest) = u32::from_str_radix(tok, 16) {
+                                    ROUTETEST_DEST.store(dest, Ordering::Relaxed);
+                                    write_dest_nvs(dest); // persist so origin survives the capture DTR-reset
+                                    println!("r2-dfr1195: SENDTO-SET dest={dest:08x} (this board = BL-200 origin)");
+                                }
+                            }
+                        }
+                    }
+                    // Console persona-receiver (#14): PERSONA/RPF1/BOARDPROF/REBOOT = REMOTE provisioning, NO
+                    // download mode. handle_persona_cmd validates + stores to the whitelisted offsets + ACKs.
+                    let is_persona = line[..n].starts_with(b"PERSONA")
+                        || line[..n].starts_with(b"RPF1 ")
+                        || line[..n].starts_with(b"BOARDPROF ")
+                        || line[..n].starts_with(b"REBOOT");
+                    if is_persona && handle_persona_cmd(&line[..n], &mut paccum, &mut paccum_len) {
+                        esp_hal::system::software_reset();
+                    }
+                    if !is_provision && !is_mask && !is_sendto && !is_persona {
+                    if let Some((target, on)) = parse_identify(&line[..n]) {
+                        let payload = [u8::from(on)];
+                        let hdr = ExtendedHeader {
+                            version: 0,
+                            msg_type: MsgType::Event,
+                            flags: Flags { mcu_origin: true, ..Default::default() },
+                            ttl: 2,
+                            k: 1,
+                            msg_id: 0,
+                            event_hash: IDENTIFY_HASH,
+                            payload_len: 1,
+                            target_group: my_tg_hash,
+                            target_hive: target,
+                        };
+                        let m = ExtendedMessage { header: hdr, route: None, payload: &payload, hmac_tag: None };
+                        let mut txb = [0u8; 64];
+                        if let Ok(sz) = encode_extended(&m, &mut txb) {
+                            let _ = socket.send_to(&txb[..sz], bcast).await;
+                        }
+                        println!("r2-dfr1195: IDENTIFY-inject target={target:08x} on={on}");
+                    }
+                    } // end !is_provision
+                    n = 0;
+                }
+            } else if n < line.len() {
+                line[n] = c;
+                n += 1;
+            }
+        } else {
+            Timer::after(Duration::from_millis(20)).await;
+        }
+    }
+}
+
+/// Parse "IDENTIFY <wire_hex> <1|0>" → (target_hive, on).
+fn parse_identify(s: &[u8]) -> Option<(u32, bool)> {
+    let s = core::str::from_utf8(s).ok()?;
+    let mut it = s.split_ascii_whitespace();
+    if it.next()? != "IDENTIFY" {
+        return None;
+    }
+    let target = u32::from_str_radix(it.next()?, 16).ok()?;
+    let on = it.next()? != "0";
+    Some((target, on))
+}
+
+/// Parse a colon-hex MAC "aa:bb:cc:dd:ee:ff" → [u8;6] (routetest topology MASK).
+#[cfg(feature = "routetest")]
+fn parse_mac(tok: &str) -> Option<[u8; 6]> {
+    let mut mac = [0u8; 6];
+    let mut parts = tok.split(':');
+    for b in mac.iter_mut() {
+        *b = u8::from_str_radix(parts.next()?, 16).ok()?;
+    }
+    if parts.next().is_some() {
+        return None; // too many octets
+    }
+    Some(mac)
+}
+
+/// OTA network receiver (#17) — FLASH-WRITE-WHILE-WIFI DE-RISK (esp-storage#31).
+/// The slot-switch/commit path is already proven (test b). The open hardware question is
+/// whether an esp-storage flash write (cache-suspend) RETURNS PROMPTLY with esp-radio
+/// running, or hangs/browns-out. Self-triggered ~15 s after boot (mesh synced, WiFi
+/// active): erase+write one 4 KB sector to the INACTIVE OTA slot (harmless — not booted)
+/// and report the elapsed time. A printed "wtest write_ok=.. Nms" = per-chunk streaming is
+/// viable; a hang (no line, heartbeat stops) = the radio must be quiesced around the burst.
+/// Board-to-board auto-OTA push is TEST scaffolding only — OFF for the live mesh so the
+/// AP behaves as a normal soft-AP/conductor candidate. The receiver stays active on STAs;
+/// real OTA pushes come from the orchestrator over the same START/DATA/COMMIT protocol.
+const OTA_SELFTEST: bool = false;
+
+// SECURITY (codex A7/A8 finding b — mirrors core's linux ota_tcp_recv + esp32 ota_tcp): the
+// `dev-unsigned-ota` feature accepts UNAUTHENTICATED firmware (sha256 = integrity only, NOT authenticity)
+// = remote code execution. It is DEV-ONLY and MUST NOT ship in a release build. A release build (NOT
+// debug_assertions) with the feature enabled FAILS TO COMPILE — the default OTA path is CMD_START_SIGNED
+// (verify-before-write). (On the DFR the legacy unsigned path is additionally absent from the production
+// build entirely; this guard is the belt-and-braces mirror of core's, so the fleet's guard is uniform.)
+#[cfg(all(feature = "dev-unsigned-ota", not(debug_assertions)))]
+compile_error!(
+    "dev-unsigned-ota is DEV-ONLY (it accepts unauthenticated firmware = RCE) and MUST NOT be enabled in \
+     a release build — use the default CMD_START_SIGNED (0x03) verify-before-write OTA path instead"
+);
+
+#[embassy_executor::task]
+async fn ota_task(is_ap: bool, stack: embassy_net::Stack<'static>) {
+    Timer::after(Duration::from_secs(12)).await; // let WiFi + the mesh settle
+    if is_ap {
+        if OTA_SELFTEST {
+            ota_sender(stack).await; // TEST: one-shot board-to-board push
+        }
+    } else {
+        ota_receiver(stack).await; // the deliverable: accept a streamed network OTA
+    }
+}
+
+/// OTA network receiver (#17). Streams an image over UDP into the INACTIVE OTA slot and,
+/// on a SHA-256-verified COMMIT, activates it + reboots — the no-USB update path. The
+/// flash writes run with WiFi up (de-risked: ~20ms/sector, heartbeat-safe), so no quiesce.
+/// Protocol (stop-and-wait): OST<total:4><sha:32> -> OAK; ODT<off:4><payload> -> OAK<written:4>;
+/// OCM -> verify -> ODN + activate + reboot (or OER).
+/// OTA anti-rollback NVS slot — 8 bytes LE: seq[0..4] || authority_epoch_floor[4..8] (core's
+/// anti_rollback.bin format, byte-identical). Raw-flash region in the partition gap (its own 4 KB
+/// sector, like provisioned-TG @0x14000), so it survives an app-reflash. Bumped (monotonic, max())
+/// only on a successful verify-and-finish.
+///
+/// A7/A8 triage (a): this is a FIXED flash sector, NOT a relative/cwd `anti_rollback.bin` file (that path
+/// concern is the linux-host receiver's, N/A here) — so the floor is anchored. FIXED a latent COLLISION:
+/// this was @0x15000, the SAME sector as MASK_NVS_OFFSET — and since `loraroute` implies `routetest`
+/// (which uses the mask), the FIELD build aliased the rollback floor onto the mask sector (a mask write
+/// would corrupt the security_version floor, and vice versa). Moved to its own 0x18000 sector (still below
+/// ota_0@0x20000). A board carrying an old 0x15000 floor restarts at 0 here — acceptable pre-deployment.
+const ANTI_ROLLBACK_OFFSET: u32 = 0x18000;
+fn read_anti_rollback() -> (u32, u32) {
+    use embedded_storage::ReadStorage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 8];
+    if flash.read(ANTI_ROLLBACK_OFFSET, &mut b).is_err() {
+        return (0, 0);
+    }
+    let z = |v: u32| if v == u32::MAX { 0 } else { v }; // 0xFFFFFFFF = erased flash -> 0 (no floor yet)
+    (
+        z(u32::from_le_bytes([b[0], b[1], b[2], b[3]])),
+        z(u32::from_le_bytes([b[4], b[5], b[6], b[7]])),
+    )
+}
+fn write_anti_rollback(seq: u32, floor: u32) {
+    use embedded_storage::Storage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 8];
+    b[0..4].copy_from_slice(&seq.to_le_bytes());
+    b[4..8].copy_from_slice(&floor.to_le_bytes());
+    let _ = flash.write(ANTI_ROLLBACK_OFFSET, &b); // esp-storage erases+writes the 4 KB sector
+}
+
+// R2-UPDATE §5.1 AFTER-CONFIRM — the (seq,floor) STAGED at OTA-commit (OCM), committed to the live
+// anti-rollback floor ONLY at confirmed-boot (items 2+3). Own 4 KB sector @0x1A000 (after the reserved
+// CCR1@0x19000, below ota_0@0x20000). Layout: [magic "OPND" u32 BE][seq u32 LE][floor u32 LE] = 12 B.
+const OTA_PENDING_OFFSET: u32 = 0x1A000;
+const OTA_PENDING_MAGIC: u32 = 0x4F504E44; // "OPND"
+fn read_ota_pending() -> Option<(u32, u32)> {
+    use embedded_storage::ReadStorage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 12];
+    flash.read(OTA_PENDING_OFFSET, &mut b).ok()?;
+    if u32::from_be_bytes([b[0], b[1], b[2], b[3]]) != OTA_PENDING_MAGIC {
+        return None; // erased/absent
+    }
+    Some((
+        u32::from_le_bytes([b[4], b[5], b[6], b[7]]),
+        u32::from_le_bytes([b[8], b[9], b[10], b[11]]),
+    ))
+}
+fn write_ota_pending(seq: u32, floor: u32) {
+    use embedded_storage::Storage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut b = [0u8; 12];
+    b[0..4].copy_from_slice(&OTA_PENDING_MAGIC.to_be_bytes());
+    b[4..8].copy_from_slice(&seq.to_le_bytes());
+    b[8..12].copy_from_slice(&floor.to_le_bytes());
+    let _ = flash.write(OTA_PENDING_OFFSET, &b);
+}
+fn clear_ota_pending() {
+    use embedded_storage::Storage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let b = [0xFFu8; 12]; // erased magic → read_ota_pending() returns None
+    let _ = flash.write(OTA_PENDING_OFFSET, &b);
+}
+
+/// SIGNED OTA receiver (A7/A8 contract, R2-UPDATE v0.6) — verify-BEFORE-write, byte-identical verify
+/// path with core's linux/esp32. Frame (over the existing UDP stop-and-wait carrier): "OST" || 123-byte
+/// UpdateHeader || 64-byte Ed25519 sig (verify_header up front) ; "ODT"<off:4><chunk> (pv.update? THEN
+/// write to the INACTIVE slot) ; "OCM" (pv.finish? BEFORE activate). No byte boots until finish() is Ok.
+/// RESP_OK=0x00 / RESP_ERR=0x01+reject_reason. The legacy UNSIGNED sha-on-commit path is REMOVED from the
+/// production build (the strongest dev-unsigned-OFF: not even present); re-add behind dev-unsigned-ota if
+/// the bench ota_sender needs it. (TRANSPORT NOTE: core's contract is TCP-streamed; this carries the SAME
+/// signed-frame + verify contract over the DFR's UDP stop-and-wait — a TCP swap is the byte-identical-
+/// transport follow-up. SCOPE-1: tg_pk-direct + empty certs/G-Set; target gates 0 = broadcast updates,
+/// full per-device target-gating lands with #20 provisioning.)
+async fn ota_receiver(stack: embassy_net::Stack<'static>) {
+    use embedded_storage::Storage;
+    use r2_update::{reject_reason, verify_header, DeviceContext, PayloadVerifier, HEADER_LEN};
+    let mut rx_meta = [PacketMetadata::EMPTY; 8];
+    let mut rx_buf = [0u8; 2048];
+    let mut tx_meta = [PacketMetadata::EMPTY; 4];
+    let mut tx_buf = [0u8; 256];
+    let mut socket = UdpSocket::new(stack, &mut rx_meta, &mut rx_buf, &mut tx_meta, &mut tx_buf);
+    socket.bind(R2_OTA_PORT).expect("bind OTA port");
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut tbl = [0u8; esp_bootloader_esp_idf::partitions::PARTITION_TABLE_MAX_LEN];
+    let mut ota = match esp_bootloader_esp_idf::ota_updater::OtaUpdater::new(&mut flash, &mut tbl) {
+        Ok(o) => o,
+        Err(_) => return,
+    };
+    let mut region = None;
+    let mut pv: Option<PayloadVerifier> = None; // None until verify_header accepts -> verify-before-write
+    let mut pend_seq = 0u32;
+    let mut pend_floor = 0u32;
+    let mut written = 0u32;
+    let mut payload_size = 0u32; // R3: declared total payload (vh.payload_len) — bounds + completeness gate
+    let mut session_from = None; // R4: in-flight reassembly is BOUND to the OST sender's addr
+    let mut secbuf = [0u8; 4096];
+    let mut secfill = 0usize;
+    let mut secbase = 0u32;
+    let mut pkt = [0u8; 1500];
+    // R2 (datagram-binding §4a, specs-verified): a stalled OTA session MUST NOT wedge the receiver. recv with
+    // an inactivity deadline; on timeout with an in-flight session, abandon it. Safe — the candidate slot is
+    // staged-not-booted, so a dropped transfer just frees the receiver for a fresh OST.
+    const OTA_SESSION_TIMEOUT_S: u64 = 30;
+    loop {
+        let (n, from) = match embassy_time::with_timeout(
+            Duration::from_secs(OTA_SESSION_TIMEOUT_S),
+            socket.recv_from(&mut pkt),
+        )
+        .await
+        {
+            Ok(Ok(v)) => v,
+            Ok(Err(_)) => continue, // socket error
+            Err(_) => {
+                if pv.is_some() || session_from.is_some() {
+                    println!(
+                        "r2-dfr1195: OTA session inactivity-timeout (>{OTA_SESSION_TIMEOUT_S}s) — abandoning stalled transfer"
+                    );
+                    pv = None;
+                    region = None;
+                    written = 0;
+                    secfill = 0;
+                    secbase = 0;
+                    payload_size = 0;
+                    session_from = None;
+                }
+                continue;
+            }
+        };
+        if n < 3 {
+            continue;
+        }
+        match &pkt[0..3] {
+            // SIGNED start: verify the 123-byte header + 64-byte sig BEFORE opening the inactive slot.
+            b"OST" if n >= 3 + HEADER_LEN + 64 => {
+                let header = &pkt[3..3 + HEADER_LEN];
+                let sig = &pkt[3 + HEADER_LEN..3 + HEADER_LEN + 64];
+                let persona = read_persona();
+                let tg_pk = persona.as_ref().map(|p| p.tg_pk).unwrap_or([0u8; 32]);
+                let (cur_seq, floor) = read_anti_rollback();
+                let ctx = DeviceContext {
+                    class_hash: 0,        // §20: per-device target-gating provisioned later (0 = broadcast)
+                    carrier_hash: 0,      //  "
+                    tg_prefix: [0u8; 8],  //  "
+                    device_id_prefix: [0u8; 8],
+                    current_seq: cur_seq,
+                    battery_pct: 100, // mains DFR
+                    tg_pk,
+                    update_authority_certs: &[], // scope-1: TG_SK-direct only
+                    revocation_gset: &[],        // scope-1
+                    authority_epoch_floor: floor,
+                };
+                match verify_header(header, sig, &ctx) {
+                    Ok(vh) => {
+                        pend_seq = vh.seq;
+                        pend_floor = vh.authority_epoch.unwrap_or(0);
+                        pv = Some(PayloadVerifier::new(&vh));
+                        region = ota.next_partition().ok().map(|(r, _)| r);
+                        written = 0;
+                        secfill = 0;
+                        secbase = 0;
+                        // R3: the declared total — every ODT chunk must fit inside it and OCM only commits when
+                        // the cumulative written == this. R4: (re)bind the reassembly to THIS sender; a fresh
+                        // authenticated OST re-binds, but no ODT/OCM from any other addr can touch this session.
+                        payload_size = vh.payload_len as u32;
+                        session_from = Some(from);
+                        println!("r2-dfr1195: OTA SIGNED start seq={} payload_size={}", vh.seq, payload_size);
+                        let _ = socket.send_to(&[r2_update::RESP_OK], from).await;
+                    }
+                    Err(e) => {
+                        pv = None;
+                        region = None;
+                        payload_size = 0;
+                        session_from = None;
+                        println!("r2-dfr1195: OTA verify REJECT reason={}", reject_reason(e));
+                        let _ = socket.send_to(&[r2_update::RESP_ERR, reject_reason(e)], from).await;
+                    }
+                }
+            }
+            // SIGNED data: pv.update(chunk)? BEFORE the slot write — a corrupt/forged chunk -> reject + discard.
+            b"ODT" if n >= 7 => {
+                // R4: a chunk is accepted ONLY from the addr that opened the session. A foreign ODT (no
+                // matching authenticated OST) is dropped SILENTLY — no ack, no state, no reply to leak to.
+                if session_from != Some(from) {
+                    continue;
+                }
+                let off = u32::from_be_bytes([pkt[3], pkt[4], pkt[5], pkt[6]]);
+                let chunk_len = (n - 7) as u32;
+                // R3: the chunk MUST fit inside the declared payload — off and off+len bounded by payload_size.
+                // An over-long or out-of-bounds frame is a malformed/forged transfer: reject + tear the session
+                // down (no partial slot write past the declared image).
+                if off.saturating_add(chunk_len) > payload_size {
+                    pv = None;
+                    region = None;
+                    written = 0;
+                    secfill = 0;
+                    secbase = 0;
+                    payload_size = 0;
+                    session_from = None;
+                    println!("r2-dfr1195: OTA ODT REJECT — frame past declared payload (off+{chunk_len} > {payload_size})");
+                    let _ = socket.send_to(&[r2_update::RESP_ERR, 0x0E], from).await; // 0x0E = framing out-of-bounds
+                    continue;
+                }
+                if off == written {
+                    let chunk_ok = pv.as_mut().is_some_and(|v| v.update(&pkt[7..n]).is_ok());
+                    if !chunk_ok {
+                        pv = None;
+                        region = None;
+                        let _ = socket
+                            .send_to(&[r2_update::RESP_ERR, reject_reason(r2_update::VerifyError::PayloadHashMismatch)], from)
+                            .await;
+                        continue;
+                    }
+                    if let Some(r) = region.as_mut() {
+                        let mut p = &pkt[7..n];
+                        while !p.is_empty() {
+                            let take = core::cmp::min(4096 - secfill, p.len());
+                            secbuf[secfill..secfill + take].copy_from_slice(&p[..take]);
+                            secfill += take;
+                            p = &p[take..];
+                            if secfill == 4096 {
+                                let _ = r.write(secbase, &secbuf);
+                                secbase += 4096;
+                                secfill = 0;
+                            }
+                        }
+                        written += (n - 7) as u32;
+                    }
+                }
+                let mut ack = *b"OAK\0\0\0\0";
+                ack[3..7].copy_from_slice(&written.to_be_bytes());
+                let _ = socket.send_to(&ack, from).await;
+            }
+            // SIGNED commit: flush the slot, then pv.finish()? (payload hash) BEFORE set_boot. Bump the
+            // anti-rollback floor (monotonic) only on a successful finish. No byte boots until finish() Ok.
+            b"OCM" => {
+                // R4: only the session owner may commit.
+                if session_from != Some(from) {
+                    continue;
+                }
+                // R3: commit ONLY when the cumulative bytes equal the declared payload. A short/incomplete
+                // transfer must never reach activate — tear it down so the candidate slot is never booted.
+                // (pv.finish() also catches this via the payload hash, but the framing gate is the MUST.)
+                if written != payload_size {
+                    let got = written;
+                    let want = payload_size;
+                    pv = None;
+                    region = None;
+                    written = 0;
+                    secfill = 0;
+                    secbase = 0;
+                    payload_size = 0;
+                    session_from = None;
+                    println!("r2-dfr1195: OTA OCM REJECT — incomplete ({got} != declared {want})");
+                    let _ = socket.send_to(&[r2_update::RESP_ERR, 0x0E], from).await; // 0x0E = framing/incomplete
+                    continue;
+                }
+                if let Some(r) = region.as_mut() {
+                    if secfill > 0 {
+                        let _ = r.write(secbase, &secbuf[..secfill]);
+                    }
+                }
+                let finish_ok = pv.take().is_some_and(|v| v.finish().is_ok());
+                if finish_ok {
+                    region = None; // drop the FlashRegion borrow before activate
+                    // verify + payload-hash BOTH passed -> activate the inactive slot (atomic set_boot).
+                    if ota.activate_next_partition().is_ok() {
+                        // R2-UPDATE §5.1 AFTER-CONFIRM (items 2+3): STAGE, don't commit. Mark the just-
+                        // activated slot `New` (esp-idf set_boot semantics → a rollback-enabled bootloader
+                        // transitions New→PendingVerify on boot + arms auto-rollback) and persist the
+                        // (seq,floor) to the OTA-pending slot. The live anti-rollback floor is advanced ONLY
+                        // at confirmed-boot (ota_confirm_or_rollback_on_boot), after the new image boots +
+                        // passes the §5 health-gate — so a bad/failed image can't raise the floor and brick
+                        // rollback. A failed install never reaches here, so the same seq can be re-sent.
+                        let _ = ota.set_current_ota_state(
+                            esp_bootloader_esp_idf::ota::OtaImageState::New,
+                        );
+                        write_ota_pending(pend_seq, pend_floor);
+                        let _ = socket.send_to(&[r2_update::RESP_OK], from).await;
+                        println!("r2-dfr1195: OTA SIGNED staged seq={pend_seq} (New/PendingVerify; floor commits at confirmed-boot)");
+                        Timer::after(Duration::from_millis(300)).await;
+                        esp_hal::system::software_reset();
+                    } else {
+                        // POST-VERIFY install failure (reject byte 0x0D, core db75932): both gates PASSED but the
+                        // slot activate failed — the running image is UNCHANGED (atomic), NO rollback-floor bump.
+                        println!("r2-dfr1195: OTA install FAIL post-verify (0x0D)");
+                        let _ = socket.send_to(&[r2_update::RESP_ERR, 0x0D], from).await;
+                    }
+                } else {
+                    region = None;
+                    println!("r2-dfr1195: OTA finish REJECT (payload hash)");
+                    let _ = socket
+                        .send_to(&[r2_update::RESP_ERR, reject_reason(r2_update::VerifyError::PayloadHashMismatch)], from)
+                        .await;
+                }
+            }
+            _ => {}
+        }
+    }
+}
