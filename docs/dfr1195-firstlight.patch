+/// R2 mesh UDP port (R2-WIFI §4).
+const R2_UDP_PORT: u16 = 21042;
+/// OTA network-receiver port (#17): START/DATA/COMMIT image transfer.
+const R2_OTA_PORT: u16 = 21043;
+/// IDENTIFY inject-bridge port: a board reads "IDENTIFY <wire_hex> <1|0>" from its USB-serial
+/// (composer's orchestrator writes it) + broadcasts the r2.hb.identify Directed frame.
+const R2_IDENTIFY_BRIDGE_PORT: u16 = 21045;
+
+/// #18 health telemetry: event_hash discriminator + the collector (AP) wire hive_id.
+/// Followers Direct r2.hb.health to the collector over TN; the collector logs it as hex
+/// for composer's orchestrator serial-reader (the AP↔tuxedo USB uplink feeds the dashboard).
+const HEALTH_HASH: u32 = r2_fnv::fnv1a_32(b"r2.hb.health");
+const R2_COLLECTOR_HIVE: u32 = 0x480e_900e; // AP board KS1-canonical hive_id = collector
+
+/// IDENTIFY (Roy dashboard locate-a-board): a Directed r2.hb.identify frame (payload[0]=1 on /
+/// 0 off) addressed to a hive_id makes THAT board light its LED SOLID, overriding the lub-dub,
+/// for ~5s (or until an off frame). Set as a 50ms-tick countdown (no clock needed).
+const IDENTIFY_HASH: u32 = r2_fnv::fnv1a_32(b"r2.hb.identify");
+// BL-200 routetest: event_hash discriminator for distributed-trail request/reply Events (so the
+// §4.3.4 reinforcer acts ONLY on them, not health/identify/trust-demo Events).
+#[cfg(feature = "routetest")]
+const ROUTETEST_HASH: u32 = r2_fnv::fnv1a_32(b"r2.tn.routetest");
+// SENDTO target: if non-zero, THIS board is the origin (A) and sends directed requests to this dest (D).
+#[cfg(feature = "routetest")]
+static ROUTETEST_DEST: AtomicU32 = AtomicU32::new(0);
+static IDENTIFY_TICKS: AtomicU32 = AtomicU32::new(0); // 50ms LED-loop ticks of SOLID remaining
+
+// ─────────────────────────── Real-TG persona (#20) ───────────────────────────
+/// Flash offset of the provisioned persona bundle (composer write-bins it raw here).
+const PERSONA_OFFSET: u32 = 0x12000;
+
+/// A provisioned trust-group persona, read raw from flash (R2-KEYSTORE v0.2).
+struct Persona {
+    tg_label: heapless::String<40>, // tg_id UUID string — the real TG label (off "DEMO")
+    tg_hash: u32,                   // FNV-1a-32(tg_id) = frame target_group
+    hk: [u8; 32],                   // group HMAC key — RECEIVED, used directly by the gate
+    hive_id: u32,                   // FNV-1a-32(UUID(HKDF(master_secret, tg_id)))
+}
+
+/// Read + decode the persona bundle from flash @0x12000. None if absent/invalid
+/// (firmware then falls back to the demo TG). Called BEFORE the radio starts, so the
+/// esp-storage flash read can't collide with WiFi (esp-storage#31).
+fn read_persona() -> Option<Persona> {
+    use embedded_storage::ReadStorage;
+    let mut flash = esp_storage::FlashStorage::new();
+    let mut buf = [0u8; 256];
+    flash.read(PERSONA_OFFSET, &mut buf).ok()?;
+    // SHARED parser (north-star, core 1b93108): r2_trust::parse_persona does the r2_cbor
+    // decode + canonical derive_hive_id + tg_hash internally, so consume can't disagree
+    // with composer's producer. Our only platform glue is the esp-storage flash read above.
+    let p = r2_trust::parse_persona(&buf)?;
+    let mut tg_label: heapless::String<40> = heapless::String::new();
+    tg_label.push_str(p.tg_id).ok()?;
+    Some(Persona { tg_label, tg_hash: p.tg_hash, hk: p.hk, hive_id: p.hive_id })
+}
