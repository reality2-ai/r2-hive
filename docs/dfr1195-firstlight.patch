+/// Sync NegotiationRadio façade over the async BLE bridge + the WiFi data plane.
+#[cfg(feature = "ble")]
+struct EspNegRadio;
+#[cfg(feature = "ble")]
+impl r2_discovery::negotiation::NegotiationRadio for EspNegRadio {
+    fn advertise(&mut self, _beacon: &r2_discovery::negotiation::BeaconAd) {
+        // the async advertise loop keeps the beacon up continuously (S0–S4); nothing per-poll.
+    }
+    fn poll_scan(&mut self) -> Option<r2_discovery::negotiation::NegObservation> {
+        let obs = SCAN_OBS.lock(|c| c.borrow_mut().pop_front());
+        obs.map(|(h, pc, ps)| {
+            r2_discovery::negotiation::NegObservation::new(h, pc, r2_discovery::beacon::PowerState::from_bits(ps))
+        })
+    }
+    fn send_control(&mut self, peer: r2_discovery::HiveId, msg: &r2_discovery::negotiation::ControlMsg) {
+        let mut b = [0u8; r2_discovery::negotiation::ControlMsg::MAX_ENCODED_LEN];
+        let n = msg.encode(&mut b);
+        CTRL_OUT.lock(|c| {
+            let mut q = c.borrow_mut();
+            if q.is_full() {
+                let _ = q.pop_front();
+            }
+            let _ = q.push_back((peer, b, n));
+        });
+    }
+    fn poll_control(&mut self) -> Option<(r2_discovery::HiveId, r2_discovery::negotiation::ControlMsg)> {
+        let item = CTRL_IN.lock(|c| c.borrow_mut().pop_front());
+        item.and_then(|(h, b, n)| r2_discovery::negotiation::ControlMsg::decode(&b[..n]).map(|m| (h, m)))
+    }
+    fn bring_up_provider(&mut self, _p: &r2_discovery::negotiation::DataPlaneParams) -> bool {
+        // M8c: the provider already serves the "r2-tn-form" SoftAP from boot → data plane is up.
+        DATA_PLANE_AVAIL.store(true, Ordering::Relaxed);
+        true
+    }
+    fn join_provider(&mut self, _p: &r2_discovery::negotiation::DataPlaneParams) -> bool {
+        // M8c: signal the wifi task to connect this joiner to the provider's SoftAP (real WiFi form).
+        // DATA_PLANE_AVAIL is set by the wifi task once the link is actually up.
+        DATA_PLANE_JOIN.signal(());
+        true
+    }
+    fn data_plane_state(&self) -> r2_discovery::negotiation::DataPlaneState {
+        if DATA_PLANE_AVAIL.load(Ordering::Relaxed) {
+            r2_discovery::negotiation::DataPlaneState::Available
+        } else {
+            r2_discovery::negotiation::DataPlaneState::Unavailable
+        }
+    }
+    fn teardown_data_plane(&mut self) {
+        DATA_PLANE_AVAIL.store(false, Ordering::Relaxed);
+    }
+    fn now_ms(&self) -> u64 {
+        embassy_time::Instant::now().as_millis()
+    }
+}
+
+/// M9: run the S0–S4 negotiation engine over the sync EspNegRadio (driven by the async bridge).
+#[cfg(feature = "ble")]
+#[embassy_executor::task]
+async fn engine_task(my_hive: u32) {
+    use r2_discovery::beacon::PowerState;
+    use r2_discovery::negotiation::{NegotiationEngine, NegotiationState, NodeCaps};
+    let mut radio = EspNegRadio;
+    let mut eng = NegotiationEngine::<16>::new(my_hive, NodeCaps::new(true, PowerState::Normal), 5000, 10000);
+    let mut prev: Option<NegotiationState> = None;
+    let mut ticks = 0u32;
+    let mut requested = false;
+    loop {
+        // Discover for ~3s first (let the roster fill from scans/injected obs) BEFORE requesting the
+        // data plane, so the election sees peers instead of self-electing alone.
+        if !requested && ticks >= 15 {
+            eng.request_data_plane();
+            requested = true;
+            println!("r2-dfr1195: NEG requesting data plane (roster discovered)");
+        }
+        ticks += 1;
+        let st = eng.poll(&mut radio);
+        if prev != Some(st) {
+            println!("r2-dfr1195: NEG state -> {st:?} provider={:?}", eng.provider());
+            prev = Some(st);
+        }
+        Timer::after(Duration::from_millis(200)).await;
+    }
+}
+
+// LoRa (#21/#22) first-light task — concrete-typed for the embassy executor. Configures the SX1262
+// (TCXO 1.8V is REQUIRED on the DFR1195 or the PLL never locks), then loops: poll RX ~3s + TX a beacon
+// (my_hive + seq). RXEN (GPIO42) toggled around TX/RX as a stopgap until core adds the RXEN driver param.
+// First light = two DFRs mutually receiving each other's beacons (LORA-RX from=<peer>).
+#[cfg(feature = "lora")]
+type LoraRadioTy = Sx1262<
+    ExclusiveDevice<Spi<'static, esp_hal::Blocking>, Output<'static>, Delay>,
+    Input<'static>,
+    Output<'static>,
+    Delay,
+>;
+
+#[cfg(feature = "lora")]
+// ─── R2-BEACON §8.1 — the LoRa discovery beacon (RBID, NO hive_id, NO counter) ──────────────────────
+// The km-range active-discovery signpost (§8.1). Replaces the interim `[hive_id_be32 | seq]` 8-byte beacon
+// — the exact §8.1.2 conformance gate ("an interim implementation which broadcast [hive_id | seq] in the
+// clear"). Wire format (§8.1.1, 15-byte core, big-endian): [0]=magic 0xB2 · [1]=version 0x01 · [2]=flags
+// (bit7 profile=0, bit6 has_bloom=0 MUST) · [3..11]=rbid (8B Rotating Beacon ID, §6.1) · [11..15]=class_hash
+// (FNV-1a-32 of the class string, §4) · [15]=tx_power (OPTIONAL i8 dBm@1m). The rbid uses core's RBID
+// primitives so a fellow TG member resolves rbid→hive with NO key distribution (§6.1), while a km-range
+// stranger without `hk` can neither predict nor correlate it across epochs. NO sequence field (§8.1.2 #2:
+// a cross-epoch counter re-links rotated RBIDs — forbidden). T_rotate = 3600 s (§8.1.3). Airtime: priority
+// 4, lowest (R2-LORA §4.4) — emitted only when no higher-priority traffic is queued (§8.1.4).
+#[cfg(feature = "lora")]
+const LORA_BEACON_CORE_LEN: usize = 15;
+#[cfg(feature = "lora")]
+const LORA_BEACON_T_ROTATE_S: u64 = 3600; // §8.1.3 LoRa T_rotate = 1 h (sparse/airtime-bounded cadence)
+
+/// FNV-1a-32 of the class string (§4) → the beacon `class_hash`.
+#[cfg(feature = "lora")]
+fn fnv1a32(s: &[u8]) -> u32 {
+    let mut h: u32 = 0x811c_9dc5;
+    for &b in s {
+        h ^= b as u32;
+        h = h.wrapping_mul(0x0100_0193);
+    }
+    h
+}
+
+/// The device-class string per role (§4) — gives §8.1 pre-connection filtering a class to match on.
+#[cfg(feature = "lora")]
+fn role_class_hash(role: Role) -> u32 {
+    fnv1a32(
+        match role {
+            Role::Repeater => "r2.repeater",
+            Role::Sensor => "r2.sensor",
+            Role::Bridge => "r2.bridge",
+            Role::Receiver => "r2.receiver",
+        }
+        .as_bytes(),
+    )
+}
+
+/// Current RBID rotation epoch (§6.1: `floor(shared_coarse_time / T_rotate)`). INTERIM: the shared
+/// coarse-time base is not yet wired on this tier (the BLE beacon path uses the same epoch=0 placeholder,
+/// pending scan→resolve_rbid_windowed); the rbid is still NOT a stable id (it is the keyed §6.1 RBID, not
+/// the hive_id). When a shared coarse-time base lands, return `coarse_time_s / LORA_BEACON_T_ROTATE_S`.
+#[cfg(feature = "lora")]
+fn current_beacon_epoch() -> u64 {
+    let _ = LORA_BEACON_T_ROTATE_S;
+    0
+}
+
+/// Build this node's §8.1 LoRa beacon into `buf`; returns the byte length (15, or 16 with tx_power).
+#[cfg(feature = "lora")]
+fn build_lora_beacon(
+    buf: &mut [u8; 16],
+    hk: &[u8; 32],
+    my_hive: u32,
+    class_hash: u32,
+    tx_power: Option<i8>,
+) -> usize {
+    use r2_discovery::beacon::{
+        compute_rbid, derive_beacon_session_key, BEACON_VERSION, R2_BEACON_MAGIC,
+    };
+    let sk = derive_beacon_session_key(hk, my_hive);
+    let rbid = compute_rbid(&sk, current_beacon_epoch());
+    buf[0] = R2_BEACON_MAGIC; // 0xB2
+    buf[1] = BEACON_VERSION; // 0x01
+    buf[2] = 0; // flags: bit7 (profile)=0, bit6 (has_bloom)=0 (§8.1.1 MUST); others default 0
+    buf[3..11].copy_from_slice(&rbid);
+    buf[11..15].copy_from_slice(&class_hash.to_be_bytes()); // big-endian (§8.1.1)
+    match tx_power {
+        Some(p) => {
+            buf[15] = p as u8;
+            16
+        }
+        None => LORA_BEACON_CORE_LEN,
+    }
+}
+
+/// Recognise a §8.1 LoRa beacon (magic+version+length). Returns (rbid, class_hash, tx_power) — NOT the
+/// hive_id: a stranger cannot resolve it; a fellow member resolves rbid→hive via resolve_rbid_windowed
+/// (§6.1) against the member registry (registry-driven resolution is a follow-up; logged unresolved here).
+#[cfg(feature = "lora")]
+fn decode_lora_beacon(p: &[u8]) -> Option<([u8; 8], u32, Option<i8>)> {
+    use r2_discovery::beacon::{BEACON_VERSION, R2_BEACON_MAGIC};
+    // Exactly 15 or 16 bytes — distinguishes a beacon from a `[4B hive | core frame]` data frame (which is
+    // always larger than a 12-byte R2-WIRE header), so the demux is unambiguous on the shared carrier.
+    if (p.len() != LORA_BEACON_CORE_LEN && p.len() != LORA_BEACON_CORE_LEN + 1)
+        || p[0] != R2_BEACON_MAGIC
+        || p[1] != BEACON_VERSION
+    {
+        return None;
+    }
+    let mut rbid = [0u8; 8];
+    rbid.copy_from_slice(&p[3..11]);
+    let class_hash = u32::from_be_bytes([p[11], p[12], p[13], p[14]]);
+    let tx_power = if p.len() == LORA_BEACON_CORE_LEN + 1 { Some(p[15] as i8) } else { None };
+    Some((rbid, class_hash, tx_power))
+}
+
+#[cfg(feature = "lora")]
+#[embassy_executor::task]
+async fn lora_task(
+    mut radio: LoraRadioTy,
+    mut rxen: Output<'static>,
+    my_hive: u32,
+    hk: [u8; 32],
+    class_hash: u32,
+) {
+    // BENCH first-light: boards are ~30cm apart -> +20dBm SF12 SATURATES the RX (close-range overload ->
+    // every packet detected but CRC-fails). Drop to the SX1262 high-PA minimum (-9 dBm) for the bench.
+    // (The Wairoa deployment uses the full +20/+22 for 18km hops; this override is bench-only.)
+    let mut cfg = wairoa_as923_nz();
+    cfg.tx_power_dbm = -9;
+    // BENCH first-light: SF12 = ~2s time-on-air for an 8B packet, but the listen/TX windows are ~3s, so the
+    // RX often catches PARTIAL packets (window opens mid-frame) -> CRC fails every time. SF7 = ~40ms ToA ->
+    // the 3s listen easily catches a COMPLETE frame -> clean CRC. (Wairoa deployment keeps SF12 for 18km
+    // range; SF is config-driven. This bench override proves the link cleanly; SF12 range is a later test.)
+    cfg.spreading_factor = 7;
+    match radio.configure(&cfg) {
+        Ok(()) => println!(
+            "r2-dfr1195: LORA configure OK (916.8MHz SF12 BW125 sync0x21 TCXO1.8 txpwr={}dBm)",
+            cfg.tx_power_dbm
+        ),
+        Err(e) => println!("r2-dfr1195: LORA configure ERR {e:?} (check TCXO/wiring)"),
+    }
+    rxen.set_high();
+    let _ = radio.listen();
+    loop {
+        // listen ~3s
+        for _ in 0..30 {
+            match radio.poll() {
+                Ok(Some(RadioEvent::RxDone)) => {
+                    let mut buf = [0u8; 64];
+                    if let Ok(info) = radio.read(&mut buf) {
+                        if let Some((rbid, ch, _txp)) = decode_lora_beacon(&buf[..info.len]) {
+                            // §8.1 discovery beacon — log the RBID (NOT a hive_id) + class hash.
+                            println!(
+                                "r2-dfr1195: LORA-BEACON rbid={:02x}{:02x}{:02x}.. class={ch:08x} rssi={}dBm snr={}dB",
+                                rbid[0], rbid[1], rbid[2], info.rssi_dbm, info.snr_db
+                            );
+                        } else {
+                            println!(
+                                "r2-dfr1195: LORA-RX len={} rssi={}dBm snr={}dB",
+                                info.len, info.rssi_dbm, info.snr_db
+                            );
+                        }
+                    }
+                }
+                Ok(Some(RadioEvent::CrcError)) => println!("r2-dfr1195: LORA-RX crc-err"),
+                _ => {}
+            }
+            embassy_time::Timer::after(embassy_time::Duration::from_millis(100)).await;
+        }
+        // TX a §8.1 LoRa discovery beacon (RBID, NOT [hive|seq] — closes the §8.1.2 conformance gate).
+        let mut bbuf = [0u8; 16];
+        let blen = build_lora_beacon(&mut bbuf, &hk, my_hive, class_hash, Some(-9));
+        let pl = &bbuf[..blen];
+        rxen.set_low();
+        match radio.transmit(pl) {
+            Ok(()) => {
+                for _ in 0..25 {
+                    if let Ok(Some(RadioEvent::TxDone)) = radio.poll() {
+                        break;
+                    }
+                    embassy_time::Timer::after(embassy_time::Duration::from_millis(20)).await;
+                }
+                println!("r2-dfr1195: LORA-TX §8.1 beacon ({}B)", pl.len());
+            }
+            Err(e) => println!("r2-dfr1195: LORA-TX ERR {e:?}"),
+        }
+        rxen.set_high();
+        let _ = radio.listen();
+    }
+}
+
+
+// ── TN-FR-1: BL-200 MESSAGE-PASSING over LoRa (loraroute) ──────────────────────────────────────────
+// Replaces the naive half-duplex lora_mesh_task with core's READY LoRaTransport data-plane:
+// service(now_ms) does continuous-RX + TX-pacing + §4.2/§4.3 airtime-gating (defer-not-drop) in ONE call.
+// Carries ALL frames (Events + HBs), unlike loramesh which TX'd HB-only. A 4-byte IMMEDIATE-SENDER hive
+// is PREPENDED on TX and read back on RX = the LoRa analogue of ESP-NOW's L2 src MAC on a MAC-less
+// broadcast medium: it (a) feeds the hive-based can_hear MASK that forces A->B->C multi-hop, and (b)
+// threads the true RELAYER (not the origin) as src_hive into DATA_RX for the §4.3.4 TrailReinforcer. The
+// R2-WIRE ORIGIN (A) is carried INSIDE the frame and decoded into ForwardRequest.origin by io_task —
+// distinct from the immediate sender, per core's BL-200 contract.
+
+// RXEN-aware LoRaRadio wrapper: core's LoRaTransport drives the radio through the LoRaRadio trait but is
+// chip-agnostic — it doesn't know the DFR1195's RF switch (GPIO42, HIGH-RX/LOW-TX). Wrap so transmit/
+// standby pull RXEN low and listen pulls it high, keeping the RF-switch concern in the thin per-platform
+// layer (the one-codebase seam). Delegates everything else to the inner Sx1262.
+#[cfg(feature = "loraroute")]
+struct RxenRadio {
+    inner: LoraRadioTy,
+    rxen: Output<'static>,
+}
+#[cfg(feature = "loraroute")]
+impl LoRaRadio for RxenRadio {
+    type Error = <LoraRadioTy as LoRaRadio>::Error;
+    fn configure(&mut self, cfg: &r2_transport::lora::LoRaConfig) -> Result<(), Self::Error> {
+        self.inner.configure(cfg)
+    }
+    fn transmit(&mut self, payload: &[u8]) -> Result<(), Self::Error> {
+        self.rxen.set_low(); // RF switch -> TX
+        self.inner.transmit(payload)
+    }
+    fn listen(&mut self) -> Result<(), Self::Error> {
+        self.rxen.set_high(); // RF switch -> RX (continuous listen between sends)
+        self.inner.listen()
+    }
+    fn poll(&mut self) -> Result<Option<RadioEvent>, Self::Error> {
+        self.inner.poll()
+    }
+    fn read(&mut self, buf: &mut [u8]) -> Result<r2_transport::lora::RxInfo, Self::Error> {
+        self.inner.read(buf)
+    }
+    fn max_payload_len(&self) -> usize {
+        self.inner.max_payload_len()
+    }
+    fn standby(&mut self) -> Result<(), Self::Error> {
+        self.rxen.set_low(); // prep for the transmit() that LoRaTransport::service issues next
+        self.inner.standby()
+    }
+}
+
+/// Hive-based can_hear MASK for the LoRa broadcast medium (no L2 MAC to filter on, so the immediate
+/// sender is carried per-frame). Hardcoded 3-board chain so the bench run is self-contained (no fragile
+/// raw-tty provisioning): A(0dcadbf8)={B}, B(2cab5f69)={A,C}, C(f91c8911)={B} -> A<->C NOT direct -> A->C
+/// only via B's relay. Unknown sender (0 = no prepend / pre-mapping) and other hives: hear all.
+#[cfg(feature = "loraroute")]
+fn can_hear_hive(my_hive: u32, sender: u32) -> bool {
+    // Released bench set (D1/D2/D3, all TG-A): A=originator, B=relay, C=receiver. A<->C masked.
+    const A: u32 = FR4_SENSOR_HIVE;
+    const B: u32 = FR4_ROUTER_HIVE;
+    const C: u32 = FR4_BRIDGE_HIVE;
+    if sender == 0 {
+        return true;
+    }
+    match my_hive {
+        A => sender == B,
+        B => sender == A || sender == C,
+        C => sender == B,
+        _ => true,
+    }
+}
+
+/// LoRa message-passing carrier bridge (loraroute) — drains DATA_TX (io_task's routed Events + HBs) onto
+/// the air via core's LoRaTransport, and feeds RX -> DATA_RX so the PROVEN io_task r2-route + TrailReinforcer
+/// run over LoRa. service(now_ms) is the data-plane: it self-paces TX within the airtime budget (defer-not-
+/// drop) and drains RX in the same call — call it every tick = continuous-RX. SF7 bench (916.8/BW125/-9dBm).
+#[cfg(feature = "loraroute")]
+#[embassy_executor::task]
+async fn lora_route_task(
+    radio: LoraRadioTy,
+    rxen: Output<'static>,
+    my_hive: u32,
+    hk: [u8; 32],
+    class_hash: u32,
+) {
+    use r2_transport::{LoRaTransport, Transport}; // Transport trait brings send()/current_mtu() into scope
+    let mut cfg = wairoa_as923_nz();
+    cfg.tx_power_dbm = -9; // bench close-range (30cm); the Wairoa deployment uses +20/+22 for 18km
+    cfg.spreading_factor = 7; // SF7 ~40ms ToA = clean bench (SF12 range test is a later rung)
+    // labrig: RF-ISOLATE the laptop rig — shift the LoRa carrier off tuxedo's 916.8 (>3 MHz = no BW125 overlap)
+    // so the co-located tuxedo D-rig's traffic is OUT OF BAND (eliminates the run-1 LoRa-collision confound).
+    #[cfg(feature = "labrig")]
+    {
+        cfg.freq_hz = 919_800_000;
+    }
+    let beacon_tx_power: i8 = cfg.tx_power_dbm; // capture before cfg moves into the transport (§8.1 tx_power)
+    let lora = match LoRaTransport::new(RxenRadio { inner: radio, rxen }, cfg, 8) {
+        Ok(l) => {
+            println!("r2-dfr1195: LORA-ROUTE up (SF7 BW125 916.8 sync0x21 -9dBm) — BL-200 message-passing over LoRa");
+            l
+        }
+        Err(e) => {
+            println!("r2-dfr1195: LORA-ROUTE configure ERR {e:?} (check TCXO/wiring)");
+            return;
+        }
+    };
+    let mut last_nbr_recalc = 0u32;
+    // LOOSE-JITTER carrier state (Roy's refinement: the HB is loose BACKGROUND liveness, not tight PCO —
+    // sidestep synchronized-fire). Even if the PCO syncs the 3 boards' FIRES, each board scatters its own
+    // on-air TX start with an ALOHA-style random backoff so their ~40ms SF7 frames rarely overlap on the
+    // half-duplex channel (the metal symptom: B's frames reached A/C ~1/100s under lockstep TX). NOT CSMA
+    // (the deferred redesign) — just per-board TX decorrelation. Seeded per-board by my_hive.
+    let mut lcg: u32 = my_hive ^ 0x9E37_79B9;
+    // R2-LORA §6.5.2 (MUST): randomise the FIRST post-boot TX to de-correlate the mains-restore cohort
+    // (a power blip restarts every node at once; CAD alone won't break a synchronised tie). Seed the
+    // initial backoff from the per-board LCG (distinct per my_hive ⇒ distinct first-TX offset per board)
+    // instead of 0 (which would TX immediately on the first frame = a synchronised cohort).
+    lcg = lcg.wrapping_mul(1_664_525).wrapping_add(1_013_904_223);
+    let mut tx_backoff: i32 = ((lcg >> 22) % 200) as i32; // 0..200 ticks @5ms = 0..1s first-TX spread
+    // R2-BEACON §8.1 discovery beacon — emitted on the field path as the lowest-priority class (§8.1.4 /
+    // R2-LORA §4.4 priority 4). NO fixed interval: this is a MIN-interval floor; it is enqueued only when
+    // no app traffic was pending this tick (higher-priority first), and the transport's §4.2/§4.3 airtime
+    // budget defers it further under load — so dense/busy meshes naturally lengthen the inter-beacon gap.
+    let mut last_beacon_ms: u32 = 0;
+    const LORA_BEACON_MIN_INTERVAL_MS: u32 = 30_000;
+    loop {
+        let now_ms = embassy_time::Instant::now().as_millis() as u32;
+        // TX: drain io_task's outbound frames behind a per-board random backoff -> PREPEND the 4-byte
+        // immediate-sender hive -> enqueue. service() then paces onto the air within the airtime budget.
+        if tx_backoff > 0 {
+            tx_backoff -= 1;
+        } else {
+            let mut sent_any = false;
+            while let Ok((frame, n)) = DATA_TX_LORA.try_receive() {
+                let mut carrier = [0u8; 260];
+                carrier[0..4].copy_from_slice(&my_hive.to_be_bytes());
+                let m = n.min(256);
+                carrier[4..4 + m].copy_from_slice(&frame[..m]);
+                let _ = lora.send(0, &carrier[..4 + m]); // back-pressure on a full queue, never a stall
+                sent_any = true;
+            }
+            if sent_any {
+                lcg = lcg.wrapping_mul(1_664_525).wrapping_add(1_013_904_223);
+                tx_backoff = ((lcg >> 22) % 60) as i32; // 0..60 ticks @5ms = 0..300ms random backoff
+            } else if now_ms.wrapping_sub(last_beacon_ms) >= LORA_BEACON_MIN_INTERVAL_MS {
+                // §8.1.4: no app traffic was queued this tick (sent_any == false) → enqueue the lowest-
+                // priority §8.1 discovery beacon. The transport's airtime budget defers it under load; a
+                // full queue back-pressures (beacons are sheddable). Beacon = raw 15B (NO 4B hive prepend).
+                let mut bbuf = [0u8; 16];
+                let blen = build_lora_beacon(&mut bbuf, &hk, my_hive, class_hash, Some(beacon_tx_power));
+                if lora.send(0, &bbuf[..blen]).is_ok() {
+                    last_beacon_ms = now_ms;
+                }
+            }
+        }
+        // SERVICE: one data-plane step — TX-pacing + RX-drain. Returns the carrier frame on RxDone.
+        if let Some((carrier, info)) = lora.service(now_ms) {
+            if let Some((rbid, ch, _txp)) = decode_lora_beacon(&carrier) {
+                // §8.1 discovery beacon (demuxed by magic+version+len, ahead of the data-frame path). The
+                // rbid is NOT a hive_id; resolving rbid→hive (resolve_rbid_windowed, §6.1) against the
+                // member registry is a follow-up — logged unresolved here (presence signpost).
+                println!(
+                    "r2-dfr1195: LORA-BEACON rbid={:02x}{:02x}{:02x}.. class={ch:08x} rssi={}dBm",
+                    rbid[0], rbid[1], rbid[2], info.rssi_dbm
+                );
+            } else if carrier.len() >= 4 {
+                let sender = u32::from_be_bytes([carrier[0], carrier[1], carrier[2], carrier[3]]);
+                // RX diagnostic (the metal proof + link health): every good frame, its immediate sender,
+                // RSSI, and whether the hive-MASK admits it.
+                println!(
+                    "r2-dfr1195: LORA-RX sender={sender:08x} len={} rssi={}dBm masked={}",
+                    carrier.len(), info.rssi_dbm, !can_hear_hive(my_hive, sender)
+                );
+                // Hive-MASK: drop frames from a non-allowed immediate sender (forces the A->B->C multi-hop
+                // on the broadcast-on-air medium where every node physically hears every node).
+                if can_hear_hive(my_hive, sender) {
+                    let inner = &carrier[4..];
+                    let l = inner.len().min(256);
+                    let mut f = [0u8; 256];
+                    f[..l].copy_from_slice(&inner[..l]);
+                    // src_hive = the IMMEDIATE SENDER (relayer), per the §4.3.4 reinforcer contract — NOT the
+                    // R2-WIRE origin (io_task decodes that from the frame for ForwardRequest.origin).
+                    let _ = DATA_RX.try_send((f, l, sender, r2_route::Transport::Lora as u8));
+                }
+            }
+        }
+        // §4.2 airtime duty tracks neighbour density (~every 60s). We don't hold the engine's nbr table here,
+        // so approximate from the dashboard NBRS (good enough for the 0-2/3-4/>=5 duty tiers).
+        let now_s = (now_ms / 1000) as u32;
+        if now_s.wrapping_sub(last_nbr_recalc) >= 60 {
+            last_nbr_recalc = now_s;
+            lora.set_neighbour_count(NBRS.load(Ordering::Relaxed) as usize);
+        }
+        embassy_time::Timer::after(embassy_time::Duration::from_millis(5)).await;
+    }
+}
